{
  "schema_version": "1.2.0",
  "contract_id": "next_workflow_team_agent_security",
  "activation_mode": "planned",
  "layers": [
    {"depth": 0, "kind": "orchestrator", "canonical_name": "Orchestrator Agent", "may_delegate_to": ["lead"]},
    {"depth": 1, "kind": "lead", "canonical_name": "Lead Agent", "may_delegate_to": ["task"]},
    {"depth": 2, "kind": "task", "canonical_name": "Task Agent", "may_delegate_to": []}
  ],
  "lead_roles": ["Value Design Lead", "Planning Design Lead", "Implementation Lead", "Independent Review Lead", "Safety and Acceptance Decision Lead"],
  "external_roles": ["Developer/Owner", "Runtime/Tools"],
  "rigor_topology": {
    "L1": {"max_leads": 0, "max_tasks": 0, "writer": "orchestrator_as_implementation_lead"},
    "L2": {"max_leads": 1, "max_tasks": 0, "writer": "orchestrator_or_one_implementation_lead"},
    "L3": {"max_leads": 5, "max_tasks": 8, "writer": "implementation_lead_or_disjoint_owned_tasks"},
    "L4": {"max_leads": 5, "max_tasks": 12, "writer": "implementation_lead_or_disjoint_owned_tasks"},
    "L5": {"max_leads": 5, "max_tasks": 16, "writer": "implementation_lead_or_disjoint_owned_tasks"}
  },
  "schemas": {
    "AgentDefinition": ["agent_id", "layer", "role", "capability_requirements", "allowed_actions", "allowed_tools"],
    "DelegationGrant": ["grant_id", "parent_agent_id", "child_role", "scope", "authority_fingerprint", "budget", "ownership", "expires_at"],
    "AgentLaunchIntent": ["intent_id", "grant_fingerprint", "selection_fingerprint", "effective_fingerprint", "selected_model", "selected_native_reasoning", "selected_normalized_effort", "context_fingerprint", "reservation_id", "invariant_fingerprint", "instruction_fingerprint", "envelope_fingerprint", "delivery_fingerprint", "actual_observed"],
    "AgentRun": ["run_id", "intent_id", "launch_intent_fingerprint", "parent_run_id", "depth", "state", "process_group_identity", "launch_observation", "actual_attestation_id", "ownership"],
    "AgentResultCandidate": ["candidate_id", "run_id", "lifecycle_run_id", "result_fingerprint", "process_identity_fingerprint", "launch_report", "accepted"],
    "AgentResult": ["result_id", "run_id", "candidate_record_id", "candidate_result_fingerprint", "status", "provenance", "scope_validation", "lead_review", "orchestrator_review", "validator_disposition"]
  },
  "trust_envelopes": {
    "trusted_control": ["policy", "authority_decision", "delegation_grant", "structured_arguments"],
    "untrusted_data": ["repository_text", "provider_output", "agent_output", "logs", "external_projection"],
    "untrusted_data_cannot_become_instruction": true
  },
  "launch_security": {
    "common_gateway_required": true,
    "requested_selected_effective_authorized_pre_spawn": true,
    "actual_observed_absent_pre_spawn": true,
    "actual_observed_required_before_running": true,
    "silent_provider_or_model_substitution": "forbidden",
    "actual_observation_requires_injected_independent_verifier": true,
    "post_launch_admission_failure_requires_injected_quarantine_or_terminate": true,
    "failure_and_fence_persist_before_stop": true,
    "unmanaged_process_after_admission_failure": "forbidden",
    "authority_owned_task_delivery": true,
    "applicable_agents_and_instruction_fingerprinted": true,
    "exact_delivery_fingerprint_bound": true,
    "provider_neutral_run_lifecycle_port": ["start", "observe", "cancel", "terminate", "collect_result", "reconcile", "recover"],
    "run_lifecycle_port_requires_protected_factory_brand": true,
    "run_lifecycle_runtime_writer_is_private_and_store_bound": true,
    "authority_fenced_cli_executor_requires_protected_lifecycle_brand": true,
    "prompt_fingerprint_read_preserves_child_stdin_offset": true,
    "detached_process_group_owned": true,
    "two_stage_crash_proof_startup_barrier": true,
    "controller_eof_is_never_execution_release": true,
    "repository_git_and_owner_trust_root_overlap": "forbidden",
    "control_metadata_ancestors_and_descendants": "forbidden",
    "private_response_directory_is_descriptor_pinned": true,
    "contained_process_identity_is_persisted_for_recovery": true,
    "task_delivery_reverified_immediately_before_finalization": true,
    "candidate_fingerprint_required_for_review_and_closure": true,
    "candidate_requires_completed_runtime_run_provenance": true,
    "candidate_requires_durable_launch_intent_and_exact_admission_subject": true,
    "candidate_requires_exact_launch_request_fingerprint": true,
    "candidate_relation_and_event_topology_is_exact": true,
    "agent_authority_records_require_protected_owner_trust_brand": true,
    "completed_runtime_replay_preserves_result_fingerprint": true,
    "closed_result_schema_and_redaction_required": true
  },
  "ownership": {"read_only_default": true, "concurrent_writes_require_disjoint_paths": true, "integration_order_required": true, "independent_review_is_non_writer": true},
  "budget_dimensions": ["agents", "parallel", "runtime_ms", "tokens", "cost", "retries", "network_bytes", "disk_bytes"],
  "child_cannot_expand": ["scope", "authority", "budget", "capability", "ownership", "depth"],
  "interruption_states": ["STARTING", "RUNNING", "INTERRUPTING", "INTERRUPTED", "COMPLETED", "FAILED", "STOPPED"],
  "refusal_codes": ["DEPTH_EXCEEDED", "MISSING_LEAD_PARENT", "BUDGET_EXCEEDED", "WRITE_OWNERSHIP_CONFLICT", "UNTRUSTED_CONTROL_INPUT", "MISSING_ACTUAL_ATTESTATION", "PROVIDER_SUBSTITUTION", "DELEGATION_NOT_ALLOWED"]
}
