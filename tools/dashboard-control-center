#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_DIR="$ROOT/.dashboard-control-center"
DATA_FILE="$RUNTIME_DIR/dashboard-data.json"
DEFAULT_PORT="${DASHBOARD_CONTROL_CENTER_PORT:-5173}"
REFRESH_SECONDS="${DASHBOARD_CONTROL_CENTER_REFRESH_SECONDS:-3}"

usage() {
  cat <<'USAGE'
Usage:
  ./tools/dashboard-control-center snapshot [--output <file>]
  ./tools/dashboard-control-center build
  ./tools/dashboard-control-center check
  ./tools/dashboard-control-center open

Maintained entry point for the browser dashboard control center with a guarded Settings update path.
USAGE
}

require_node_tools() {
  if [[ ! -x "$ROOT/node_modules/.bin/vite" || ! -x "$ROOT/node_modules/.bin/playwright" ]]; then
    printf 'Dashboard control-center dependencies are not installed.\n' >&2
    printf 'Run npm install before using this tool.\n' >&2
    return 1
  fi
}

snapshot_selected_menu() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  DASHBOARD_CONTROL_CENTER_SNAPSHOT="$file" node <<'NODE'
const fs = require("node:fs");

let data;
try {
  data = JSON.parse(fs.readFileSync(process.env.DASHBOARD_CONTROL_CENTER_SNAPSHOT, "utf8"));
} catch (_error) {
  process.exit(1);
}
const menuId = String(data?.selected_context?.menu_id || "");
if (!/^(step_1_7|step_1_14|advanced|free-development|product-improvement|external-integration|lesson-repository-improvement)$/.test(menuId)) {
  process.exit(1);
}
process.stdout.write(menuId);
NODE
}

write_snapshot() {
  local output="$1"
  local output_dir tmp selected_menu
  output_dir="$(dirname "$output")"
  mkdir -p "$output_dir"
  tmp="$(mktemp "$output_dir/.dashboard-data.XXXXXX.tmp")"
  selected_menu="${DASHBOARD_SELECTED_MENU_ID:-}"
  if [[ -z "$selected_menu" ]]; then
    selected_menu="$(snapshot_selected_menu "$output" 2>/dev/null || true)"
  fi
  selected_menu="${selected_menu:-step_1_14}"
  if DASHBOARD_SELECTED_MENU_ID="$selected_menu" "$ROOT/tools/dashboard-data" >"$tmp" && (cd "$ROOT" && DASHBOARD_EXPECTED_MENU_ID="$selected_menu" node --input-type=module - "$tmp" <<'NODE'
import fs from "node:fs";
import { dashboardDataValidationError, validateDashboardData } from "./vite.config.mjs";

const file = process.argv[2];
const body = fs.readFileSync(file, "utf8");
let data;
try {
  data = JSON.parse(body);
} catch (error) {
  console.error(`invalid dashboard-data snapshot: ${error.message}`);
  process.exit(1);
}
if (!validateDashboardData(body)) {
  console.error(`dashboard-data snapshot failed schema validation: ${dashboardDataValidationError() || "unknown"}`);
  process.exit(1);
}
if (String(data?.selected_context?.menu_id || "") !== process.env.DASHBOARD_EXPECTED_MENU_ID) {
  console.error(`dashboard-data snapshot selected menu mismatch: expected ${process.env.DASHBOARD_EXPECTED_MENU_ID}`);
  process.exit(1);
}
NODE
  ); then
    mv "$tmp" "$output"
  else
    rm -f "$tmp"
    return 1
  fi
}

refresh_snapshots_loop() {
  local output="$1"
  while :; do
    sleep "$REFRESH_SECONDS" || return
    write_snapshot "$output" || printf 'Dashboard control-center refresh kept the last valid snapshot.\n' >&2
  done
}

dashboard_url() {
  printf 'http://127.0.0.1:%s/' "$DEFAULT_PORT"
}

port_is_listening() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    local listeners
    listeners="$(ss -ltn "sport = :$port" 2>/dev/null || true)"
    [[ "$listeners" == *LISTEN* ]]
    return
  fi
  (exec 3<>"/dev/tcp/127.0.0.1/$port") >/dev/null 2>&1
}

open_dashboard_browser_once() {
  local url="$1"
  if [[ -x /mnt/c/Windows/System32/cmd.exe ]]; then
    /mnt/c/Windows/System32/cmd.exe /C start "" "$url" >/dev/null 2>&1 && return 0
  fi
  if command -v sensible-browser >/dev/null 2>&1; then
    sensible-browser "$url" >/dev/null 2>&1 &
    return 0
  fi
  printf 'Open Dashboard Control Center manually: %s\n' "$url" >&2
}

open_dashboard_when_ready() {
  local url="$1"
  local port="$2"
  local attempt=0
  while [[ "$attempt" -lt 50 ]]; do
    if port_is_listening "$port"; then
      open_dashboard_browser_once "$url"
      return 0
    fi
    attempt=$((attempt + 1))
    sleep 0.2 || return 1
  done
  printf 'Dashboard control center is starting. Open manually if the browser does not appear: %s\n' "$url" >&2
}

build_control_center() {
  require_node_tools
  (cd "$ROOT" && npm run dashboard:build)
}

run_check() {
  "$ROOT/tools/test_dashboard_control_center.sh"
}

open_control_center() {
  if [[ $# -ne 0 ]]; then
    usage >&2
    exit 1
  fi
  if ! [[ "$DEFAULT_PORT" =~ ^[1-9][0-9]*$ ]]; then
    printf 'configured dashboard control-center port must be a positive integer.\n' >&2
    exit 1
  fi
  if ! [[ "$REFRESH_SECONDS" =~ ^[1-9][0-9]*$ ]]; then
    printf 'configured dashboard control-center refresh interval must be a positive integer.\n' >&2
    exit 1
  fi

  require_node_tools
  if port_is_listening "$DEFAULT_PORT"; then
    write_snapshot "$DATA_FILE"
    printf 'Dashboard control center is already running through maintained tooling.\n'
    printf 'Refresh the existing browser tab: %s\n' "$(dashboard_url)"
    return 0
  fi

  write_snapshot "$DATA_FILE"
  refresh_snapshots_loop "$DATA_FILE" &
  refresh_pid="$!"
  open_dashboard_when_ready "$(dashboard_url)" "$DEFAULT_PORT" &
  opener_pid="$!"
  trap 'kill "$refresh_pid" "$opener_pid" 2>/dev/null || true' EXIT INT TERM
  printf 'Dashboard control center is opening through maintained tooling.\n'
  (
    cd "$ROOT"
    DASHBOARD_CONTROL_CENTER_DATA_FILE="$DATA_FILE" "$ROOT/node_modules/.bin/vite" --host 127.0.0.1 --port "$DEFAULT_PORT" --strictPort --clearScreen false
  ) 2>&1 | sed -E '/Local:|Network:|ready in|VITE|press h \+ enter/d'
}

cmd="${1:-open}"
shift || true

case "$cmd" in
  snapshot)
    output="$DATA_FILE"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --output)
          [[ $# -ge 2 ]] || {
            printf -- '--output requires a value.\n' >&2
            exit 1
          }
          output="$2"
          shift 2
          ;;
        *)
          usage >&2
          exit 1
          ;;
      esac
    done
    write_snapshot "$output"
    printf 'Dashboard control-center data snapshot written: %s\n' "$output"
    ;;
  build)
    build_control_center
    ;;
  check)
    run_check
    ;;
  open)
    open_control_center "$@"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
