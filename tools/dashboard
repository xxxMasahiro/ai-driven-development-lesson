#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DASHBOARD_CI_TIMEOUT_SECONDS="${DASHBOARD_CI_TIMEOUT_SECONDS:-8}"
DASHBOARD_LESSON_CONFIG="$ROOT/lesson/LESSON_CONFIG.tsv"
DASHBOARD_LESSON14_CONFIG="$ROOT/lesson/LESSON_CONFIG_14_DAYS.tsv"
export LESSON_CONFIG="${LESSON_CONFIG:-$DASHBOARD_LESSON14_CONFIG}"

# shellcheck source=tools/lib/lesson_common.sh
source "$ROOT/tools/lib/lesson_common.sh"
# shellcheck source=tools/lib/document_paths.sh
source "$ROOT/tools/lib/document_paths.sh"
# shellcheck source=tools/lib/lesson_display_labels.sh
source "$ROOT/tools/lib/lesson_display_labels.sh"
PRODUCT_ROOT="${PRODUCT_ROOT:-$(lesson_product_repo_root)}"

print_section() {
  local title="$1"
  printf '%s\n' "$title"
  printf '%s\n\n' "$(printf '%s' "$title" | sed 's/./=/g')"
}

file_status() {
  local root="$1"
  local file="$2"
  if [[ -f "$root/$file" ]]; then
    printf '%s\n' "- $file: present"
  else
    printf '%s\n' "- $file: missing"
  fi
}

next_action_from_file() {
  local file="$1"
  awk '
    /^## / {
      capture = ($0 ~ /Next Step|Remaining Work|次にやること/)
      next
    }
    capture && NF {
      print
      found = 1
      exit
    }
    END {
      if (!found) print "not recorded"
    }
  ' "$file"
}

current_state_from_file() {
  local file="$1"
  awk '
    /^## / {
      capture = ($0 ~ /Current State|Current Status|Current/)
      next
    }
    capture && NF {
      print
      found = 1
      exit
    }
    END {
      if (!found) print "not recorded"
    }
  ' "$file"
}

language_status() {
  local file="$1"
  local label="$2"
  if [[ -f "$file" ]]; then
    awk -F '\t' -v label="$label" '
      $1 !~ /^#/ && $2 != "" {
        printf "%s: %s (%s)\n", label, $2, $3
        found = 1
        exit
      }
      END {
        if (!found) printf "%s: not selected\n", label
      }
    ' "$file"
  else
    printf '%s: not selected\n' "$label"
  fi
}

optional_ci_status() {
  if command -v timeout >/dev/null 2>&1; then
    if timeout "$DASHBOARD_CI_TIMEOUT_SECONDS" "$ROOT/tools/check_ci_status.sh" --repo "$PRODUCT_ROOT"; then
      return 0
    fi
    printf 'CI status: optional dashboard lookup did not finish within %s seconds or could not complete.\n' "$DASHBOARD_CI_TIMEOUT_SECONDS"
    return 0
  fi

  "$ROOT/tools/check_ci_status.sh" --repo "$PRODUCT_ROOT" || true
}

next_approval_status() {
  local current approvals state_file
  state_file="$ROOT/learning/LESSON_STATE_14_DAYS.tsv"
  approvals="$ROOT/learning/LESSON_APPROVALS_14_DAYS.tsv"
  current="$(awk -F '\t' '$1 !~ /^#/ && $3 == "current" { print $2; exit }' "$state_file" 2>/dev/null || true)"
  if [[ -z "$current" ]]; then
    printf 'Next approval: none\n'
    return
  fi
  printf 'Next approval step: %s\n' "$current"
  if [[ -f "$approvals" ]]; then
    if awk -F '\t' -v step="$current" '$1 !~ /^#/ && $1 == step && $2 == "start" { found=1 } END { exit found ? 0 : 1 }' "$approvals"; then
      printf 'Start approval: recorded\n'
    else
      printf 'Start approval: pending\n'
    fi
    if awk -F '\t' -v step="$current" '$1 !~ /^#/ && $1 == step && $2 == "pass" { found=1 } END { exit found ? 0 : 1 }' "$approvals"; then
      printf 'Pass approval: recorded\n'
    else
      printf 'Pass approval: pending\n'
    fi
  fi
}

show_lesson() {
  local lesson7_label lesson14_label lesson7_short lesson14_short
  lesson7_label="$(lesson_display_label lesson_7)"
  lesson14_label="$(lesson_display_label lesson_14)"
  lesson7_short="$(lesson_display_short_label lesson_7)"
  lesson14_short="$(lesson_display_short_label lesson_14)"
  print_section 'Lesson Dashboard'
  printf '%s status:\n' "$lesson14_label"
  LESSON_CONFIG="$DASHBOARD_LESSON14_CONFIG" "$ROOT/tools/lesson14" status || true
  printf '\n%s status:\n' "$lesson7_label"
  LESSON_CONFIG="$DASHBOARD_LESSON_CONFIG" "$ROOT/tools/lesson" status || true
  printf '\nLearning mode:\n'
  printf '%s: ' "$lesson14_short"
  LESSON_CONFIG="$DASHBOARD_LESSON14_CONFIG" "$ROOT/tools/lesson14" 学習モード || true
  printf '%s: ' "$lesson7_short"
  LESSON_CONFIG="$DASHBOARD_LESSON_CONFIG" "$ROOT/tools/lesson" 学習モード || true
  printf '\nLanguage settings:\n'
  language_status "$ROOT/learning/WORKFLOW_DISPLAY_LANGUAGE_14_DAYS.tsv" "$lesson14_short Workflow display language"
  language_status "$ROOT/learning/PRODUCT_DEVELOPMENT_LANGUAGE_14_DAYS.tsv" "$lesson14_short Product development language"
  language_status "$ROOT/learning/WORKFLOW_DISPLAY_LANGUAGE.tsv" "$lesson7_short Workflow display language"
  language_status "$ROOT/learning/PRODUCT_DEVELOPMENT_LANGUAGE.tsv" "$lesson7_short Product development language"
  printf '\nNext approval:\n'
  next_approval_status
  printf '\nSync-gate status:\n'
  "$ROOT/tools/check_lesson14_sync.sh" >/dev/null && printf 'Lesson14 sync gate data: synchronized\n' || printf 'Lesson14 sync gate data: inconsistent\n'
  printf '\nIllustration availability:\n'
  "$ROOT/tools/illustrations" list || true
  printf '\nHelp desk summary:\n'
  "$ROOT/tools/helpdesk" 一覧 || true
  printf '\nDeveloper memory themes:\n'
  developer_memory_path="$(lesson_doc_path developer_memory)"
  if [[ -f "$developer_memory_path" ]]; then
    awk '
      /^### / && section == 1 { print "- " substr($0, 5) }
      /^## Systematic Review Index/ { section = 1; next }
      /^## Chronological Operation Test Notes/ { section = 0 }
    ' "$developer_memory_path"
  else
    printf 'Optional local temporary memory is not present.\n'
  fi
}

show_development() {
  print_section 'Development Dashboard'
  if [[ -d "$PRODUCT_ROOT/.git" ]]; then
    printf 'Product repository: %s\n\n' "$PRODUCT_ROOT"
    (cd "$PRODUCT_ROOT" && git status --short --branch)
    printf '\nGit sync check:\n'
    "$ROOT/tools/check_git_sync.sh" --repo "$PRODUCT_ROOT" --required || true
    printf '\nGit workflow policy:\n'
    "$ROOT/tools/git-workflow" status --repo "$PRODUCT_ROOT" || true
    printf '\nProduct security:\n'
    "$ROOT/tools/product-security" status --context product-improvement --repo "$PRODUCT_ROOT" || true
    printf '\nWorkflow documents:\n'
    for file in docs/product/REQUIREMENTS.md docs/product/SPECIFICATION.md docs/product/IMPLEMENTATION_PLAN.md docs/workflow/TASK_TRACKER.md docs/workflow/HANDOFF.md README.md RETROSPECTIVE.md; do
      file_status "$PRODUCT_ROOT" "$file"
    done
    printf '\nPaired workflow state:\n'
    if [[ -f "$PRODUCT_ROOT/docs/workflow/TASK_TRACKER.md" && -f "$PRODUCT_ROOT/docs/workflow/HANDOFF.md" ]]; then
      if "$ROOT/tools/check_workflow_pair_sync.sh" --repo "$PRODUCT_ROOT" >/dev/null 2>&1; then
        printf 'Workflow pair sync: synchronized\n'
      else
        printf 'Workflow pair sync: inconsistent\n'
      fi
      printf 'Current objective: %s\n' "$(current_state_from_file "$PRODUCT_ROOT/docs/workflow/TASK_TRACKER.md")"
      printf 'TASK_TRACKER next action: %s\n' "$(next_action_from_file "$PRODUCT_ROOT/docs/workflow/TASK_TRACKER.md")"
      printf 'HANDOFF next action: %s\n' "$(next_action_from_file "$PRODUCT_ROOT/docs/workflow/HANDOFF.md")"
    else
      printf 'docs/workflow/TASK_TRACKER.md and docs/workflow/HANDOFF.md are not both present.\n'
    fi
    printf '\nCI status:\n'
    optional_ci_status
    printf 'Required CI command: ./tools/check_ci_status.sh --repo "%s" --required\n' "$PRODUCT_ROOT"
    printf '\nCleanup readiness:\n'
    "$ROOT/tools/product-repository-cleanup" status || true
    printf 'Cleanup plan command: ./tools/product-repository-cleanup plan\n'
  else
    printf 'Product repository not found: %s\n' "$PRODUCT_ROOT"
    printf 'Use Free Development Mode or a lesson-created product repository when development work starts.\n'
    printf 'Cleanup status command: ./tools/product-repository-cleanup status\n'
    printf '\nGit workflow policy:\n'
    "$ROOT/tools/git-workflow" status --repo "$ROOT" || true
    printf '\nProduct security:\n'
    "$ROOT/tools/product-security" status --context free-development || true
  fi
}

show_illustrations() {
  print_section 'Illustration Review Dashboard'
  "$ROOT/tools/illustrations" list
  printf '\nReview page: illustration-review/index.html\n'
}

show_docs() {
  print_section 'Documentation Map Dashboard'
  "$ROOT/tools/docs-tour" status
  printf '\nDocument categories:\n'
  printf -- '- Rules and routing: AGENTS.MD, guides/DOCUMENT_MAP.md\n'
  printf -- '- Design/as-built: docs/as-built/REQUIREMENTS.md, docs/as-built/SPECIFICATION.md, docs/as-built/IMPLEMENTATION_PLAN.md\n'
  printf -- '- Workflow state: docs/workflow/TASK_TRACKER.md, docs/workflow/HANDOFF.md\n'
  printf -- '- Git hook policy: docs/workflow/GIT_HOOKS_POLICY.tsv, docs/workflow/GIT_HOOK_CHECKS.tsv, docs/workflow/GIT_HOOK_RECOMMENDATION_PATHS.tsv, learning/GIT_HOOK_SETTINGS.tsv\n'
  printf -- '- Optional local temporary memory (Git-ignored): docs/memory/DEVELOPER_MEMORY.md, docs/memory/SESSION_MEMORY.md\n'
  printf -- '- Reusable agent procedures: skills/*/SKILL.md\n'
  printf '\nDocument purposes:\n'
  printf -- '- AGENTS.MD: lesson-side agent rulebook; product-side AGENTS.MD is the external product rulebook, and legacy AGENT.md is a migration target\n'
  printf -- '- guides/DOCUMENT_MAP.md: learner-facing explanation of the document system\n'
  printf -- '- docs/as-built/REQUIREMENTS.md: what the lesson repository must provide\n'
  printf -- '- docs/as-built/SPECIFICATION.md: how the repository behavior is specified\n'
  printf -- '- docs/as-built/IMPLEMENTATION_PLAN.md: how implementation and verification are organized\n'
  printf -- '- docs/workflow/TASK_TRACKER.md: current progress and remaining work\n'
  printf -- '- docs/workflow/HANDOFF.md: restart context and next safe action\n'
  printf -- '- docs/workflow/GIT_HOOKS_POLICY.tsv: available Git hook modes and the default mode\n'
  printf -- '- docs/workflow/GIT_HOOK_CHECKS.tsv: checks included in each Git hook mode\n'
  printf -- '- docs/workflow/GIT_HOOK_RECOMMENDATION_PATHS.tsv: changed files that recommend local full/no-cache verification\n'
  printf -- '- learning/GIT_HOOK_SETTINGS.tsv: current local Git hook mode setting\n'
  printf -- '- docs/memory/DEVELOPER_MEMORY.md: optional Git-ignored local temporary notes; may be absent and are not repository authority\n'
  printf -- '- docs/memory/SESSION_MEMORY.md: optional Git-ignored local session notes; may be absent and are not repository authority\n'
  printf -- '- product-side docs/memory/FAILURE_MEMORY.md: failure and recovery records when a product repository uses one\n'
  printf -- '- skills/*/SKILL.md: reusable agent procedures, not learner homework\n'
  printf '\nPrompt help: ./tools/docs-tour all, ./tools/docs-tour rules, ./tools/docs-tour memory, ./tools/docs-tour workflow, ./tools/check_document_root.sh\n'
}

show_menu() {
  print_section 'Menu'
  "$ROOT/tools/menu"
  printf '\nMenu Readiness\n'
  printf '==============\n'
  "$ROOT/tools/menu" readiness || true
  printf '\nMenu Git Workflow Policy\n'
  printf '========================\n'
  "$ROOT/tools/git-workflow" status --repo "$ROOT" || true
}

case "${1:-all}" in
  menu)
    show_menu
    ;;
  lesson)
    show_lesson
    ;;
  development)
    show_development
    ;;
  docs)
    show_docs
    ;;
  illustrations)
    show_illustrations
    ;;
  control-center)
    shift || true
    "$ROOT/tools/dashboard-control-center" open "$@"
    ;;
  all)
    show_menu
    printf '\n'
    show_lesson
    printf '\n'
    show_docs
    printf '\n'
    show_development
    printf '\n'
    show_illustrations
    ;;
  *)
    printf 'Usage: ./tools/dashboard <menu|lesson|docs|development|illustrations|all|control-center>\n' >&2
    exit 1
    ;;
esac
