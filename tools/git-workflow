#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=lib/lesson_common.sh
source "$ROOT/tools/lib/lesson_common.sh"
# shellcheck source=lib/git_workflow_policy.sh
source "$ROOT/tools/lib/git_workflow_policy.sh"

usage() {
  cat <<'USAGE'
Usage:
  tools/git-workflow status [--repo PATH]
  tools/git-workflow configure
  tools/git-workflow set <key> <value>
  tools/git-workflow approve <push|pr|merge> "memo" [--repo PATH]
  tools/git-workflow allow <branch|worktree|main-direct|commit|push|pr|ci|pr-ci|merge|main-ci|sync|developer-auto-merge> [--repo PATH] [--delivery-plan PATH]
  tools/git-workflow check [--repo PATH]
  tools/git-workflow cleanup-plan [--repo PATH]

Settings:
  branch_allowed: true|false
  worktree_allowed: true|false
  main_direct_work_allowed: true|false
  automation_level: manual|commit|pr_ci|sync
  commit_automation: manual|auto
  push_automation: manual|auto
  pr_creation: manual|auto
  pr_ci_monitoring: manual|auto
  merge_execution: manual|after_approval
  developer_auto_merge_allowed: false|true
  main_ci_monitoring: manual|auto
  sync_monitoring: manual|auto
USAGE
}

repo_arg() {
  local repo="$PWD"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        [[ $# -ge 2 ]] || {
          printf '%s\n' '--repo requires a path' >&2
          return 1
        }
        repo="$2"
        shift 2
        ;;
      *)
        printf 'Unknown option: %s\n' "$1" >&2
        return 1
        ;;
    esac
  done
  printf '%s\n' "$repo"
}

approve_args() {
  local action="${1:-}"
  local memo="${2:-}"
  local repo="$PWD"
  [[ -n "$action" && -n "$memo" ]] || {
    printf 'approve requires an action and memo.\n' >&2
    return 1
  }
  shift 2
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        [[ $# -ge 2 ]] || {
          printf '%s\n' '--repo requires a path' >&2
          return 1
        }
        repo="$2"
        shift 2
        ;;
      *)
        printf 'Unknown option: %s\n' "$1" >&2
        return 1
        ;;
    esac
  done
  printf '%s\t%s\t%s\n' "$action" "$memo" "$repo"
}

allow_args() {
  local action="${1:-}"
  local repo="$PWD"
  local delivery_plan=""
  [[ -n "$action" ]] || {
    printf 'allow requires an action.\n' >&2
    return 1
  }
  shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        [[ $# -ge 2 ]] || {
          printf '%s\n' '--repo requires a path' >&2
          return 1
        }
        repo="$2"
        shift 2
        ;;
      --delivery-plan)
        [[ $# -ge 2 ]] || {
          printf '%s\n' '--delivery-plan requires a path' >&2
          return 1
        }
        delivery_plan="$2"
        shift 2
        ;;
      *)
        printf 'Unknown option: %s\n' "$1" >&2
        return 1
        ;;
    esac
  done
  printf '%s\t%s\t%s\n' "$action" "$repo" "$delivery_plan"
}

cmd="${1:-}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  status)
    repo="$(repo_arg "$@")"
    printf 'Git workflow policy status\n'
    printf 'Policy file: %s\n' "$(git_workflow_policy_file)"
    printf 'Settings file: %s\n' "$(git_workflow_settings_file)"
    printf 'Approval file: %s\n' "$(git_workflow_approvals_file)"
    printf '\nSettings\n'
    git_workflow_print_settings
    printf '\nAction modes\n'
    git_workflow_print_action_modes "$repo"
    printf '\nRepository monitor\n'
    git_workflow_print_monitor "$repo"
    ;;
  configure)
    printf 'Git workflow settings\n'
    printf 'Use these commands when the user chooses Git management preferences.\n\n'
    git_workflow_print_settings
    printf '\nExamples\n'
    printf '  ./tools/git-workflow set branch_allowed true\n'
    printf '  ./tools/git-workflow set worktree_allowed false\n'
    printf '  ./tools/git-workflow set automation_level manual\n'
    printf '  ./tools/git-workflow set commit_automation auto\n'
    printf '  ./tools/git-workflow set push_automation manual\n'
    printf '  ./tools/git-workflow set pr_creation manual\n'
    printf '  ./tools/git-workflow set pr_ci_monitoring auto\n'
    printf '  ./tools/git-workflow set merge_execution after_approval\n'
    printf '  ./tools/git-workflow set developer_auto_merge_allowed false\n'
    printf '  ./tools/git-workflow set main_ci_monitoring auto\n'
    printf '  ./tools/git-workflow set sync_monitoring auto\n'
    printf '  ./tools/git-workflow approve push "User approved push"\n'
    printf '  ./tools/git-workflow approve pr "User approved PR creation"\n'
    printf '  ./tools/git-workflow approve merge "User approved merge"\n'
    printf '  ./tools/git-workflow status\n'
    ;;
  set)
    [[ $# -eq 2 ]] || {
      usage >&2
      exit 1
    }
    git_workflow_write_setting "$1" "$2"
    printf 'Updated %s to %s\n' "$1" "$2"
    ;;
  approve)
    parsed="$(approve_args "$@")"
    action="${parsed%%$'\t'*}"
    rest="${parsed#*$'\t'}"
    memo="${rest%%$'\t'*}"
    repo="${rest#*$'\t'}"
    git_workflow_write_approval "$action" "$repo" "$memo"
    ;;
  allow)
    parsed="$(allow_args "$@")"
    action="${parsed%%$'\t'*}"
    rest="${parsed#*$'\t'}"
    repo="${rest%%$'\t'*}"
    delivery_plan="${rest#*$'\t'}"
    if [[ -n "$delivery_plan" ]]; then
      git_workflow_require_delivery_plan "$delivery_plan" "$action" "$repo"
    fi
    if git_workflow_allow_policy "$action" "$repo"; then
      printf 'Allowed: %s\n' "$action"
    else
      printf 'Not allowed by current Git workflow settings: %s\n' "$action" >&2
      exit 1
    fi
    ;;
  check)
    repo="$(repo_arg "$@")"
    git_workflow_check_repository "$repo"
    ;;
  cleanup-plan)
    repo="$(repo_arg "$@")"
    root="$(git_workflow_git_root "$repo")" || {
      printf 'Git repository: not found (%s)\n' "$repo" >&2
      exit 1
    }
    branch="$(git_workflow_branch_name "$root")"
    printf 'Git cleanup plan\n'
    printf 'Repository context: %s\n' "$(git_workflow_repository_context "$root")"
    printf 'Git root: %s\n' "$root"
    printf '\nBranches that can be reviewed for deletion:\n'
    git_workflow_candidate_branches "$root" "$branch" || true
    printf '\nWorktrees that can be reviewed for removal:\n'
    git_workflow_candidate_worktrees "$root" "$root" || true
    printf '\nNo deletion is performed by this command.\n'
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
