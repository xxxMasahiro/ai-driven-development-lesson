#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$ROOT/tools/lib/lesson_common.sh"
# shellcheck source=tools/lib/repository_development_workflow.sh
source "$ROOT/tools/lib/repository_development_workflow.sh"
# shellcheck source=tools/lib/repository_development_runner.sh
source "$ROOT/tools/lib/repository_development_runner.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./tools/repository-development-workflow status [--phase <phase_id>]
  ./tools/repository-development-workflow list
  ./tools/repository-development-workflow plan --phase <phase_id>
  ./tools/repository-development-workflow guidance --phase <phase_id>
  ./tools/repository-development-workflow gate --phase <phase_id>
  ./tools/repository-development-workflow detect
  ./tools/repository-development-workflow plan-run --phase <phase_id> [--check-set required|recommended]
  ./tools/repository-development-workflow run --phase <phase_id> [--check-set required|recommended] [--execute] [--approved] [--no-reuse]
  ./tools/repository-development-workflow record --phase <phase_id> --check-id <check_id> --result pass|fail|skipped --exit-status <n>
  ./tools/repository-development-workflow next --phase <phase_id>
  ./tools/repository-development-workflow status --runs [--phase <phase_id>]
  ./tools/repository-development-workflow check
USAGE
}

phase="${REPOSITORY_DEVELOPMENT_PHASE:-context_triage}"
check_set="required"
runs=false
execute=false
approved=false
use_reuse=true
check_id=""
result=""
exit_status=""
cmd="${1:-status}"
shift || true

while [[ $# -gt 0 ]]; do
  case "$1" in
    --phase)
      [[ $# -ge 2 ]] || {
        printf -- '--phase requires a value.\n' >&2
        exit 1
      }
      phase="$2"
      shift 2
      ;;
    --check-set)
      [[ $# -ge 2 ]] || {
        printf -- '--check-set requires a value.\n' >&2
        exit 1
      }
      case "$2" in
        required|recommended) check_set="$2" ;;
        *)
          printf -- '--check-set must be required or recommended.\n' >&2
          exit 1
          ;;
      esac
      shift 2
      ;;
    --runs)
      runs=true
      shift
      ;;
    --execute)
      execute=true
      shift
      ;;
    --approved)
      approved=true
      shift
      ;;
    --no-reuse)
      use_reuse=false
      shift
      ;;
    --check-id)
      [[ $# -ge 2 ]] || {
        printf -- '--check-id requires a value.\n' >&2
        exit 1
      }
      check_id="$2"
      shift 2
      ;;
    --result)
      [[ $# -ge 2 ]] || {
        printf -- '--result requires a value.\n' >&2
        exit 1
      }
      result="$2"
      shift 2
      ;;
    --exit-status)
      [[ $# -ge 2 ]] || {
        printf -- '--exit-status requires a value.\n' >&2
        exit 1
      }
      exit_status="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

case "$cmd" in
  status)
    repository_development_validate_policy
    repository_development_runner_validate_policy
    printf 'Repository development workflow\n'
    printf 'Policy file: %s\n' "$(repository_development_workflow_file)"
    printf 'Approvals file: %s\n' "$(repository_development_approvals_file)"
    printf 'Runner policy file: %s\n' "$(repository_development_runner_policy_file)"
    printf 'Selected phase: %s\n' "$phase"
    repository_development_print_phase "$phase"
    if [[ "$runs" == "true" ]]; then
      repository_development_runner_print_records
    fi
    ;;
  list)
    repository_development_validate_policy
    repository_development_runner_validate_policy
    repository_development_print_list
    ;;
  plan)
    repository_development_validate_policy
    repository_development_runner_validate_policy
    repository_development_print_phase "$phase"
    printf 'Plan status: policy-backed; follow document sync and approval boundaries before writing.\n'
    ;;
  guidance)
    repository_development_validate_policy
    repository_development_runner_validate_policy
    repository_development_print_guidance "$phase"
    ;;
  gate)
    repository_development_validate_policy
    repository_development_runner_validate_policy
    repository_development_print_phase "$phase"
    printf 'Policy gate status: policy-valid only. This does not prove listed checks passed; execute listed checks through their owner commands before advancing.\n'
    ;;
  detect)
    repository_development_runner_detect_phase
    ;;
  plan-run)
    repository_development_runner_print_plan "$phase" "$check_set"
    ;;
  run)
    if [[ "$execute" != "true" ]]; then
      repository_development_runner_print_plan "$phase" "$check_set"
      printf 'Runner dry-run only. Add --execute to run allowed local checks.\n'
    else
      repository_development_runner_execute "$phase" "$check_set" "$approved" "$use_reuse"
    fi
    ;;
  record)
    if [[ -z "$check_id" || -z "$result" || -z "$exit_status" ]]; then
      printf 'record requires --check-id, --result, and --exit-status.\n' >&2
      usage >&2
      exit 1
    fi
    repository_development_runner_record_manual "$phase" "$check_id" "$result" "$exit_status"
    ;;
  next)
    repository_development_runner_print_next "$phase"
    ;;
  check)
    repository_development_validate_policy
    repository_development_runner_validate_policy
    printf 'Repository development workflow check passed.\n'
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
