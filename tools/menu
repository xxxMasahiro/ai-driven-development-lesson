#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$SCRIPT_DIR/lib/lesson_common.sh"
# shellcheck source=tools/lib/git_workflow_policy.sh
source "$SCRIPT_DIR/lib/git_workflow_policy.sh"
# shellcheck source=tools/lib/lesson_display_labels.sh
source "$SCRIPT_DIR/lib/lesson_display_labels.sh"
# shellcheck source=tools/lib/product_workflow_git_usage.sh
source "$SCRIPT_DIR/lib/product_workflow_git_usage.sh"

SKILL_ALIASES_FILE="$LESSON_ROOT/skills/SKILL_ALIASES.tsv"

show_menu() {
  local lesson7_label lesson14_label lesson7_description lesson14_description
  lesson7_label="$(lesson_display_label lesson_7)"
  lesson14_label="$(lesson_display_label lesson_14)"
  lesson7_description="$(lesson_display_description lesson_7)"
  lesson14_description="$(lesson_display_description lesson_14)"
  cat <<MENU
メニュー

【学ぶ】
1. $lesson7_label
   $lesson7_description
   入口: ./tools/lesson status
   開始前確認: ./tools/menu check 1

2. $lesson14_label
   $lesson14_description
   入口: ./tools/lesson14 status
   開始前確認: ./tools/menu check 2

3. 応用レッスン
   Docker、git worktree、チーム開発、より実務的な検証を学ぶ
   入口: ./tools/team-development status
   開始前確認: ./tools/menu check 3

【作る・発展させる】
4. 自由開発
   自分で成果物を決め、この教材のワークフローで開発する
   入口: ./tools/free-development status
   開始前確認: ./tools/menu check 4

5. 成果物を改善
   完了、削除、保存、デザイン改善などを追加する
   入口: ./tools/product-improvement status
   削除前確認: ./tools/product-repository-cleanup status
   開始前確認: ./tools/menu check 5

6. 外部連携
   自由開発や既存成果物を、Googleカレンダーなど外部ツールと連携させる
   入口: ./tools/external-integration status
   開始前確認: ./tools/menu check 6

【整える】
7. 教材そのものを改善
   レッスン、プロンプト、ダッシュボード、文書、運用テストを改善する
   入口: docs/memory/DEVELOPER_MEMORY.md と ./tools/dashboard all を確認する

Git管理設定
   作業ブランチ、git worktree、Git自動化レベル、同期監視を設定する
   入口: ./tools/git-workflow status
   設定案内: ./tools/git-workflow configure

Security確認
   自由開発、成果物改善、外部連携の安全確認をする
   入口: ./tools/product-security status
   確認: ./tools/product-security check --context <free-development|product-improvement|external-integration>

流れの目安:
  自由開発で作る → 成果物を改善する → 外部連携で発展させる

外部連携は、既存成果物リポジトリがある場合は単独でも選べます。
MENU
}

usage() {
  cat <<'USAGE'
Usage:
  tools/menu
  tools/menu status
  tools/menu readiness
  tools/menu skills
  tools/menu skill-aliases
  tools/menu check <1|2|3|4|5|6|7>
  tools/menu start <1|2|3|4|5|6|7> --confirm
USAGE
}

menu_require_skill_aliases_file() {
  if [[ ! -f "$SKILL_ALIASES_FILE" ]]; then
    printf 'missing skill aliases file: %s\n' "$SKILL_ALIASES_FILE" >&2
    exit 1
  fi
}

menu_skill_alias_rows() {
  menu_require_skill_aliases_file
  awk -F '\t' '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    NF >= 4 { print $1 "\t" $2 "\t" $3 "\t" $4 }
  ' "$SKILL_ALIASES_FILE"
}

menu_show_skills() {
  local alias skill display_name description
  printf 'Skills\n'
  printf '======\n'
  while IFS=$'\t' read -r alias skill display_name description; do
    printf '\n%s\n' "$skill"
    printf '  Alias: %s\n' "$alias"
    printf '  Display: %s\n' "$display_name"
    printf '  Use: %s\n' "$description"
    printf '  File: skills/%s/SKILL.md\n' "$skill"
  done < <(menu_skill_alias_rows)
}

menu_show_skill_aliases() {
  local alias skill display_name description
  printf 'Skill aliases\n'
  printf '=============\n'
  while IFS=$'\t' read -r alias skill display_name description; do
    printf '%s -> %s\n' "$alias" "$skill"
  done < <(menu_skill_alias_rows)
}

menu_item_name() {
  case "$1" in
    1) lesson_display_label lesson_7 ;;
    2) lesson_display_label lesson_14 ;;
    3) printf '応用レッスン' ;;
    4) printf '自由開発' ;;
    5) printf '成果物を改善' ;;
    6) printf '外部連携' ;;
    7) printf '教材そのものを改善' ;;
    *) printf 'unknown menu item: %s\n' "$1" >&2; exit 1 ;;
  esac
}

menu_item_entry() {
  case "$1" in
    1) printf './tools/lesson status' ;;
    2) printf './tools/lesson14 status' ;;
    3) printf './tools/team-development start --confirm' ;;
    4) printf './tools/free-development start --confirm' ;;
    5) printf './tools/product-improvement start --confirm' ;;
    6) printf './tools/external-integration start --confirm' ;;
    7) printf 'docs/memory/DEVELOPER_MEMORY.md and ./tools/dashboard all' ;;
    *) printf 'unknown menu item: %s\n' "$1" >&2; exit 1 ;;
  esac
}

menu_git_workflow_repo_for_item() {
  case "$1" in
    4) product_workflow_git_usage_repository_root_for_context free-development ;;
    5) product_workflow_git_usage_repository_root_for_context product-improvement ;;
    6) product_workflow_git_usage_repository_root_for_context external-integration ;;
    *)
      printf '%s\n' "$LESSON_ROOT"
      ;;
  esac
}

menu_product_workflow_context_for_item() {
  case "$1" in
    4) printf 'free-development' ;;
    5) printf 'product-improvement' ;;
    6) printf 'external-integration' ;;
    *) printf 'not_applicable' ;;
  esac
}

menu_product_workflow_mode_for_item() {
  local context
  context="$(menu_product_workflow_context_for_item "$1")"
  product_workflow_git_usage_mode_for_context "$context"
}

menu_product_workflow_requires_git_for_item() {
  local context mode
  context="$(menu_product_workflow_context_for_item "$1")"
  [[ "$context" != "not_applicable" ]] || return 1
  mode="$(product_workflow_git_usage_mode_for_context "$context")"
  product_workflow_git_usage_requires_git_worktree "$mode"
}

menu_product_workflow_repository_boundary_gate_for_item() {
  local context
  context="$(menu_product_workflow_context_for_item "$1")"
  [[ "$context" != "not_applicable" ]] || return 1
  product_workflow_git_usage_repository_boundary_gate "$context"
}

menu_require_git_workflow_policy() {
  local item="$1"
  local policy_file
  local settings_file
  local repo
  local context
  local key

  policy_file="$(git_workflow_policy_file)"
  settings_file="$(git_workflow_settings_file)"
  if [[ ! -f "$policy_file" ]]; then
    printf 'missing Git workflow policy file: %s\n' "$policy_file" >&2
    exit 1
  fi

  while IFS=$'\t' read -r key _allowed _default _label _description; do
    git_workflow_setting_value "$key" >/dev/null
  done < <(git_workflow_policy_rows)

  if [[ "$(menu_product_workflow_context_for_item "$item")" != "not_applicable" ]] && ! menu_product_workflow_requires_git_for_item "$item"; then
    printf 'Git workflow policy: ready\n'
    printf 'Git workflow settings: %s\n' "$settings_file"
    printf 'Git workflow repository context: not_applicable\n'
    printf 'Git workflow automation: not_applicable\n'
    return 0
  fi

  repo="$(menu_git_workflow_repo_for_item "$item")"
  context="$(git_workflow_repository_context "$repo")" || {
    printf 'missing Git workflow repository context for menu item %s: %s\n' "$item" "$repo" >&2
    exit 1
  }

  printf 'Git workflow policy: ready\n'
  printf 'Git workflow settings: %s\n' "$settings_file"
  printf 'Git workflow repository context: %s\n' "$context"
  printf 'Git workflow automation: %s\n' "$(git_workflow_automation_level)"
}

menu_print_git_workflow_readiness() {
  local item="$1"
  local repo
  local context
  if ( menu_require_git_workflow_policy "$item" ) >/dev/null 2>&1; then
    if [[ "$(menu_product_workflow_context_for_item "$item")" != "not_applicable" ]]; then
      printf 'Product workflow Git usage mode: %s\n' "$(menu_product_workflow_mode_for_item "$item")"
    fi
    if [[ "$(menu_product_workflow_context_for_item "$item")" != "not_applicable" ]] && ! menu_product_workflow_requires_git_for_item "$item"; then
      printf 'Git workflow policy: ready\n'
      printf 'Git workflow repository monitor: not_applicable\n'
      printf 'Git workflow actions: not_applicable\n'
      return
    fi
    repo="$(menu_git_workflow_repo_for_item "$item")"
    context="$(git_workflow_repository_context "$repo")"
    printf 'Git workflow policy: ready\n'
    printf 'Git branch permission: %s\n' "$(git_workflow_setting_value branch_allowed)"
    printf 'Git worktree permission: %s\n' "$(git_workflow_setting_value worktree_allowed)"
    printf 'Git direct-main permission: %s\n' "$(git_workflow_setting_value main_direct_work_allowed)"
    printf 'Git workflow automation: %s\n' "$(git_workflow_automation_level)"
    printf 'Git commit automation: %s\n' "$(git_workflow_action_mode commit "$repo")"
    printf 'Git push automation: %s\n' "$(git_workflow_action_mode push "$repo")"
    printf 'Git PR creation: %s\n' "$(git_workflow_action_mode pr "$repo")"
    printf 'Git PR CI monitoring: %s\n' "$(git_workflow_action_mode pr_ci "$repo")"
    printf 'Git merge execution: %s\n' "$(git_workflow_action_mode merge "$repo")"
    printf 'Git developer auto-merge allowed: %s\n' "$(git_workflow_setting_value developer_auto_merge_allowed)"
    printf 'Git main CI monitoring: %s\n' "$(git_workflow_action_mode main_ci "$repo")"
    printf 'Git sync monitoring: %s\n' "$(git_workflow_action_mode sync "$repo")"
    printf 'Git repository monitor: ready (%s)\n' "$context"
  else
    printf 'Git workflow policy: missing\n'
  fi
}

menu_check_item() {
  local item="$1"
  case "$item" in
    1)
      lesson_menu_require_config_settings "$(menu_item_name "$item")" "$LESSON_ROOT/lesson/LESSON_CONFIG.tsv"
      ;;
    2)
      lesson_menu_require_config_settings "$(menu_item_name "$item")" "$LESSON_ROOT/lesson/LESSON_CONFIG_14_DAYS.tsv"
      ;;
    3|4)
      lesson_menu_require_settings "$(menu_item_name "$item")"
      ;;
    5|6)
      lesson_menu_require_settings "$(menu_item_name "$item")"
      ;;
    7)
      :
      ;;
    *)
      printf 'menu item must be 1 through 7.\n' >&2
      exit 1
      ;;
  esac
  if [[ "$(menu_product_workflow_context_for_item "$item")" != "not_applicable" ]]; then
    menu_product_workflow_repository_boundary_gate_for_item "$item" >/dev/null
  fi
  lesson_product_profile_require "$item" "$(menu_item_name "$item")"
  menu_require_git_workflow_policy "$item"
  if [[ "$item" == "4" || "$item" == "5" || "$item" == "6" ]]; then
    "$LESSON_ROOT/tools/product-security" status --context "$(menu_product_workflow_context_for_item "$item")" >/dev/null
    printf 'Product security policy: ready\n'
  fi
  printf 'Menu prerequisite check passed: %s\n' "$(menu_item_name "$item")"
}

menu_readiness() {
  local item
  for item in 1 2 3 4 5 6 7; do
    printf '\n[%s] %s\n' "$item" "$(menu_item_name "$item")"
    case "$item" in
      1)
        if ( lesson_menu_require_config_settings "$(menu_item_name "$item")" "$LESSON_ROOT/lesson/LESSON_CONFIG.tsv" ) >/dev/null 2>&1; then
          printf 'Settings: ready\n'
        else
          printf 'Settings: missing\n'
        fi
        ;;
      2)
        if ( lesson_menu_require_config_settings "$(menu_item_name "$item")" "$LESSON_ROOT/lesson/LESSON_CONFIG_14_DAYS.tsv" ) >/dev/null 2>&1; then
          printf 'Settings: ready\n'
        else
          printf 'Settings: missing\n'
        fi
        ;;
      *)
        if [[ "$item" == "7" ]]; then
          printf 'Settings: not required before maintenance start\n'
        else
          lesson_menu_print_readiness "$(menu_item_name "$item")"
        fi
        if [[ "$(menu_product_workflow_context_for_item "$item")" != "not_applicable" ]]; then
          printf 'Product workflow Git usage mode: %s\n' "$(menu_product_workflow_mode_for_item "$item")"
          if menu_product_workflow_repository_boundary_gate_for_item "$item" >/dev/null 2>&1; then
            printf 'Product repository boundary: ready\n'
          else
            printf 'Product repository boundary: missing\n'
          fi
        else
          printf 'Product repository boundary: not required before start\n'
        fi
        ;;
    esac
    lesson_product_profile_print_readiness "$item" "Product name"
    menu_print_git_workflow_readiness "$item"
    if [[ "$item" == "4" || "$item" == "5" || "$item" == "6" ]]; then
      printf 'Product security: '
      if "$LESSON_ROOT/tools/product-security" status --context "$(menu_product_workflow_context_for_item "$item")" >/dev/null 2>&1; then
        printf 'policy ready\n'
      else
        printf 'policy missing\n'
      fi
    fi
    printf 'Start command: ./tools/menu start %s --confirm\n' "$item"
  done
}

case "${1:-status}" in
  ""|status|現在地)
    show_menu
    ;;
  readiness|準備)
    menu_readiness
    ;;
  skills|skill|スキル)
    menu_show_skills
    ;;
  skill-aliases|aliases|alias)
    menu_show_skill_aliases
    ;;
  check|確認)
    menu_check_item "${2:-}"
    ;;
  start|開始)
    item="${2:-}"
    lesson_menu_require_start_approval "$(menu_item_name "$item")" "${3:-}"
    menu_check_item "$item"
    printf 'Start entry: %s\n' "$(menu_item_entry "$item")"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n' "$1" >&2
    usage
    exit 1
    ;;
esac
