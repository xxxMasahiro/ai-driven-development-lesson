#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export LESSON_CONFIG="$ROOT/lesson/LESSON_CONFIG_14_DAYS.tsv"

# shellcheck source=tools/lib/lesson_common.sh
source "$SCRIPT_DIR/lib/lesson_common.sh"
# shellcheck source=tools/lib/lesson_display_labels.sh
source "$SCRIPT_DIR/lib/lesson_display_labels.sh"
# shellcheck source=tools/lib/lesson_runtime.sh
source "$SCRIPT_DIR/lib/lesson_runtime.sh"

LESSON_RUNTIME_NAME="lesson14"
LESSON_RUNTIME_FLOW="$(lesson_flow_file)"
LESSON_RUNTIME_STATE="$(lesson_state_file)"
LESSON_RUNTIME_TRACKER="$(lesson_tracker_file)"
LESSON_RUNTIME_HANDOFF="$(lesson_handoff_file)"
LESSON_RUNTIME_APPROVAL="$(lesson_approval_file)"
LESSON_RUNTIME_REQUIRE_APPROVAL=1
LESSON_RUNTIME_CHECK="$ROOT/tools/check_lesson14_structure.sh"
LESSON_RUNTIME_BEFORE_PASS="lesson14_before_pass"
LESSON14_LEARNING_MODE_FILE="$(lesson_learning_mode_file)"
LESSON14_WORKFLOW_LANGUAGE_FILE="$(lesson_workflow_language_file)"
LESSON14_PRODUCT_LANGUAGE_FILE="$(lesson_product_language_file)"
LESSON14_LANGUAGE_CODES="$(lesson_supported_language_codes)"

lesson_runtime_name="$LESSON_RUNTIME_NAME"
lesson_runtime_flow="$LESSON_RUNTIME_FLOW"
lesson_runtime_state="$LESSON_RUNTIME_STATE"
lesson_runtime_tracker="$LESSON_RUNTIME_TRACKER"
lesson_runtime_handoff="$LESSON_RUNTIME_HANDOFF"
lesson_runtime_approval="$LESSON_RUNTIME_APPROVAL"
lesson_runtime_approval_required="$LESSON_RUNTIME_REQUIRE_APPROVAL"
lesson_runtime_check="$LESSON_RUNTIME_CHECK"
lesson_runtime_before_pass="$LESSON_RUNTIME_BEFORE_PASS"

lesson14_current_learning_mode() {
  lesson_current_learning_mode_file "$LESSON14_LEARNING_MODE_FILE"
}

lesson14_set_learning_mode() {
  lesson_set_learning_mode_file "$LESSON14_LEARNING_MODE_FILE" "${1:-}"
}

lesson14_show_learning_mode() {
  lesson_show_learning_mode_file "$LESSON14_LEARNING_MODE_FILE"
}

lesson14_set_language_file() {
  local file="$1"
  local label="$2"
  lesson_set_language_file "$file" "$label" "${3:-}"
}

lesson14_show_language_file() {
  local file="$1"
  local label="$2"
  lesson_show_language_file "$file" "$label"
}

lesson14_reset_run() {
  local lesson_label
  lesson_label="$(lesson_display_label lesson_14)"
  local confirm="${1:-}"
  if [[ "$confirm" != "--confirm" ]]; then
    printf '%sの実行状態を最初からやり直す操作です。\n' "$lesson_label" >&2
    printf '本当に初期化する場合は、次のコマンドを実行してください。\n' >&2
    printf './tools/lesson14 初期化 --confirm\n' >&2
    exit 1
  fi
  local tmp_state
  tmp_state="$(mktemp "$LESSON_RUNTIME_STATE.tmp.XXXXXX")"
  awk -F '\t' -v OFS='\t' '
    BEGIN { print "# order", "step_id", "status", "started_at", "completed_at" }
    $1 !~ /^#/ {
      if ($2 == "setup.index") print $1, $2, "current", "", ""
      else print $1, $2, "locked", "", ""
    }
  ' "$LESSON_RUNTIME_FLOW" > "$tmp_state"
  mv "$tmp_state" "$LESSON_RUNTIME_STATE"
  printf '# step_id\taction\tapproved_at\tmemo\n' > "$LESSON_RUNTIME_APPROVAL"
  printf '# selected_at\tmode\tdescription\n' > "$LESSON14_LEARNING_MODE_FILE"
  printf '# selected_at\tcode\tlabel\n' > "$LESSON14_WORKFLOW_LANGUAGE_FILE"
  printf '# selected_at\tcode\tlabel\n' > "$LESSON14_PRODUCT_LANGUAGE_FILE"
  {
    printf '# Learning Task Tracker (%s)\n\n' "$lesson_label"
    printf 'This file records learner-visible progress for %s.\n' "$lesson_label"
    printf '\n## Step Progress\n\n'
    local step_number
    for step_number in $(seq 1 14); do
      printf '%s\n' "- Step $step_number/14: not started"
    done
  } > "$LESSON_RUNTIME_TRACKER"
  {
    printf '# Learning Handoff (%s)\n\n' "$lesson_label"
    printf 'Current step: Setup: index-14-days.mdでレッスン全体とSTEP 1-14の入口を確認する\n'
    printf 'Next question: index-14-days.mdから%sを開始してよいですか？\n' "$lesson_label"
  } > "$LESSON_RUNTIME_HANDOFF"
  printf '%sの実行状態を最初のセットアップ項目へ戻しました。\n' "$lesson_label"
}

lesson14_require_learning_mode() {
  if lesson14_current_learning_mode >/dev/null; then
    return 0
  fi
  printf 'Learning mode is required before passing setup.index.\n' >&2
  printf 'Run: ./tools/lesson14 学習モード <A|B|C>\n' >&2
  exit 1
}

lesson14_language_file_has_value() {
  local file="$1"
  lesson_language_file_has_value "$file"
}

lesson14_require_language_settings() {
  local missing=0
  if ! lesson14_language_file_has_value "$LESSON14_WORKFLOW_LANGUAGE_FILE"; then
    printf 'Workflow display language is required before passing setup.index.\n' >&2
    printf 'Run: ./tools/lesson14 表示言語 <%s>\n' "$LESSON14_LANGUAGE_CODES" >&2
    missing=1
  fi
  if ! lesson14_language_file_has_value "$LESSON14_PRODUCT_LANGUAGE_FILE"; then
    printf 'Product development language is required before passing setup.index.\n' >&2
    printf 'Run: ./tools/lesson14 開発言語 <%s>\n' "$LESSON14_LANGUAGE_CODES" >&2
    missing=1
  fi
  if ! lesson_product_profile_has_name_for_menu 2; then
    printf 'Product name is required before passing setup.index.\n' >&2
    lesson_product_profile_print_readiness 2 "Product name" >&2
    missing=1
  fi
  [[ "$missing" -eq 0 ]] || exit 1
}

lesson14_sync_gate_command_for_day() {
  local day="$1"
  awk -F '\t' -v day="$day" '$1 !~ /^#/ && $1 == day { print $6; found=1; exit } END { if (!found) exit 1 }' "$ROOT/lesson/SYNC_GATES_14_DAYS.tsv"
}

lesson14_run_command_segment() {
  local segment="$1"
  local -a args
  read -r -a args <<< "$segment"
  [[ ${#args[@]} -gt 0 ]] || return 0
  case "${args[0]}" in
    -)
      return 0
      ;;
    tools/*)
      args[0]="$ROOT/${args[0]}"
      ;;
    ./tools/*)
      args[0]="$ROOT/${args[0]#./}"
      ;;
    *)
      printf 'unsupported lesson14 gate command: %s\n' "$segment" >&2
      exit 1
      ;;
  esac
  (cd "$ROOT" && "${args[@]}")
}

lesson14_run_required_command() {
  local command="$1"
  local segment
  [[ -n "$command" && "$command" != "-" ]] || return 0
  while [[ "$command" == *" && "* ]]; do
    segment="${command%% && *}"
    command="${command#* && }"
    lesson14_run_command_segment "$segment"
  done
  lesson14_run_command_segment "$command"
}

lesson14_before_pass() {
  local step_id="$1"
  local day command
  case "$step_id" in
    setup.index)
      lesson14_require_learning_mode
      lesson14_require_language_settings
      ;;
    *.sync-gate|day14.release-readiness)
      day="$(lesson_runtime_flow_field "$step_id" 3)"
      command="$(lesson14_sync_gate_command_for_day "$day")"
      printf 'Running required sync gate for %s: %s\n' "$day" "$command"
      lesson14_run_required_command "$command"
      ;;
  esac
}

case "${1:-}" in
  学習モード|learning-mode|mode)
    shift || true
    lesson_runtime_require_files
    if [[ $# -eq 0 ]]; then
      lesson14_show_learning_mode
      exit 0
    fi
    lesson14_set_learning_mode "$@"
    exit 0
    ;;
  表示言語|display-language|workflow-language)
    shift || true
    lesson_runtime_require_files
    [[ -f "$LESSON14_WORKFLOW_LANGUAGE_FILE" ]] || printf '# selected_at\tcode\tlabel\n' > "$LESSON14_WORKFLOW_LANGUAGE_FILE"
    if [[ $# -eq 0 ]]; then
      lesson14_show_language_file "$LESSON14_WORKFLOW_LANGUAGE_FILE" "workflow display language"
      exit 0
    fi
    lesson14_set_language_file "$LESSON14_WORKFLOW_LANGUAGE_FILE" "Workflow display language" "$1"
    exit 0
    ;;
  開発言語|product-language|development-language)
    shift || true
    lesson_runtime_require_files
    [[ -f "$LESSON14_PRODUCT_LANGUAGE_FILE" ]] || printf '# selected_at\tcode\tlabel\n' > "$LESSON14_PRODUCT_LANGUAGE_FILE"
    if [[ $# -eq 0 ]]; then
      lesson14_show_language_file "$LESSON14_PRODUCT_LANGUAGE_FILE" "product development language"
      exit 0
    fi
    lesson14_set_language_file "$LESSON14_PRODUCT_LANGUAGE_FILE" "Product development language" "$1"
    exit 0
    ;;
  初期化|reset)
    shift || true
    lesson_runtime_require_files
    lesson14_reset_run "$@"
    exit 0
    ;;
esac

lesson_runtime_main "$@"
