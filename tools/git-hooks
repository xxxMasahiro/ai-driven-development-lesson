#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$ROOT/tools/lib/lesson_common.sh"
# shellcheck source=tools/lib/git_hooks_policy.sh
source "$ROOT/tools/lib/git_hooks_policy.sh"
# shellcheck source=tools/lib/resource_guard.sh
source "$ROOT/tools/lib/resource_guard.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./tools/git-hooks status
  ./tools/git-hooks recommend [--paths <path>...]
  ./tools/git-hooks mode
  ./tools/git-hooks mode <full|fast|minimal>
  ./tools/git-hooks cache clear
  ./tools/git-hooks run [--mode <full|fast|minimal>] [--no-cache]
USAGE
}

cmd="${1:-status}"
shift || true

case "$cmd" in
  status)
    git_hooks_print_status
    ;;
  recommend)
    if [[ $# -eq 0 ]]; then
      git_hooks_print_recommendation
    elif [[ "${1:-}" == "--paths" && $# -ge 2 ]]; then
      shift
      git_hooks_print_recommendation "$@"
    else
      usage >&2
      exit 1
    fi
    ;;
  mode)
    if [[ $# -eq 0 ]]; then
      mode="$(git_hooks_mode)" || exit 1
      printf 'Current Git hooks mode: %s\n' "$mode"
    elif [[ $# -eq 1 ]]; then
      git_hooks_write_mode "$1"
      printf 'Git hooks mode recorded: %s\n' "$1"
    else
      usage >&2
      exit 1
    fi
    ;;
  cache)
    subcmd="${1:-}"
    if [[ "$subcmd" != "clear" || $# -ne 1 ]]; then
      usage >&2
      exit 1
    fi
    git_hooks_clear_cache
    ;;
  run)
    mode="$(git_hooks_mode)" || exit 1
    no_cache="false"
    worker_count="1"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --mode)
          [[ $# -ge 2 ]] || {
            printf '--mode requires a value.\n' >&2
            exit 1
          }
          mode="$2"
          shift 2
          ;;
        --no-cache)
          no_cache="true"
          shift
          ;;
        *)
          usage >&2
          exit 1
          ;;
      esac
    done
    case "$mode" in
      full|fast)
        if [[ "${RESOURCE_GUARD_SKIP_LOCAL_CHECK:-0}" == "1" ]]; then
          printf 'Resource guard pre-check skipped for this environment.\n'
        elif [[ -f "$(resource_guard_policy_file)" && -f "$(resource_guard_settings_file)" ]]; then
          resource_guard_check_profile git-hooks-full
          worker_count="$(resource_guard_recommended_jobs git-hooks-full)"
        fi
        ;;
    esac
    git_hooks_run_checks_parallel "$mode" "$no_cache" "$worker_count"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
