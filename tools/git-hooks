#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$ROOT/tools/lib/lesson_common.sh"
# shellcheck source=tools/lib/git_hooks_policy.sh
source "$ROOT/tools/lib/git_hooks_policy.sh"
# shellcheck source=tools/lib/resource_guard.sh
source "$ROOT/tools/lib/resource_guard.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./tools/git-hooks status
  ./tools/git-hooks recommend [--paths <path>...]
  ./tools/git-hooks mode
  ./tools/git-hooks mode <full|fast|minimal>
  ./tools/git-hooks cache clear
  ./tools/git-hooks run [--mode <full|fast|minimal>] [--no-cache] [--jobs <count>]
USAGE
}

validate_positive_integer() {
  local value="$1"
  local label="$2"
  if ! [[ "$value" =~ ^[1-9][0-9]*$ ]]; then
    printf '%s must be a positive integer: %s\n' "$label" "$value" >&2
    return 1
  fi
}

min_positive_integer() {
  local left="$1"
  local right="$2"
  if (( left < right )); then
    printf '%s\n' "$left"
  else
    printf '%s\n' "$right"
  fi
}

cmd="${1:-status}"
shift || true

case "$cmd" in
  status)
    git_hooks_print_status
    ;;
  recommend)
    if [[ $# -eq 0 ]]; then
      git_hooks_print_recommendation
    elif [[ "${1:-}" == "--paths" && $# -ge 2 ]]; then
      shift
      git_hooks_print_recommendation "$@"
    else
      usage >&2
      exit 1
    fi
    ;;
  mode)
    if [[ $# -eq 0 ]]; then
      mode="$(git_hooks_mode)" || exit 1
      printf 'Current Git hooks mode: %s\n' "$mode"
    elif [[ $# -eq 1 ]]; then
      git_hooks_write_mode "$1"
      printf 'Git hooks mode recorded: %s\n' "$1"
    else
      usage >&2
      exit 1
    fi
    ;;
  cache)
    subcmd="${1:-}"
    if [[ "$subcmd" != "clear" || $# -ne 1 ]]; then
      usage >&2
      exit 1
    fi
    git_hooks_clear_cache
    ;;
  run)
    mode="$(git_hooks_mode)" || exit 1
    no_cache="false"
    worker_count="1"
    requested_worker_count="${GIT_HOOKS_JOBS:-}"
    if [[ -n "$requested_worker_count" ]]; then
      validate_positive_integer "$requested_worker_count" "GIT_HOOKS_JOBS" || exit 1
    fi
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --mode)
          [[ $# -ge 2 ]] || {
            printf '--mode requires a value.\n' >&2
            exit 1
          }
          mode="$2"
          shift 2
          ;;
        --no-cache)
          no_cache="true"
          shift
          ;;
        --jobs)
          [[ $# -ge 2 ]] || {
            printf -- '--jobs requires a value.\n' >&2
            exit 1
          }
          validate_positive_integer "$2" "--jobs" || exit 1
          requested_worker_count="$2"
          shift 2
          ;;
        *)
          usage >&2
          exit 1
          ;;
      esac
    done
    if [[ -z "${CI_EVIDENCE_RUN_ID:-}" && -z "${GITHUB_RUN_ID:-}" ]]; then
      export CI_EVIDENCE_RUN_ID="local-git-hooks-$$-$(date +%s)"
    fi
    if [[ "$mode" == "full" && "$no_cache" == "true" ]]; then
      export CI_FINAL_GATE_REQUIRE_HOOK_EVIDENCE="1"
    fi
    if [[ "$mode" == "full" && "$no_cache" == "true" && -z "${CI_EVIDENCE_USE:-}" ]]; then
      export CI_EVIDENCE_USE="1"
    fi
    if [[ "$mode" == "full" && "$no_cache" == "true" && -z "${CI_EVIDENCE_PLAYWRIGHT_SOURCE_JOB:-}" ]]; then
      export CI_EVIDENCE_PLAYWRIGHT_SOURCE_JOB="playwright-local"
    fi
    case "$mode" in
      full|fast)
        if [[ "${RESOURCE_GUARD_SKIP_LOCAL_CHECK:-0}" == "1" ]]; then
          printf 'Resource guard pre-check skipped for this environment.\n'
          if [[ -n "$requested_worker_count" ]]; then
            worker_count="$requested_worker_count"
            printf 'Git hooks parallel jobs requested: %s.\n' "$worker_count"
          fi
        elif [[ -f "$(resource_guard_policy_file)" && -f "$(resource_guard_settings_file)" ]]; then
          resource_guard_check_profile git-hooks-full
          recommended_worker_count="$(resource_guard_recommended_jobs git-hooks-full)"
          worker_count="$recommended_worker_count"
          if [[ -n "$requested_worker_count" ]]; then
            worker_count="$(min_positive_integer "$requested_worker_count" "$recommended_worker_count")"
            if [[ "$worker_count" != "$requested_worker_count" ]]; then
              printf 'Git hooks parallel jobs capped by resource guard: requested %s, using %s.\n' "$requested_worker_count" "$worker_count"
            else
              printf 'Git hooks parallel jobs requested: %s.\n' "$worker_count"
            fi
          fi
        elif [[ -n "$requested_worker_count" ]]; then
          worker_count="$requested_worker_count"
          printf 'Git hooks parallel jobs requested without resource guard policy: %s.\n' "$worker_count"
        fi
        ;;
    esac
    git_hooks_run_checks_parallel "$mode" "$no_cache" "$worker_count"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
