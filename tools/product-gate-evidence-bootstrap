print_status() {
  local missing=0
  local relpath
  for relpath in "tools/lib/product_gate_evidence.sh" "tools/product-gate-evidence" "ops/EVIDENCE_DETAIL_MANIFEST.tsv"; do
    if [[ -s "$REPO/$relpath" ]]; then
      printf 'ready: %s\n' "$relpath"
    else
      printf 'missing: %s\n' "$relpath"
      missing=1
    fi
  done
  return "$missing"
}

case "$COMMAND" in
  status|plan)
    require_repo
    print_status
    ;;
  install)
    require_repo
    require_confirm_for_write
    write_helper
    write_command
    write_detail_manifest
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n' "$COMMAND" >&2
    usage >&2
    exit 1
    ;;
esac
