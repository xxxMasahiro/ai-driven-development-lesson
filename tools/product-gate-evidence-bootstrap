      printf 'invalid product test evidence source_id: %s\n' "$source_id" >&2
      overall_rc=1
      continue
    fi
    case "$required_mode" in
      required|contextual) required_in_context="true" ;;
      optional) required_in_context="false" ;;
      *)
        printf 'invalid product test required mode: %s\n' "$required_mode" >&2
        overall_rc=1
        continue
        ;;
    esac
    source_artifacts="ops/TEST_PLAN_MANIFEST.tsv;test_id=$test_id;command_id=$command_id"
    next_command="$command_id"
    if command_path="$(product_gate_evidence_manifest_command_path "$command_id")"; then
      product_gate_evidence_run_manifest_command "$source_id" "$context" "$required_in_context" "$source_artifacts" "$next_command" "$max_age_seconds" "$command_path"
      rc=$?
    else
      product_gate_evidence_record "$source_id" "$context" "blocked" "$required_in_context" "manual_required" "$max_age_seconds" "$source_artifacts" "product.tests.command" "$next_command"
      rc=127
    fi
    if [[ "$rc" -ne 0 ]]; then
      overall_rc=1
    fi
  done <<<"$rows"
  return "$overall_rc"
}

product_gate_evidence_status() {
  local index ledger details
  index="$(product_gate_evidence_index)"
  ledger="$(product_gate_evidence_ledger)"
  details="$(product_gate_evidence_details_dir)"
  printf 'Product gate evidence index: %s\n' "${index#$(product_gate_evidence_repo_root)/}"
  if [[ -f "$index" ]]; then
    printf 'Status: ready\n'
  else
    printf 'Status: not_collected\n'
  fi
  if [[ -f "$ledger" ]]; then
    printf 'Ledger: ready\n'
  else
    printf 'Ledger: not_collected\n'
  fi
  if [[ -d "$details" ]]; then
    printf 'Details: ready\n'
  else
    printf 'Details: not_collected\n'
  fi
}
PRODUCT_GATE_EVIDENCE_HELPER
  printf 'installed: %s\n' "${path#$REPO/}"
}

write_command() {
  local path
  path="$(command_path)"
  mkdir -p "$(dirname "$path")"
  if [[ -e "$path" && "$FORCE" != "true" ]]; then
    printf 'kept existing: %s\n' "${path#$REPO/}"
    return
  fi
  cat >"$path" <<'PRODUCT_GATE_EVIDENCE_COMMAND'
#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=tools/lib/product_gate_evidence.sh
source "$ROOT/tools/lib/product_gate_evidence.sh"

COMMAND="${1:-status}"
if [[ $# -gt 0 ]]; then
  shift
fi

usage() {
  cat <<'USAGE'
Usage:
  tools/product-gate-evidence status
  tools/product-gate-evidence record <source-id> <context> <status> <source-artifacts> <next-command> [max-age-seconds]
  tools/product-gate-evidence run <source-id> <context> <source-artifacts> <next-command> [max-age-seconds] -- <command> [args...]
  tools/product-gate-evidence structure-status <context> [max-age-seconds]
  tools/product-gate-evidence git-status <context> [max-age-seconds]
  tools/product-gate-evidence ci-status <context> [max-age-seconds]
  tools/product-gate-evidence ci-runs <context> [max-age-seconds] [--main-branch <branch>] [--pr <number-or-url>] [--limit <count>]
  tools/product-gate-evidence security-status <context> [max-age-seconds]
  tools/product-gate-evidence manifest-tests <context> [max-age-seconds] [product-type]

Records Dashboard-readable product gate evidence in:
  .git/product-gate-evidence/index.tsv
USAGE
}

case "$COMMAND" in
  status)
    product_gate_evidence_status
    ;;
  record)
    if [[ "$#" -lt 5 ]]; then
      usage >&2
      exit 1
    fi
    product_gate_evidence_record "$1" "$2" "$3" "true" "authoritative" "${6:-3600}" "$4" "" "$5"
    ;;
  run)
    if [[ "$#" -lt 6 ]]; then
      usage >&2
      exit 1
    fi
    source_id="$1"
    context="$2"
    source_artifacts="$3"
    next_command="$4"
    max_age_seconds="$5"
    shift 5
    product_gate_evidence_run "$source_id" "$context" "$source_artifacts" "$next_command" "$max_age_seconds" "$@"
    ;;
  structure-status)
    product_gate_evidence_structure_status "${1:-free-development}" "${2:-3600}"
    ;;
  git-status)
    product_gate_evidence_git_status "${1:-free-development}" "${2:-300}"
    ;;
  ci-status)
    product_gate_evidence_ci_status "${1:-product-improvement}" "${2:-3600}"
    ;;
  ci-runs)
    product_gate_evidence_ci_runs "${1:-product-improvement}" "${2:-3600}" "${@:3}"
    ;;
  security-status)
    product_gate_evidence_security_status "${1:-free-development}" "${2:-3600}"
    ;;
  manifest-tests)
    product_gate_evidence_manifest_tests "${1:-free-development}" "${2:-3600}" "${3:-all}"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n' "$COMMAND" >&2
    usage >&2
    exit 1
    ;;
esac
PRODUCT_GATE_EVIDENCE_COMMAND
  chmod +x "$path"
  printf 'installed: %s\n' "${path#$REPO/}"
}

