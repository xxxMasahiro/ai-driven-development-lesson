function generatedJs(tokens, components, orchestration) {
  const payload = {
    name: tokens.name,
    version: tokens.version,
    source: tokens.source,
    tokens: sortedTokenRows(tokens),
    components: components.components,
    pipeline: components.pipeline,
    orchestration,
  };
  return [
    "// Generated by tools/dashboard-design-system from docs/design-system/dashboard-control-center/tokens.json and components.json.",
    "// Do not edit by hand; update the design-system source files and regenerate.",
    `export const dashboardControlCenterDesignSystem = Object.freeze(${JSON.stringify(payload, null, 2)});`,
    "",
    "export default dashboardControlCenterDesignSystem;",
    "",
  ].join("\n");
}

function validateSource(tokens, components) {
  if (tokens.name !== "dashboard-control-center") {
    fail(`invalid token source name: ${tokens.name}`);
  }
  if (components.name !== tokens.name || components.version !== tokens.version) {
    fail("tokens and components must share name and version");
  }
  const seen = new Set();
  for (const token of tokens.tokens) {
    if (!/^--dcc-[a-z0-9-]+$/.test(token.cssVariable || "")) {
      fail(`invalid CSS variable for token ${token.name}: ${token.cssVariable}`);
    }
    if (seen.has(token.cssVariable)) {
      fail(`duplicate CSS variable: ${token.cssVariable}`);
    }
    seen.add(token.cssVariable);
    if (!token.value || !token.role) {
      fail(`token must have value and role: ${token.name}`);
    }
  }
  const requiredComponents = [
    "page-header",
    "status-badge",
    "operational-card",
    "data-row",
    "detail-surface",
    "tooltip-copy",
    "command-preview",
    "interactive-control",
    "design-studio-visual-editor",
    "design-studio-orchestration",
  ];
  const componentIds = new Set(components.components.map((component) => component.id));
  for (const required of requiredComponents) {
    if (!componentIds.has(required)) {
      fail(`missing required component contract: ${required}`);
    }
  }
  for (const component of components.components) {
    if (!Array.isArray(component.selectors) || !Array.isArray(component.tokens) || !Array.isArray(component.contract)) {
      fail(`component contract is incomplete: ${component.id}`);
    }
  }
  validateInteractionContract(components);
}

function requireString(value, label) {
  if (typeof value !== "string" || !value.trim()) {
    fail(`${label} must be a non-empty string`);
    return "";
  }
  return value;
}

function requireStringArray(value, label, { min = 1 } = {}) {
  if (!Array.isArray(value) || value.length < min) {
    fail(`${label} must be a non-empty array`);
    return [];
  }
  for (const item of value) {
    if (typeof item !== "string" || !item.trim()) {
      fail(`${label} contains an invalid item`);
    }
  }
  return value;
}

function requireBoolean(value, label) {
  if (typeof value !== "boolean") {
    fail(`${label} must be a boolean`);
  }
}

function validateNoSecretLikePayload(value, label) {
  const text = JSON.stringify(value);
  if (secretLikePattern.test(text)) {
    fail(`${label} must not contain secret-like payloads`);
  }
}

function assertNoSecretLikePayload(value, label) {
  const text = JSON.stringify(value);
  if (secretLikePattern.test(text)) {
    stop(`${label} must not contain secret-like payloads`);
  }
}

function validateOrchestration(orchestration) {
  validateNoSecretLikePayload(orchestration, "orchestration contract");
  requireString(orchestration.name, "orchestration name");
  requireString(orchestration.version, "orchestration version");
  if (orchestration.syncId !== "dashboard_design_studio_orchestration_foundation") {
    fail(`invalid orchestration syncId: ${orchestration.syncId}`);
  }
  if (orchestration.source !== "docs/design-system/dashboard-control-center/DESIGN_SYSTEM.md") {
    fail(`invalid orchestration source: ${orchestration.source}`);
  }
  requireStringArray(orchestration.model, "orchestration model", { min: 10 });
  for (const requiredStep of ["candidate-envelope", "plan-token", "explicit-approval", "owner-tool-apply", "rollback-ready-evidence"]) {
    if (!orchestration.model.includes(requiredStep)) {
      fail(`orchestration model is missing ${requiredStep}`);
    }
  }
  const states = orchestration.states || {};
  for (const stateGroup of ["request", "job", "proposal", "apply"]) {
    requireStringArray(states[stateGroup], `orchestration state group ${stateGroup}`);
  }
  const requiredSchemas = [
    "DesignIntentRequest",
    "DesignChangeProposal",
    "CandidateEnvelope",
    "MockArtifact",
    "MockAnalysisProposal",
    "TemplateDefinition",
    "TemplateProposal",
    "ApplyEvidence",
  ];
  const schemas = Array.isArray(orchestration.schemas) ? orchestration.schemas : [];
  for (const schemaId of requiredSchemas) {
    const schema = schemas.find((candidate) => candidate.id === schemaId);
    if (!schema) {
      fail(`orchestration schema is missing ${schemaId}`);
      continue;
    }
    requireString(schema.status, `orchestration schema ${schemaId} status`);
    requireString(schema.purpose, `orchestration schema ${schemaId} purpose`);
    requireStringArray(schema.requiredFields, `orchestration schema ${schemaId} requiredFields`);
    requireStringArray(schema.forbiddenFields, `orchestration schema ${schemaId} forbiddenFields`);
  }
  const providerModes = Array.isArray(orchestration.providerModes) ? orchestration.providerModes : [];
  for (const providerId of ["manual", "subscription-agent", "api-key"]) {
    const provider = providerModes.find((candidate) => candidate.id === providerId);
    if (!provider) {
      fail(`orchestration provider mode is missing ${providerId}`);
      continue;
    }
    requireString(provider.status, `orchestration provider ${providerId} status`);
    requireBoolean(provider.directApplyAuthority, `orchestration provider ${providerId} directApplyAuthority`);
    if (provider.directApplyAuthority !== false) {
      fail(`orchestration provider ${providerId} must not have direct apply authority`);
    }
    requireString(provider.secretPolicy, `orchestration provider ${providerId} secretPolicy`);
  }
  const apiProvider = providerModes.find((candidate) => candidate.id === "api-key");
  if (apiProvider && apiProvider.secretPolicy !== "secret-reference-only") {
    fail("api-key provider mode must use secret-reference-only policy");
  }
  const targetAdapters = Array.isArray(orchestration.targetAdapters) ? orchestration.targetAdapters : [];
  const dashboardTarget = targetAdapters.find((target) => target.id === "dashboard-control-center");
  const productTarget = targetAdapters.find((target) => target.id === "external-product");
  if (!dashboardTarget || dashboardTarget.applyMode !== "owner-tool" || dashboardTarget.ownerTool !== "tools/dashboard-design-system") {
    fail("dashboard-control-center target must apply only through tools/dashboard-design-system");
  }
  if (!productTarget || productTarget.applyMode !== "plan-only") {
    fail("external product target must remain plan-only");
  }
  for (const target of targetAdapters) {
    requireStringArray(target.allowedOutputs, `orchestration target ${target.id} allowedOutputs`);
    requireStringArray(target.requiredChecks, `orchestration target ${target.id} requiredChecks`);
  }
  for (const group of ["store", "eventRunner", "mockLibrary", "templateLibrary"]) {
    if (!orchestration[group] || typeof orchestration[group] !== "object" || Array.isArray(orchestration[group])) {
      fail(`orchestration ${group} must be an object`);
    }
  }
  requireStringArray(orchestration.store?.requiredFields, "orchestration store requiredFields");
  requireStringArray(orchestration.eventRunner?.requiredCapabilities, "orchestration eventRunner requiredCapabilities");
  requireStringArray(orchestration.eventRunner?.forbiddenCapabilities, "orchestration eventRunner forbiddenCapabilities");
  requireStringArray(orchestration.mockLibrary?.supportedOperations, "orchestration mockLibrary supportedOperations");
  requireStringArray(orchestration.mockLibrary?.unsupportedOperations, "orchestration mockLibrary unsupportedOperations");
  requireStringArray(orchestration.templateLibrary?.supportedOperations, "orchestration templateLibrary supportedOperations");
  requireStringArray(orchestration.templateLibrary?.unsupportedOperations, "orchestration templateLibrary unsupportedOperations");
  requireStringArray(orchestration.checks, "orchestration checks");
}

function failOnUnknownKeys(value, allowedKeys, label) {
  if (!value || typeof value !== "object" || Array.isArray(value)) {
    fail(`${label} must be an object`);
    return;
  }
  for (const key of Object.keys(value)) {
    if (!allowedKeys.has(key)) {
      fail(`${label} contains an unsupported field: ${key}`);
    }
  }
}

function validateTemplateRegistry(registry, orchestration) {
  validateNoSecretLikePayload(registry, "template registry");
  failOnUnknownKeys(registry, new Set([
    "schema_version",
    "sync_id",
    "registry_id",
    "version",
    "source",
    "updated_at",
    "templates",
  ]), "template registry");
  if (registry.schema_version !== "1.0.0") {
    fail(`invalid template registry schema_version: ${registry.schema_version}`);
  }
  if (registry.sync_id !== templateLibrarySyncId) {
    fail(`invalid template registry sync_id: ${registry.sync_id}`);
  }
  if (registry.source !== "docs/design-system/dashboard-control-center/DESIGN_SYSTEM.md") {
    fail(`invalid template registry source: ${registry.source}`);
  }
  requireString(registry.registry_id, "template registry id");
  requireString(registry.version, "template registry version");
  requireString(registry.updated_at, "template registry updated_at");
  if (!Array.isArray(registry.templates) || registry.templates.length < 1) {
    fail("template registry templates must be a non-empty array");
    return;
  }
  const definitionSchema = (orchestration.schemas || []).find((candidate) => candidate.id === "TemplateDefinition");
  if (!definitionSchema) {
    fail("orchestration schema is missing TemplateDefinition");
    return;
  }
  const forbiddenTemplateKeys = new Set([
    ...(definitionSchema.forbiddenFields || []),
    "raw_api_key",
    "raw_secret",
    "secret_value",
    "shell_command",
    "script_patch",
    "css_patch",
    "direct_apply",
    "auto_apply",
    "apply_token",
    "plan_token",
    "approval_receipt",
    "credential_value",
    "credential_requirement",
    "network_call",
    "dependency_install",
    "git_operation",
    "ci_operation",
    "provider_dispatch",
    "imagegen_executed",
    "browser_command_execution",
    "external_product_write",
    "owner_write_path",
    "trusted_instruction",
  ]);
  const seenTemplateIds = new Set();
  const templateKeys = new Set([
    "template_id",
    "version",
    "display_name",
    "summary",
    "product_type",
    "supported_targets",
    "required_tokens",
    "optional_tokens",
    "components",
    "patterns",
    "page_templates",
    "allowed_outputs",
    "forbidden_operations",
    "required_checks",
    "compatibility",
    "lifecycle_state",
    "redaction_state",
    "candidate_operations",
    "affected_source_files",
    "affected_generated_files",
    "manual_decisions",
    "risk_assessment",
    "accessibility_notes",
    "confidence",
    "rollback_outline",
  ]);
  const operationKeys = new Set(["operation_id", "kind", "summary", "target_ref", "allowed_output"]);
  const compatibilityKeys = new Set(["status", "notes"]);
  for (const template of registry.templates) {
    failOnUnknownKeys(template, templateKeys, "template definition");
    rejectForbiddenPayloadFields(template, forbiddenTemplateKeys, "template definition");
    for (const field of definitionSchema.requiredFields || []) {
      if (!Object.hasOwn(template, field) || template[field] === "" || template[field] == null) {
        fail(`template definition is missing required field: ${field}`);
      }
    }
    for (const field of ["display_name", "summary", "redaction_state", "risk_assessment", "accessibility_notes", "confidence", "rollback_outline"]) {
      requireString(template[field], `template ${template.template_id || "(unknown)"} ${field}`);
    }
    validateStoreIdentifier(String(template.template_id || ""), "template id");
    if (seenTemplateIds.has(template.template_id)) {
      fail(`duplicate template id: ${template.template_id}`);
    }
    seenTemplateIds.add(template.template_id);
    if (!/^[0-9]+\.[0-9]+\.[0-9]+$/.test(String(template.version || ""))) {
      fail(`template ${template.template_id} version must use semver`);
    }
    if (!["ready", "draft", "deprecated"].includes(template.lifecycle_state)) {
      fail(`template ${template.template_id} lifecycle_state is invalid`);
    }
    if (template.redaction_state !== "metadata_only") {
      fail(`template ${template.template_id} redaction_state must be metadata_only`);
    }
    const supportedTargets = requireStringArray(template.supported_targets, `template ${template.template_id} supported_targets`);
    for (const targetRef of supportedTargets) {
      targetAdapterContract(orchestration, targetRef);
    }
    for (const arrayField of ["required_tokens", "optional_tokens", "components", "patterns", "page_templates", "allowed_outputs", "forbidden_operations", "required_checks", "manual_decisions", "affected_source_files", "affected_generated_files"]) {
      requireStringArray(template[arrayField], `template ${template.template_id} ${arrayField}`, { min: arrayField === "optional_tokens" || arrayField === "affected_generated_files" ? 0 : 1 });
    }
    for (const output of template.allowed_outputs) {
      if (!safeScopedDisplayPath(output)) {
        fail(`template ${template.template_id} allowed_outputs contains an unsafe path: ${output}`);
      }
    }
    for (const file of [...template.affected_source_files, ...template.affected_generated_files]) {
      if (!safeScopedDisplayPath(file)) {
        fail(`template ${template.template_id} affected files contain an unsafe path: ${file}`);
      }
    }
    const requiresOwnerToolChecks = supportedTargets.includes("dashboard-control-center");
    for (const command of template.required_checks) {
      if (!safeTemplateCheckReference(command)) {
        fail(`template ${template.template_id} required_checks contains an unsafe check reference: ${command}`);
      }
      if (requiresOwnerToolChecks && !safeOwnerToolCommand(command)) {
        fail(`template ${template.template_id} dashboard checks must be owner-tool commands: ${command}`);
      }
    }
    failOnUnknownKeys(template.compatibility, compatibilityKeys, `template ${template.template_id} compatibility`);
    requireString(template.compatibility?.status, `template ${template.template_id} compatibility status`);
    requireString(template.compatibility?.notes, `template ${template.template_id} compatibility notes`);
    if (!Array.isArray(template.candidate_operations) || template.candidate_operations.length < 1) {
      fail(`template ${template.template_id} candidate_operations must be a non-empty metadata array`);
      continue;
    }
    for (const operation of template.candidate_operations) {
      failOnUnknownKeys(operation, operationKeys, `template ${template.template_id} candidate operation`);
      rejectForbiddenPayloadFields(operation, forbiddenTemplateKeys, `template ${template.template_id} candidate operation`);
      validateStoreIdentifier(String(operation.operation_id || ""), "template candidate operation id");
      for (const field of ["kind", "summary", "target_ref", "allowed_output"]) {
        requireString(operation[field], `template ${template.template_id} candidate operation ${field}`);
      }
      if (!supportedTargets.includes(operation.target_ref)) {
        fail(`template ${template.template_id} candidate operation target_ref is not supported: ${operation.target_ref}`);
      }
      if (!safeScopedDisplayPath(operation.allowed_output) || !template.allowed_outputs.includes(operation.allowed_output)) {
        fail(`template ${template.template_id} candidate operation allowed_output is invalid: ${operation.allowed_output}`);
      }
    }
  }
}

function validateInteractionContract(components) {
  const tooltipCopy = components.components.find((component) => component.id === "tooltip-copy");
  const tooltip = tooltipCopy?.interaction?.tooltip;
  const copyFeedback = tooltipCopy?.interaction?.copyFeedback;
  if (!tooltip || !copyFeedback) {
    fail("tooltip-copy component must define tooltip and copyFeedback interaction");
    return;
  }
  const stringRules = [
    [tooltip.trigger, supportedInteractionValues.tooltip_trigger, "tooltip trigger"],
    [tooltip.hidePolicy, supportedInteractionValues.tooltip_hide_policy, "tooltip hide policy"],
    [tooltip.placement, supportedInteractionValues.tooltip_placement, "tooltip placement"],
    [copyFeedback.trigger, supportedInteractionValues.copy_feedback_trigger, "copy feedback trigger"],
    [copyFeedback.hidePolicy, supportedInteractionValues.copy_feedback_hide_policy, "copy feedback hide policy"],
    [copyFeedback.placement, supportedInteractionValues.copy_feedback_placement, "copy feedback placement"],
    [copyFeedback.collision, supportedInteractionValues.copy_feedback_collision, "copy feedback collision"],
  ];
  for (const [value, allowed, label] of stringRules) {
    if (!allowed.has(value)) {
      fail(`invalid ${label}: ${value}`);
    }
  }
  if (!/^[1-9][0-9]{1,3}px$/.test(tooltip.maxWidth || "")) {
    fail(`invalid tooltip maxWidth: ${tooltip.maxWidth}`);
  }
  if (!Number.isInteger(tooltip.delayMs) || tooltip.delayMs < 0 || tooltip.delayMs > 1000) {
    fail(`invalid tooltip delayMs: ${tooltip.delayMs}`);
  }
