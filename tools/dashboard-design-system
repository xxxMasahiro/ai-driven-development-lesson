function pushCssRule(cssLines, selectors, declarations) {
  selectors.forEach((selector, index) => {
    cssLines.push(`${selector}${index === selectors.length - 1 ? " {" : ","}`);
  });
  for (const declaration of declarations) {
    cssLines.push(`  ${declaration}`);
  }
  cssLines.push("}");
  cssLines.push("");
}

function appendContextMenuTileCss(cssLines) {
  const iconSelectors = [
    ".menu-tile__icon",
    ...menuTileIconTones.map((tone) => `${tone.selector} .menu-tile__icon`),
  ];
  const selectedIconSelectors = [
    ".menu-tile.is-selected .menu-tile__icon",
    ...menuTileIconTones.map((tone) => `.menu-tile.is-selected${tone.selector} .menu-tile__icon`),
  ];

  pushCssRule(cssLines, [".menu-tile"], [
    "--dcc-menu-tile-icon-bg: var(--dcc-page-soft-fallback);",
    "--dcc-menu-tile-icon-color: var(--dcc-page-accent-fallback);",
    "--dcc-menu-tile-selected-icon-bg: var(--dcc-page-accent-fallback);",
    "--dcc-menu-tile-selected-icon-color: #ffffff;",
  ]);

  for (const tone of menuTileIconTones) {
    pushCssRule(cssLines, [tone.selector], [
      `--dcc-menu-tile-icon-bg: ${tone.iconBg};`,
      `--dcc-menu-tile-icon-color: ${tone.iconColor};`,
      `--dcc-menu-tile-selected-icon-bg: ${tone.selectedIconBg};`,
      "--dcc-menu-tile-selected-icon-color: #ffffff;",
    ]);
  }

  pushCssRule(cssLines, iconSelectors, [
    "background: var(--dcc-menu-tile-icon-bg, var(--dcc-page-soft-fallback));",
    "color: var(--dcc-menu-tile-icon-color, var(--dcc-page-accent-fallback));",
  ]);

  pushCssRule(cssLines, selectedIconSelectors, [
    "background: var(--dcc-menu-tile-selected-icon-bg, var(--dcc-page-accent-fallback));",
    "color: var(--dcc-menu-tile-selected-icon-color, #ffffff);",
  ]);
}

function applyTokenValues(tokens, values) {
  const expected = new Set(Object.keys(values));
  const nextTokens = tokens.tokens.map((token) => {
    if (!Object.hasOwn(values, token.name)) {
      return token;
    }
    expected.delete(token.name);
    return { ...token, value: values[token.name] };
  });
  for (const missing of expected) {
    fail(`missing foundation token: ${missing}`);
  }
  return { ...tokens, tokens: nextTokens };
}

function applyFoundationPresets(tokens, foundation) {
  let next = tokens;
  next = applyTokenValues(next, foundationPresets.themeAccent[foundation.themeAccent]);
  next = applyTokenValues(next, foundationPresets.density[foundation.density]);
  next = applyTokenValues(next, foundationPresets.radiusScale[foundation.radiusScale]);
  next = applyTokenValues(next, foundationPresets.typographyScale[foundation.typographyScale]);
  next = applyTokenValues(next, {
    "action-control-height": foundation.actionControlHeight,
    "action-control-padding": foundation.actionControlPadding,
    "compact-control-height": foundation.compactControlHeight,
    "compact-control-padding": foundation.compactControlPadding,
    "form-control-height": foundation.formControlHeight,
    "form-control-padding": foundation.formControlPadding,
    "icon-button-size": foundation.iconButtonSize,
    "control-font-size": foundation.controlFontSize,
    "card-padding": foundation.cardPadding,
    "card-gap": foundation.cardGap,
    "row-padding": foundation.rowPadding,
    "row-gap": foundation.rowGap,
    "technical-affordance-gap": foundation.technicalAffordanceGap,
    "technical-source-max-width": foundation.technicalSourceMaxWidth,
    "technical-evidence-max-width": foundation.technicalEvidenceMaxWidth,
    "technical-preview-chip-max-width": foundation.technicalPreviewChipMaxWidth,
    "page-header-padding": foundation.pageHeaderPadding,
    "metadata-gap": foundation.metadataGap,
    "page-icon-size": foundation.pageIconSize,
    "badge-gap": foundation.badgeGap,
    "badge-height": foundation.badgeHeight,
    "mode-badge-padding": foundation.modeBadgePadding,
    "badge-font-size": foundation.badgeFontSize,
    "mode-badge-font-size": foundation.modeBadgeFontSize,
  });
  return next;
}

