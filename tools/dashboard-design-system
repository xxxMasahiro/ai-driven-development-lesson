function buildImportRecord(command, payload, inputPath, orchestration, records, options) {
  const schemaId = command === "import-candidate" ? "CandidateEnvelope" : "DesignChangeProposal";
  const schema = schemaContract(orchestration, schemaId);
  validateImportPayload(payload, schema, schemaId);
  const sourceId = importSourceId(schemaId, payload);
  const payloadText = JSON.stringify(payload);
  const payloadDigest = `sha256:${sha256Text(payloadText)}`;
  const idempotencyKey = validateStoreIdentifier(
    options.idempotency_key || `idem:${sha256Text(`${schemaId}:${sourceId}:${payloadDigest}`).slice(0, 32)}`,
    "idempotency key",
  );
  const importId = `dsi:${sha256Text(`import:${idempotencyKey}`).slice(0, 24)}`;
  const now = isoNow();
  const payloadRef = schemaId === "CandidateEnvelope" ? String(payload.payload_ref) : path.relative(root, inputPath) || path.basename(inputPath);
  const record = {
    record_version: candidateImportRecordVersion,
    sync_id: candidateImportSyncId,
