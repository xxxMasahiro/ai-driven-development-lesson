function fail(message) {
  console.error(message);
  process.exitCode = 1;
}

function stop(message, code = 2) {
  console.error(message);
  process.exit(code);
}

function sortedTokenRows(tokens) {
  return [...tokens.tokens].sort((left, right) => left.cssVariable.localeCompare(right.cssVariable));
}

function tokenValue(tokens, tokenName) {
  return tokens.tokens.find((token) => token.name === tokenName)?.value || "";
}

function matchPreset(presetGroup, tokens, fallback) {
  for (const [presetName, presetValues] of Object.entries(presetGroup)) {
    const matches = Object.entries(presetValues).every(([tokenName, value]) => tokenValue(tokens, tokenName) === value);
    if (matches) return presetName;
  }
  return fallback;
}

