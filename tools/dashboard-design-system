function buildQueuedEventRecord(options, tokens, components, orchestration, records) {
  const targetRef = options.target_ref || "dashboard-control-center";
  const providerMode = options.provider_mode || "manual";
  const requestKind = ensureRequestKind(options.request_kind || "design-intent");
  const intentText = requireOption(options, "intent_text", "queue-request");
  const purpose = (options.purpose || "Design Studio proposal request").trim();
  const provider = providerModeContract(orchestration, providerMode);
  const target = targetAdapterContract(orchestration, targetRef);
  const snapshotHash = options.base_snapshot_hash || baseSnapshotHash(tokens, components, orchestration);
  if (!/^[a-f0-9]{64}$/.test(snapshotHash)) {
    stop("base snapshot hash must be a sha256 hex digest");
  }
  if (intentText.length > 2000) {
    stop("intent text must be 2000 characters or fewer");
  }
  if (purpose.length > 240) {
    stop("purpose must be 240 characters or fewer");
  }
  if (providerMode === "api-key") {
    stop("api-key provider mode is blocked until secret references, consent, cost, rate limit, and provider policy are implemented");
  }
  assertNoSecretLikePayload({ intent_text: intentText, purpose }, "Design Studio event request");

  const idempotencyKey = validateStoreIdentifier(
    options.idempotency_key || `idem:${sha256Text(JSON.stringify({ targetRef, providerMode, requestKind, intentText, purpose, snapshotHash })).slice(0, 32)}`,
    "idempotency key",
  );
  const eventId = `dse:${sha256Text(`event:${idempotencyKey}`).slice(0, 24)}`;
  const requestId = `dsr:${sha256Text(`request:${idempotencyKey}`).slice(0, 24)}`;
  const now = isoNow();
  const lifecycleState = provider.status === "ready" && target.id === "dashboard-control-center" ? "queued" : "manual_required";
  const nextAction = lifecycleState === "queued"
    ? "manual_proposal_or_subscription_agent_import_required"
    : "manual_review_required_before_proposal";
  const record = {
    record_version: eventStoreRecordVersion,
    sync_id: eventStoreSyncId,
    record_type: "design_studio_event",
    event_type: "request_queued",
    record_id: `record:${sha256Text(`${eventId}:${records.length + 1}:${now}`).slice(0, 24)}`,
    event_id: eventId,
    request_id: requestId,
    idempotency_key: idempotencyKey,
    target_ref: target.id,
    target_apply_mode: target.applyMode,
    provider_mode: provider.id,
    provider_status: provider.status,
    request_kind: requestKind,
    lifecycle_state: lifecycleState,
    job_state: lifecycleState,
    proposal_state: "proposal_only",
    writes_allowed: false,
    direct_apply_authority: false,
    external_product_apply: false,
    forbidden_capabilities_absent: true,
    base_snapshot_hash: snapshotHash,
    redaction_state: "checked_no_secret_like_payload",
    intent_digest: `sha256:${sha256Text(intentText)}`,
    intent_preview: compactPreview(intentText),
    intent_length: intentText.length,
    purpose_digest: `sha256:${sha256Text(purpose)}`,
    purpose_preview: compactPreview(purpose, 96),
    payload_policy: "metadata_and_redacted_preview_only",
    retry_count: 0,
    event_order: records.length + 1,
    created_at: now,
    updated_at: now,
    next_action: nextAction,
    source_command: "tools/dashboard-design-system queue-request",
    audit_receipt: null,
  };
  return attachAuditReceipt(record);
}

