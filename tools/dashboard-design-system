function readImportJson(inputPath, command) {
  const value = requireOption({ input: inputPath }, "input", command);
  const resolved = path.resolve(value);
  let raw = "";
  try {
    raw = fs.readFileSync(resolved, "utf8");
  } catch (error) {
    stop(`${command} cannot read --input: ${error.message}`, 1);
  }
  try {
    return { payload: JSON.parse(raw), resolved };
  } catch (error) {
    stop(`${command} requires valid JSON input: ${error.message}`, 1);
  }
  return { payload: null, resolved };
}

function rejectForbiddenPayloadFields(value, forbiddenFields, label, currentPath = "") {
  if (!value || typeof value !== "object") {
    return;
  }
  if (Array.isArray(value)) {
    value.forEach((item, index) => rejectForbiddenPayloadFields(item, forbiddenFields, label, `${currentPath}[${index}]`));
    return;
  }
  for (const [key, nested] of Object.entries(value)) {
    const nextPath = currentPath ? `${currentPath}.${key}` : key;
    if (forbiddenFields.has(key)) {
      stop(`${label} must not contain forbidden field: ${nextPath}`);
    }
    rejectForbiddenPayloadFields(nested, forbiddenFields, label, nextPath);
  }
}

function validateImportPayload(payload, schema, schemaId) {
  if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
    stop(`${schemaId} import payload must be an object`);
  }
  assertNoSecretLikePayload(payload, `${schemaId} import payload`);
  for (const field of schema.requiredFields || []) {
    if (!Object.hasOwn(payload, field) || payload[field] === "" || payload[field] == null) {
      stop(`${schemaId} import payload is missing required field: ${field}`);
    }
  }
  const extraForbidden = [
    "raw_api_key",
    "raw_secret",
    "shell_command",
    "direct_apply",
    "auto_apply",
    "apply_token",
    "plan_token",
    "approval_receipt",
    "credential_value",
    "trusted_instruction",
    "owner_write_path",
    "secret_value",
    "css_patch",
    "script_patch",
    "external_product_apply",
    "direct_apply_authority",
  ];
  rejectForbiddenPayloadFields(payload, new Set([...(schema.forbiddenFields || []), ...extraForbidden]), `${schemaId} import payload`);
  if (schemaId === "DesignChangeProposal" && payload.proposal_only !== true) {
    stop("DesignChangeProposal import payload must set proposal_only true");
  }
}

function importSourceId(schemaId, payload) {
  if (schemaId === "CandidateEnvelope") {
