function handleInteractionCommand(command, tokens, components) {
  const options = parseOptionArgs(process.argv.slice(3));
  const componentId = options.component || "tooltip-copy";
  if (!supportedInteractionValues.component.has(componentId)) {
    console.error(`unsupported component: ${componentId}`);
    process.exit(2);
  }
  if (command === "apply-interaction" && options.confirm !== true) {
    console.error("apply-interaction requires --confirm");
    process.exit(2);
  }
  const currentFoundation = foundationFromTokens(tokens);
  const proposedFoundation = foundationFromOptions(tokens, options);
  validateFoundation(proposedFoundation);
  if (process.exitCode) {
    process.exit(process.exitCode);
  }
  const component = components.components.find((candidate) => candidate.id === componentId);
  if (!component) {
    console.error(`missing component: ${componentId}`);
    process.exit(2);
  }
  const proposed = interactionFromOptions(component, options);
  const updatedComponents = {
    ...components,
    components: components.components.map((candidate) => (candidate.id === componentId ? { ...candidate, interaction: proposed } : candidate)),
  };
  const updatedTokens = applyFoundationPresets(tokens, proposedFoundation);
  validateSource(updatedTokens, updatedComponents);
  if (process.exitCode) {
    process.exit(process.exitCode);
  }
  if (command === "apply-interaction") {
    fs.writeFileSync(tokensPath, `${JSON.stringify(updatedTokens, null, 2)}\n`, "utf8");
    fs.writeFileSync(componentsPath, `${JSON.stringify(updatedComponents, null, 2)}\n`, "utf8");
    fs.writeFileSync(generatedCssPath, generatedCss(updatedTokens, updatedComponents), "utf8");
    fs.writeFileSync(generatedJsPath, generatedJs(updatedTokens, updatedComponents, orchestration), "utf8");
  }
  const payload = interactionPayload(command === "apply-interaction" ? "passed" : "ready", component, currentFoundation, proposedFoundation, proposed, command === "apply-interaction");
  process.stdout.write(`${JSON.stringify(payload, null, 2)}\n`);
}

const command = process.argv[2] || "check";
const { tokens, components, orchestration, templates } = loadSources();
const css = generatedCss(tokens, components);
const js = generatedJs(tokens, components, orchestration);

if (command === "emit-css") {
  process.stdout.write(css);
} else if (command === "emit-js") {
  process.stdout.write(js);
} else if (command === "emit-orchestration") {
  process.stdout.write(`${JSON.stringify(orchestration, null, 2)}\n`);
} else if (command === "write") {
  fs.writeFileSync(generatedCssPath, css, "utf8");
  fs.writeFileSync(generatedJsPath, js, "utf8");
} else if (command === "check") {
  checkFileMatches(generatedCssPath, css, "generated CSS");
  checkFileMatches(generatedJsPath, js, "generated JS");
  checkRuntimeWiring();
  if (process.exitCode) {
    process.exit(process.exitCode);
  }
  console.log("Dashboard design-system check passed.");
} else if (command === "plan-interaction" || command === "apply-interaction") {
  handleInteractionCommand(command, tokens, components);
} else if (command === "queue-request") {
  handleQueueRequest(tokens, components, orchestration);
} else if (command === "list-events") {
  handleListEvents(orchestration);
} else if (command === "event-status") {
  handleEventStatus(orchestration);
} else if (command === "cancel-event" || command === "retry-event" || command === "dead-letter-event") {
  transitionEvent(command, orchestration);
} else if (command === "import-candidate" || command === "import-proposal") {
  handleImportCommand(command, orchestration);
} else if (command === "list-imports") {
  handleListImports(orchestration);
} else if (command === "proposal-preview") {
  handleProposalPreview();
} else if (command === "candidate-review") {
  handleCandidateReview();
} else if (command === "agent-handoff") {
  handleAgentHandoff(orchestration);
} else if (command === "agent-package") {
  handleAgentPackage(orchestration);
} else if (command === "export-proposal") {
  handleExportProposal(orchestration);
} else if (command === "provider-policy") {
  handleProviderPolicy(orchestration);
} else if (command === "transaction-preview") {
  handleTransactionPreview(orchestration);
} else if (command === "list-templates") {
  handleListTemplates(orchestration, templates);
} else if (command === "template-preview") {
  handleTemplatePreview(orchestration, templates);
} else if (command === "proposal-status") {
  handleProposalStatus(orchestration, templates);
} else {
  usage();
}
