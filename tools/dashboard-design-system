  if (!rootRelative.startsWith("..") && !path.isAbsolute(rootRelative)) {
    return rootRelative;
  }
  const storeRelative = path.relative(eventStoreDir, filePath);
  if (!storeRelative.startsWith("..") && !path.isAbsolute(storeRelative)) {
    return `external-test-store/${storeRelative.replace(/\\/g, "/")}`;
  }
  return "external-test-store/agent-packages/package.json";
}

function safePackageOutputPath(value, record) {
  const fallback = path.join(agentPackageDir, packageIdForEvent(record), "package.json");
  const resolved = value ? path.resolve(root, value) : fallback;
  fs.mkdirSync(agentPackageDir, { recursive: true });
  const relative = path.relative(agentPackageDir, resolved);
  if (relative.startsWith("..") || path.isAbsolute(relative)) {
    stop("agent-package output must stay under .dashboard-design-studio-events/agent-packages");
  }
  if (path.basename(resolved) !== "package.json") {
    stop("agent-package output file must be named package.json");
  }
  const outputStat = fs.existsSync(resolved) ? fs.lstatSync(resolved) : null;
  if (outputStat?.isSymbolicLink()) {
    stop("agent-package output must not use a symlinked package file");
  }
  const packageRootReal = fs.realpathSync.native(agentPackageDir);
  let existingParent = path.dirname(resolved);
  while (!fs.existsSync(existingParent)) {
    const nextParent = path.dirname(existingParent);
    if (nextParent === existingParent) {
      stop("agent-package output parent could not be resolved safely");
    }
    existingParent = nextParent;
  }
  const parentReal = fs.realpathSync.native(existingParent);
  const realRelative = path.relative(packageRootReal, parentReal);
  if (realRelative.startsWith("..") || path.isAbsolute(realRelative)) {
    stop("agent-package output must stay under the real agent package directory");
  }
  return resolved;
}

