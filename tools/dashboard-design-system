function parseOptionArgs(args) {
  const parsed = { confirm: false };
  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];
    if (arg === "--confirm") {
      parsed.confirm = true;
      continue;
    }
    if (!arg.startsWith("--")) {
      usage();
    }
    const key = arg.slice(2).replace(/-/g, "_");
    const value = args[index + 1];
    if (!value || value.startsWith("--")) {
      usage();
    }
    parsed[key] = value;
    index += 1;
  }
  return parsed;
}

function sha256Text(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function isoNow() {
  if (process.env.DASHBOARD_DESIGN_STUDIO_EVENT_NOW) {
    const forced = new Date(process.env.DASHBOARD_DESIGN_STUDIO_EVENT_NOW);
    if (Number.isNaN(forced.getTime())) {
      stop(`invalid DASHBOARD_DESIGN_STUDIO_EVENT_NOW: ${process.env.DASHBOARD_DESIGN_STUDIO_EVENT_NOW}`);
    }
    return forced.toISOString();
  }
  return new Date().toISOString();
}

function relativeStorePath() {
  const relative = path.relative(root, eventStorePath);
  if (!relative.startsWith("..") && !path.isAbsolute(relative)) {
    return relative;
  }
  return "external-test-store/events.jsonl";
}

function compactPreview(value, limit = 160) {
  const normalized = String(value || "").replace(/\s+/g, " ").trim();
  if (normalized.length <= limit) {
    return normalized;
  }
  return `${normalized.slice(0, limit - 3)}...`;
}

function rejectUnknownOptions(options, allowedKeys, command) {
  for (const key of Object.keys(options)) {
    if (key === "confirm") {
      continue;
    }
    if (!allowedKeys.has(key)) {
      stop(`${command} does not support --${key.replace(/_/g, "-")}`);
    }
  }
}

function requireOption(options, key, command) {
  const value = options[key];
  if (typeof value !== "string" || !value.trim()) {
    stop(`${command} requires --${key.replace(/_/g, "-")}`);
  }
  return value.trim();
}

function validateStoreIdentifier(value, label) {
  if (!/^[A-Za-z0-9._:-]{8,160}$/.test(value)) {
    stop(`${label} must use only letters, numbers, dot, underscore, colon, or hyphen and be at least 8 characters`);
  }
  return value;
}

function safeRelativeDisplayPath(value) {
  if (typeof value !== "string") {
    return "";
  }
  const normalized = value.replace(/[\u0000-\u001f]/g, "").trim();
  if (
    !normalized ||
    normalized.startsWith("/") ||
    normalized.startsWith("\\") ||
    /^[A-Za-z]:[\\/]/.test(normalized) ||
    normalized.split(/[\\/]+/).some((part) => part === "..")
  ) {
    return "";
  }
  return normalized;
}

function safeScopedDisplayPath(value) {
  if (typeof value !== "string") {
    return "";
  }
  if (value.startsWith("product:")) {
    const productPath = safeRelativeDisplayPath(value.slice("product:".length));
    return productPath ? `product:${productPath}` : "";
  }
  return safeRelativeDisplayPath(value);
}

function safeOwnerToolCommand(value) {
  if (typeof value !== "string") {
    return "";
  }
  const normalized = value.replace(/[\u0000-\u001f]/g, "").replace(/\s+/g, " ").trim();
  if (!normalized || /[;&|`$<>\\]/.test(normalized)) {
    return "";
  }
  return /^tools\/[A-Za-z0-9._-]+(?: [A-Za-z0-9._:@/%+=,-]+)*$/.test(normalized) ? normalized : "";
}

function safeTemplateCheckReference(value) {
  if (safeOwnerToolCommand(value)) {
    return value.replace(/\s+/g, " ").trim();
  }
  if (typeof value !== "string") {
    return "";
  }
  const normalized = value.replace(/[\u0000-\u001f]/g, "").trim();
  if (!normalized || /[;&|`$<>\\/\s]/.test(normalized) || secretLikePattern.test(normalized)) {
    return "";
  }
  return /^[A-Za-z0-9._:-]{4,120}$/.test(normalized) ? normalized : "";
}

function baseSnapshotHash(tokens, components, orchestration) {
  return sha256Text(JSON.stringify({
    tokens,
    components,
    orchestration,
  }));
}

function providerModeContract(orchestration, providerMode) {
  const provider = (orchestration.providerModes || []).find((candidate) => candidate.id === providerMode);
  if (!provider) {
    stop(`unsupported provider mode: ${providerMode}`);
  }
  if (provider.directApplyAuthority !== false) {
    stop(`provider mode must not have direct apply authority: ${providerMode}`);
  }
  return provider;
}

function targetAdapterContract(orchestration, targetRef) {
  const target = (orchestration.targetAdapters || []).find((candidate) => candidate.id === targetRef);
  if (!target) {
    stop(`unsupported target ref: ${targetRef}`);
  }
  if (target.id === "external-product" && target.applyMode !== "plan-only") {
    stop("external product targets must remain plan-only");
  }
  if (target.id === "dashboard-control-center" && target.applyMode !== "owner-tool") {
    stop("dashboard-control-center target must remain owner-tool mediated");
  }
  return target;
}

function ensureRequestKind(value) {
  const allowed = new Set(["design-intent", "mock", "template", "manual-proposal"]);
  if (!allowed.has(value)) {
    stop(`unsupported request kind: ${value}`);
  }
  return value;
}

function readEventRecords() {
  if (!fs.existsSync(eventStorePath)) {
    return [];
  }
  const lines = fs.readFileSync(eventStorePath, "utf8").split(/\r?\n/).filter(Boolean);
  return lines.map((line, index) => {
    try {
      return JSON.parse(line);
    } catch (error) {
      stop(`invalid Design Studio event store JSON at line ${index + 1}: ${error.message}`, 1);
    }
    return null;
  });
}

function appendEventRecord(record) {
  fs.mkdirSync(eventStoreDir, { recursive: true });
  fs.appendFileSync(eventStorePath, `${JSON.stringify(record)}\n`, "utf8");
