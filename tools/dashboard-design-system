function latestEventRecords(records) {
  const latestByEvent = new Map();
  for (const record of records) {
    if (!record || record.sync_id !== eventStoreSyncId || !record.event_id) {
      continue;
    }
    const previous = latestByEvent.get(record.event_id);
    if (!previous || Number(record.event_order || 0) >= Number(previous.event_order || 0)) {
      latestByEvent.set(record.event_id, record);
    }
  }
  return [...latestByEvent.values()].sort((left, right) => {
    const leftOrder = Number(left.event_order || 0);
    const rightOrder = Number(right.event_order || 0);
    if (leftOrder !== rightOrder) {
      return leftOrder - rightOrder;
    }
    return String(left.event_id).localeCompare(String(right.event_id));
  });
}

