function transitionEvent(command, orchestration) {
  const options = parseOptionArgs(process.argv.slice(3));
  const allowed = command === "dead-letter-event" ? new Set(["event_id", "reason"]) : new Set(["event_id"]);
  rejectUnknownOptions(options, allowed, command);
  if (options.confirm !== true) {
    stop(`${command} requires --confirm`);
  }
  const eventId = requireOption(options, "event_id", command);
  const records = readEventRecords();
  const current = findLatestEvent(records, eventId);
  if (!current) {
    stop(`unknown Design Studio event: ${eventId}`, 1);
  }
  const terminalStates = new Set(["cancelled", "completed"]);
  let nextState = "";
  let eventType = "";
  let nextAction = "";
  let retryCount = Number(current.retry_count || 0);
  if (command === "cancel-event") {
    if (terminalStates.has(current.lifecycle_state) || current.lifecycle_state === "dead_letter") {
      stop(`cannot cancel event in state: ${current.lifecycle_state}`);
    }
    nextState = "cancelled";
    eventType = "request_cancelled";
    nextAction = "no_follow_up_required";
  } else if (command === "dead-letter-event") {
    const reason = requireOption(options, "reason", command);
    if (terminalStates.has(current.lifecycle_state) || current.lifecycle_state === "dead_letter") {
      stop(`cannot dead-letter event in state: ${current.lifecycle_state}`);
    }
    assertNoSecretLikePayload({ reason }, "Design Studio dead-letter reason");
    nextState = "dead_letter";
    eventType = "request_dead_lettered";
    nextAction = "inspect_dead_letter_reason_then_retry_or_cancel";
  } else if (command === "retry-event") {
    if (!new Set(["dead_letter", "blocked", "manual_required"]).has(current.lifecycle_state)) {
      stop(`cannot retry event in state: ${current.lifecycle_state}`);
    }
    nextState = current.target_ref === "dashboard-control-center" && current.provider_status === "ready" ? "queued" : "manual_required";
    eventType = "request_retried";
    nextAction = nextState === "queued" ? "manual_proposal_or_subscription_agent_import_required" : "manual_review_required_before_proposal";
    retryCount += 1;
  } else {
    usage();
  }
  const now = isoNow();
  const transitionReason = command === "dead-letter-event" ? requireOption(options, "reason", command) : "";
  const nextRecord = attachAuditReceipt({
    ...current,
    event_type: eventType,
    record_id: `record:${sha256Text(`${eventId}:${records.length + 1}:${now}:${eventType}`).slice(0, 24)}`,
    previous_lifecycle_state: current.lifecycle_state,
    lifecycle_state: nextState,
    job_state: nextState,
    retry_count: retryCount,
    event_order: records.length + 1,
    updated_at: now,
    next_action: nextAction,
    transition_reason_digest: transitionReason ? `sha256:${sha256Text(transitionReason)}` : "",
    transition_reason_preview: transitionReason ? compactPreview(transitionReason, 120) : "",
    source_command: `tools/dashboard-design-system ${command}`,
    audit_receipt: null,
  });
  appendEventRecord(nextRecord);
  process.stdout.write(`${JSON.stringify(eventOutput("passed", nextRecord, orchestration, {
    reason_code: `design_studio_event_${nextState}`,
    next_action: nextAction,
  }), null, 2)}\n`);
}

