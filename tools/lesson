#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$SCRIPT_DIR/lib/lesson_common.sh"

ROOT="$LESSON_ROOT"
FLOW="$(lesson_flow_file)"
STATE="$(lesson_state_file)"
TRACKER="$(lesson_tracker_file)"
HANDOFF="$(lesson_handoff_file)"
COMMAND="${1:-}"
[[ $# -gt 0 ]] && shift || true
STAMP="$(date '+%Y-%m-%d %H:%M:%S')"

usage() {
  cat <<'USAGE'
Usage:
  tools/lesson 現在地
  tools/lesson 一覧
  tools/lesson 開始 <step_id>
  tools/lesson 通過 <step_id> "メモ"
  tools/lesson 復習 <step_id>

Aliases:
  status, list, start, pass, complete, revisit

Rules:
  - Only the current step can be started or passed.
  - Future locked steps cannot be started or passed.
  - Completed steps can be revisited freely.
USAGE
}

require_files() {
  for file in "$FLOW" "$STATE" "$TRACKER" "$HANDOFF"; do
    [[ -f "$file" ]] || { printf 'missing: %s\n' "$file" >&2; exit 1; }
  done
}

validate_structure() {
  lesson_structure_check
}

flow_field() {
  local step_id="$1"
  local field="$2"
  awk -F '\t' -v step="$step_id" -v field="$field" '
    $1 !~ /^#/ && $2 == step { print $field; found=1; exit }
    END { if (!found) exit 1 }
  ' "$FLOW"
}

state_field() {
  local step_id="$1"
  local field="$2"
  awk -F '\t' -v step="$step_id" -v field="$field" '
    $1 !~ /^#/ && $2 == step { print $field; found=1; exit }
    END { if (!found) exit 1 }
  ' "$STATE"
}

current_step() {
  awk -F '\t' '$1 !~ /^#/ && $3 == "current" { print $2; exit }' "$STATE"
}

next_step_after() {
  local step_id="$1"
  awk -F '\t' -v step="$step_id" '
    $1 !~ /^#/ {
      if (previous) {
        print $2
        exit
      }
      if ($2 == step) previous = 1
    }
  ' "$FLOW"
}

step_exists() {
  local step_id="$1"
  awk -F '\t' -v step="$step_id" '$1 !~ /^#/ && $2 == step { found=1 } END { exit found ? 0 : 1 }' "$FLOW"
}

step_label() {
  local step_id="$1"
  local day title
  day="$(flow_field "$step_id" 3)"
  title="$(flow_field "$step_id" 4)"
  printf '%s / %s / %s' "$step_id" "$day" "$title"
}

require_step() {
  local step_id="$1"
  [[ -n "$step_id" ]] || { printf 'step_id is required.\n' >&2; usage; exit 1; }
  step_exists "$step_id" || { printf 'unknown step_id: %s\n' "$step_id" >&2; exit 1; }
}

append_tracker() {
  local kind="$1"
  local step_id="$2"
  local memo="$3"
  {
    printf '\n## %s\n\n' "レッスン制御ログ: $STAMP"
    printf '```text\n'
    printf '種別: %s\n' "$kind"
    printf '項目: %s\n' "$(step_label "$step_id")"
    printf '通過条件: %s\n' "$(flow_field "$step_id" 5)"
    printf '内容: %s\n' "$memo"
    printf '```\n'
  } >> "$TRACKER"
}

append_handoff() {
  local kind="$1"
  local step_id="$2"
  local memo="$3"
  local current
  current="$(current_step)"
  {
    printf '\n## %s\n\n' "レッスン制御ハンドオフ: $STAMP"
    printf '```text\n'
    printf '種別: %s\n' "$kind"
    printf '直近の項目: %s\n' "$(step_label "$step_id")"
    printf '通過条件: %s\n' "$(flow_field "$step_id" 5)"
    printf '内容: %s\n' "$memo"
    if [[ -n "$current" ]]; then
      printf '次に進める項目: %s\n' "$(step_label "$current")"
      printf '次回の最初の一問: %s を始めてよいですか？\n' "$(flow_field "$current" 4)"
    else
      printf '次に進める項目: すべて完了\n'
      printf '次回の最初の一問: レッスン全体をふりかえりますか？\n'
    fi
    printf '```\n'
  } >> "$HANDOFF"
}

status() {
  local current completed total
  current="$(current_step)"
  completed="$(awk -F '\t' '$1 !~ /^#/ && $3 == "completed" { count++ } END { print count + 0 }' "$STATE")"
  total="$(awk -F '\t' '$1 !~ /^#/ { count++ } END { print count + 0 }' "$STATE")"

  printf 'Lesson progress: %s/%s completed\n' "$completed" "$total"
  if [[ -n "$current" ]]; then
    printf 'Current step: %s\n' "$(step_label "$current")"
  else
    printf 'Current step: all steps completed\n'
  fi
  printf '\nUse:\n'
  printf '  ./tools/lesson 開始 <step_id>\n'
  printf '  ./tools/lesson 通過 <step_id> "メモ"\n'
  printf '  ./tools/lesson 復習 <completed_step_id>\n'
}

list_steps() {
  awk -F '\t' '
    NR == FNR {
      if ($1 !~ /^#/) status[$2] = $3
      next
    }
    $1 !~ /^#/ {
      printf "%s\t%s\t%s\t%s\n", $2, status[$2], $3, $4
    }
  ' "$STATE" "$FLOW"
}

rewrite_state_for_start() {
  local step_id="$1"
  local tmp
  tmp="$(mktemp "$STATE.tmp.XXXXXX")"
  awk -F '\t' -v OFS='\t' -v step="$step_id" -v stamp="$STAMP" '
    /^#/ { print; next }
    $2 == step && $3 == "current" && $4 == "" { $4 = stamp }
    { print }
  ' "$STATE" > "$tmp"
  mv "$tmp" "$STATE"
}

rewrite_state_for_pass() {
  local step_id="$1"
  local next_step="$2"
  local tmp
  tmp="$(mktemp "$STATE.tmp.XXXXXX")"
  awk -F '\t' -v OFS='\t' -v step="$step_id" -v next_step="$next_step" -v stamp="$STAMP" '
    /^#/ { print; next }
    $2 == step {
      $3 = "completed"
      if ($4 == "") $4 = stamp
      $5 = stamp
      passed = 1
      print
      next
    }
    next_step != "" && $2 == next_step && $3 == "locked" {
      $3 = "current"
      $4 = stamp
      print
      next
    }
    { print }
  ' "$STATE" > "$tmp"
  mv "$tmp" "$STATE"
}

start_step() {
  local step_id="$1"
  require_step "$step_id"
  local state current
  state="$(state_field "$step_id" 3)"
  current="$(current_step)"

  case "$state" in
    current)
      rewrite_state_for_start "$step_id"
      append_tracker "開始" "$step_id" "順番どおり現在の項目を開始した。"
      append_handoff "開始" "$step_id" "この項目から進行中。"
      printf 'Started current step: %s\n' "$(step_label "$step_id")"
      ;;
    completed)
      printf 'Revisit allowed: %s\n' "$(step_label "$step_id")"
      ;;
    locked)
      printf 'Blocked: this step is locked and cannot be skipped.\n' >&2
      [[ -n "$current" ]] && printf 'Next required step: %s\n' "$(step_label "$current")" >&2
      exit 1
      ;;
    *)
      printf 'invalid state for %s: %s\n' "$step_id" "$state" >&2
      exit 1
      ;;
  esac
}

pass_step() {
  local step_id="$1"
  shift || true
  require_step "$step_id"
  local memo="${*:-}"
  if [[ -z "$memo" ]]; then
    printf 'pass memo is required. Required output: %s\n' "$(flow_field "$step_id" 5)" >&2
    exit 1
  fi
  local state current next
  state="$(state_field "$step_id" 3)"
  current="$(current_step)"
  next="$(next_step_after "$step_id")"

  case "$state" in
    current)
      rewrite_state_for_pass "$step_id" "$next"
      append_tracker "通過" "$step_id" "$memo"
      append_handoff "通過" "$step_id" "$memo"
      printf 'Passed step: %s\n' "$(step_label "$step_id")"
      current="$(current_step)"
      if [[ -n "$current" ]]; then
        printf 'Next required step: %s\n' "$(step_label "$current")"
      else
        printf 'All lesson steps completed.\n'
      fi
      ;;
    completed)
      printf 'Already completed. Revisit is allowed: %s\n' "$(step_label "$step_id")"
      ;;
    locked)
      printf 'Blocked: this step is locked and cannot be passed before earlier steps.\n' >&2
      [[ -n "$current" ]] && printf 'Next required step: %s\n' "$(step_label "$current")" >&2
      exit 1
      ;;
    *)
      printf 'invalid state for %s: %s\n' "$step_id" "$state" >&2
      exit 1
      ;;
  esac
}

revisit_step() {
  local step_id="$1"
  require_step "$step_id"
  local state current
  state="$(state_field "$step_id" 3)"
  current="$(current_step)"

  if [[ "$state" == "completed" ]]; then
    append_tracker "復習" "$step_id" "完了済み項目を再確認した。"
    append_handoff "復習" "$step_id" "完了済み項目を再確認。現在の進行位置は変更しない。"
    printf 'Revisit allowed: %s\n' "$(step_label "$step_id")"
    [[ -n "$current" ]] && printf 'Current required step remains: %s\n' "$(step_label "$current")"
    return 0
  else
    printf 'Blocked: only completed steps can be revisited freely.\n' >&2
    [[ -n "$current" ]] && printf 'Next required step: %s\n' "$(step_label "$current")" >&2
    exit 1
  fi
}

require_files
validate_structure

case "$COMMAND" in
  現在地|status)
    status
    ;;
  一覧|list)
    list_steps
    ;;
  開始|start)
    start_step "${1:-}"
    ;;
  通過|完了|pass|complete)
    step="${1:-}"
    [[ $# -gt 0 ]] && shift || true
    pass_step "$step" "$@"
    ;;
  復習|revisit)
    revisit_step "${1:-}"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n' "$COMMAND" >&2
    usage
    exit 1
    ;;
esac
