dashboard_selected_workflow_context() {
  local menu_id="$1"
  local lookup_id kind
  if [[ "$menu_id" == "lesson-repository-improvement" ]]; then
    lookup_id="lesson-maintenance"
  else
    lookup_id="$menu_id"
  fi
  kind="$(dashboard_data_workflow_context_map_field "$lookup_id" workflow_kind 2>/dev/null || printf 'unknown')"
  case "$kind" in
    lesson) printf 'lesson' ;;
    maintenance) printf 'lesson-maintenance' ;;
    workflow) printf '%s' "$lookup_id" ;;
    *) printf 'unknown' ;;
  esac
}

