dashboard_git_workflow_consistency_row_for_setting() {
  local key="$1"
  local row severity status reason_code affected_ids reason_key next_action_key best_row=""
  if [[ "${DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROWS_INITIALIZED:-0}" == "1" ]]; then
    [[ -n "${DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROWS:-}" ]] || return 1
    while IFS=$'\t' read -r severity status reason_code affected_ids reason_key next_action_key; do
      [[ -n "$severity$status" ]] || continue
      case ",$affected_ids," in
        *",$key,"*)
          row="$(printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$severity" "$status" "$reason_code" "$affected_ids" "$reason_key" "$next_action_key")"
          if [[ "$status" == "blocked" ]]; then
            printf '%s' "$row"
            return 0
          fi
          [[ -n "$best_row" ]] || best_row="$row"
          ;;
      esac
    done <<<"$DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROWS"
    [[ -n "$best_row" ]] || return 1
    printf '%s' "$best_row"
    return 0
  fi
  if [[ -n "${DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROW_CACHE[$key]+set}" ]]; then
    row="${DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROW_CACHE[$key]}"
    [[ "$row" != "__missing__" ]] || return 1
    printf '%s\n' "$row"
    return 0
  fi
  row="$(git_workflow_consistency_row_for_setting "$key" 2>/dev/null)" || {
    DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROW_CACHE[$key]="__missing__"
    return 1
  }
  DASHBOARD_GIT_WORKFLOW_CONSISTENCY_ROW_CACHE[$key]="$row"
  printf '%s\n' "$row"
}

