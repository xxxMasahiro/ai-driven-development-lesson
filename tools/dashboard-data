dashboard_document_decision_briefs_file() {
  printf '%s\n' "${DASHBOARD_DOCUMENT_DECISION_BRIEFS_FILE:-$ROOT/docs/workflow/DOCUMENT_DECISION_BRIEFS.tsv}"
}

dashboard_document_decision_brief_row() {
  local id="$1"
  local file
  file="$(dashboard_document_decision_briefs_file)"
  [[ -f "$file" ]] || return 1
  awk -F '\t' -v id="$id" '
    /^[[:space:]]*$/ { next }
    $1 ~ /^#/ { next }
    $1 == id { print; found = 1; exit }
    END { exit found ? 0 : 1 }
  ' "$file"
}

dashboard_document_decision_brief_field() {
  local id="$1"
  local field="$2"
  local row field_number
  row="$(dashboard_document_decision_brief_row "$id")" || return 1
  case "$field" in
    source_paths) field_number=2 ;;
    source_hash) field_number=3 ;;
    updated_at) field_number=4 ;;
    title_ja) field_number=5 ;;
    detail_ja) field_number=6 ;;
    summary_ja) field_number=7 ;;
    action_ja) field_number=8 ;;
    title_en) field_number=9 ;;
    detail_en) field_number=10 ;;
    summary_en) field_number=11 ;;
    action_en) field_number=12 ;;
    *) return 1 ;;
  esac
  printf '%s\n' "$row" | awk -F '\t' -v field_number="$field_number" '{ print $field_number; exit }'
}

dashboard_document_decision_brief_default_source_paths() {
  case "$1" in
    requirements) dashboard_document_target_path requirements ;;
    specification) dashboard_document_target_path specification ;;
    implementationPlan) dashboard_document_target_path implementationPlan ;;
    taskTracker) dashboard_document_target_path taskTracker ;;
    handoff) dashboard_document_target_path handoff ;;
    *) return 1 ;;
  esac
}

dashboard_document_decision_brief_source_paths() {
  local id="$1"
  local paths requires_product_repo
  paths="$(dashboard_document_decision_brief_field "$id" source_paths 2>/dev/null || dashboard_document_decision_brief_default_source_paths "$id" 2>/dev/null || printf '')"
  requires_product_repo="$(dashboard_context_product_repo_required "$SELECTED_MENU_ID")"
  if [[ "$requires_product_repo" != "true" && "$paths" == product:* ]]; then
    paths="$(dashboard_document_decision_brief_default_source_paths "$id" 2>/dev/null || printf '')"
  fi
  printf '%s' "$paths"
}

dashboard_scoped_file_state() {
  local scoped_path="$1"
  local relpath="$scoped_path"
  local root="$ROOT"
  case "$scoped_path" in
    product:*)
      relpath="${scoped_path#product:}"
      root="$PRODUCT_ROOT"
      ;;
  esac
  case "$relpath" in
    /*|\\*|*..*) printf 'unknown'; return ;;
  esac
  if [[ -f "$root/$relpath" ]]; then
    printf 'ready'
  else
    printf 'missing'
  fi
}

dashboard_document_target_path() {
  local key="$1"
  local requires_product_repo
  requires_product_repo="$(dashboard_context_product_repo_required "$SELECTED_MENU_ID")"
  if [[ "$requires_product_repo" == "true" ]]; then
    case "$key" in
      requirements) printf 'product:docs/product/REQUIREMENTS.md' ;;
