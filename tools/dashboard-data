  esac
  repo="$(dashboard_target_repository_root "$menu_id" 2>/dev/null || true)"
  [[ -n "$repo" ]] || { printf 'not_applicable'; return; }
  command_text="./tools/product-security gate --context $context --repo $repo"
  if ! product_workflow_git_usage_requires_git_worktree "$mode"; then
    command_text="$command_text --git-optional"
  fi
  printf '%s' "$command_text"
}

dashboard_product_authority_status_command() {
  local context="$1"
  local mode="$2"
  local menu_id="${3:-$SELECTED_MENU_ID}"
  local repo command_text
  repo="$(dashboard_target_repository_root "$menu_id" 2>/dev/null || true)"
  command_text="./tools/product-repository-authority status --json --context $context"
  if [[ -n "$repo" ]]; then
    command_text="$command_text --repo $repo"
  fi
  if ! product_workflow_git_usage_requires_git_worktree "$mode"; then
    command_text="$command_text --git-optional"
  fi
  if ! product_workflow_git_usage_requires_ci "$mode"; then
    command_text="$command_text --ci-optional"
  fi
  printf '%s' "$command_text"
}

dashboard_live_command_failure_status() {
  local kind="$1"
  local exit_code="$2"
  local output="$3"
  case "$exit_code" in
    124|137) printf 'unknown'; return ;;
  esac
  case "$kind" in
    git)
      case "$output" in
        *'does not exist'*|*'not inside a Git worktree'*) printf 'missing' ;;
        *) printf 'failed' ;;
      esac
      ;;
    ci)
      case "$output" in
        *'gh is not installed'*|*'gh is not authenticated'*|*'GitHub repository could not be resolved'*) printf 'blocked' ;;
        *'No GitHub Actions runs found'*|*'No GitHub Actions runs matched'*) printf 'not_run' ;;
        *) printf 'failed' ;;
      esac
      ;;
    security)
      case "$output" in
        *'missing product security policy'*|*'invalid product security policy row'*|*'invalid workflow context map row'*|*'unknown product security context'*) printf 'failed' ;;
        *) printf 'blocked' ;;
      esac
      ;;
    *)
      printf 'unknown'
      ;;
  esac
}

dashboard_live_command_status() {
  local kind="$1"
  local success_status="$2"
  shift 2
  local output exit_code
  dashboard_live_status_enabled || { printf 'unknown'; return; }
  command -v timeout >/dev/null 2>&1 || { printf 'unknown'; return; }
