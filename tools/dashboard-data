  local id="$1"
  local menu_id="${2:-$SELECTED_MENU_ID}"
  local cache_key stored_hash current_hash freshness_state
  cache_key="$id|$menu_id"
  if [[ -n "${DASHBOARD_DOCUMENT_DECISION_BRIEF_FRESHNESS_CACHE[$cache_key]+set}" ]]; then
    printf '%s' "${DASHBOARD_DOCUMENT_DECISION_BRIEF_FRESHNESS_CACHE[$cache_key]}"
    return
  fi
  if ! dashboard_document_decision_brief_row "$id" >/dev/null 2>&1; then
    DASHBOARD_DOCUMENT_DECISION_BRIEF_FRESHNESS_CACHE[$cache_key]="missing"
    printf 'missing'
    return
  fi
  stored_hash="$(dashboard_document_decision_brief_field "$id" source_hash 2>/dev/null || printf '')"
  current_hash="$(dashboard_document_decision_brief_current_hash "$id" "$menu_id" 2>/dev/null || printf '')"
  if [[ -z "$stored_hash" || -z "$current_hash" ]]; then
    freshness_state="missing"
  elif [[ "$stored_hash" == "$current_hash" ]]; then
    freshness_state="ready"
  else
    freshness_state="stale"
  fi
  DASHBOARD_DOCUMENT_DECISION_BRIEF_FRESHNESS_CACHE[$cache_key]="$freshness_state"
  printf '%s' "$freshness_state"
}

