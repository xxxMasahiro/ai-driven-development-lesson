dashboard_document_decision_brief_current_hash() {
  local id="$1"
  local source_paths rel display_rel path digest seed first
  local -a paths=()
  source_paths="$(dashboard_document_decision_brief_source_paths "$id")"
  [[ -n "$source_paths" ]] || return 1
  IFS=';' read -r -a paths <<<"$source_paths"
  first=1
  seed=""
  for rel in "${paths[@]}"; do
    [[ -n "$rel" ]] || continue
    display_rel="$rel"
    case "$rel" in
      /*|\\*|*..*) return 1 ;;
    esac
    if [[ "$rel" == product:* ]]; then
      display_rel="${rel#product:}"
      case "$display_rel" in
        /*|\\*|*..*) return 1 ;;
      esac
      path="$PRODUCT_ROOT/$display_rel"
    else
      path="$ROOT/$rel"
    fi
    if [[ -f "$path" ]]; then
      if command -v sha256sum >/dev/null 2>&1; then
        digest="$(sha256sum "$path" | awk '{ print $1; exit }')"
      else
        digest="$(shasum -a 256 "$path" | awk '{ print $1; exit }')"
      fi
    else
      digest="missing"
    fi
    if [[ "${#paths[@]}" -eq 1 ]]; then
      printf '%s' "$digest"
      return 0
    fi
    seed+="${digest} ${display_rel}"$'\n'
    first=0
  done
  [[ -n "$seed" ]] || return 1
  dashboard_data_content_hash "$seed"
}

dashboard_document_decision_brief_freshness_state() {
