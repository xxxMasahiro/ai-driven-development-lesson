add_selected_context_partial_failures() {
  local context_json="$1"
  local line source status reason required_command partial_status
  while IFS=$'\t' read -r source status reason required_command; do
    [[ -n "${source:-}" ]] || continue
    case "$status" in
      failed) partial_status="failed" ;;
      blocked) partial_status="blocked" ;;
      *) partial_status="unknown" ;;
    esac
    add_partial_failure "$source" "$partial_status" "$reason" "$required_command"
  done < <(
    DASHBOARD_SELECTED_CONTEXT_JSON="$context_json" node -e '
const data = JSON.parse(process.env.DASHBOARD_SELECTED_CONTEXT_JSON || "{}");
const blockers = Array.isArray(data.blockers) ? data.blockers : [];
const clean = (value, fallback) =>
  String(value ?? fallback)
    .replace(/[\t\r\n]+/g, " ")
    .trim() || fallback;
for (const blocker of blockers) {
  if (!blocker || typeof blocker !== "object" || Array.isArray(blocker)) continue;
  const source = clean(blocker.source, "unknown");
  const status = clean(blocker.status, "unknown");
  const reason = clean(blocker.reason, "Current selected context has a blocking condition.");
  const requiredCommand = clean(blocker.required_command, "./tools/dashboard all");
  process.stdout.write(`${source}\t${status}\t${reason}\t${requiredCommand}\n`);
}
'
  )
}

