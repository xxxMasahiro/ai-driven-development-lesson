dashboard_product_profile_menu_id_for_file() {
  local profile_file="$1"
  [[ -f "$profile_file" ]] || return 1
  DASHBOARD_PRODUCT_PROFILE_FILE="$profile_file" node <<'NODE'
const fs = require("node:fs");

const file = process.env.DASHBOARD_PRODUCT_PROFILE_FILE || "";
let data;
try {
  data = JSON.parse(fs.readFileSync(file, "utf8"));
} catch (_error) {
  process.exit(1);
}
const menuId = typeof data.menu_id === "string" ? data.menu_id.trim() : "";
if (!menuId) process.exit(1);
process.stdout.write(menuId);
NODE
}

dashboard_detect_product_repository_root_for_menu() {
  local menu_id="$1"
  local expected_menu_id project_root profile_file repo profile_menu_id
  expected_menu_id="$(dashboard_menu_profile_id "$menu_id")"
  project_root="$(lesson_project_root)"
  [[ -d "$project_root" ]] || return 1
  for profile_file in "$project_root"/*/ops/PRODUCT_PROFILE.json; do
    [[ -f "$profile_file" ]] || continue
    repo="${profile_file%/ops/PRODUCT_PROFILE.json}"
    [[ "$repo" != "$ROOT" ]] || continue
    profile_menu_id="$(dashboard_product_profile_menu_id_for_file "$profile_file" 2>/dev/null || true)"
    if [[ "$profile_menu_id" == "$expected_menu_id" ]]; then
      printf '%s' "$repo"
      return 0
    fi
  done
  return 1
}

dashboard_target_repository_root() {
  local menu_id="${1:-$SELECTED_MENU_ID}"
  local requires_product_repo cache_key root registry_has_rows
  cache_key="$menu_id"
  if [[ -n "${DASHBOARD_TARGET_REPOSITORY_ROOT_CACHE[$cache_key]+set}" ]]; then
    root="${DASHBOARD_TARGET_REPOSITORY_ROOT_CACHE[$cache_key]}"
    [[ -n "$root" ]] || return 1
    printf '%s' "$root"
    return 0
  fi

  case "$menu_id" in
    step_1_7|step_1_14|advanced)
      root="$PRODUCT_ROOT"
      ;;
    lesson-repository-improvement)
      root="$ROOT"
      ;;
    *)
      requires_product_repo="$(dashboard_context_product_repo_required "$menu_id")"
      if [[ "$requires_product_repo" == "true" ]]; then
        registry_has_rows="false"
        product_repository_registry_has_rows && registry_has_rows="true"
        root="$(product_repository_registry_root_for_menu "$menu_id" 2>/dev/null || true)"
        if [[ -z "$root" && "$registry_has_rows" != "true" ]]; then
          root="$(dashboard_detect_product_repository_root_for_menu "$menu_id" 2>/dev/null || true)"
          case "$menu_id" in
            product-improvement|external-integration)
              if [[ -z "$root" && -n "$PRODUCT_ROOT" && -d "$PRODUCT_ROOT" ]]; then
                root="$PRODUCT_ROOT"
              fi
              ;;
          esac
        fi
      else
        root=""
      fi
      ;;
  esac

  DASHBOARD_TARGET_REPOSITORY_ROOT_CACHE[$cache_key]="$root"
  [[ -n "$root" ]] || return 1
  printf '%s' "$root"
}

dashboard_selected_product_root() {
  local menu_id="${1:-$SELECTED_MENU_ID}"
  dashboard_target_repository_root "$menu_id" 2>/dev/null || return 1
}

dashboard_validate_selected_menu_id() {
