  DASHBOARD_SCOPE_OBSERVED_AT="$observed_at" \
  DASHBOARD_PREVIOUS_SNAPSHOT_FILE="$ROOT/.dashboard-control-center/dashboard-data.json" \
  node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const crypto = require("node:crypto");

function text(value, fallback = "") {
  return typeof value === "string" && value.trim() ? value.trim() : fallback;
}

function hash(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function jsonFromEnv(name, fallback) {
  try {
    return JSON.parse(process.env[name] || "");
  } catch (_error) {
    return fallback;
  }
}

function normalizeRel(rel) {
  return String(rel || "").replace(/\\/g, "/").replace(/^\/+/, "").replace(/\/+/g, "/");
}

function safeRel(rel) {
  const normalized = normalizeRel(rel);
  return Boolean(normalized) && !normalized.startsWith("../") && !normalized.includes("/../") && normalized !== "..";
}

function patternToRegExp(pattern) {
  const escaped = pattern.replace(/[.+^${}()|[\]\\]/g, "\\$&").replace(/\*/g, "[^/]*");
  return new RegExp(`^${escaped}$`);
}

function shouldExclude(rel, isDirectory, excludePatterns) {
  const normalized = normalizeRel(rel);
  if (!normalized) return false;
  const baseName = path.posix.basename(normalized);
  if (baseName === ".git" || normalized.startsWith(".git/")) return true;
  for (const pattern of excludePatterns) {
    const cleaned = normalizeRel(pattern).replace(/^\.\//, "");
    if (!cleaned) continue;
    if (cleaned.endsWith("/")) {
      const prefix = cleaned.replace(/\/+$/, "");
      if (normalized === prefix || normalized.startsWith(`${prefix}/`)) return true;
      continue;
    }
    if (cleaned.includes("*")) {
      const matcher = patternToRegExp(cleaned);
      if (matcher.test(normalized) || matcher.test(baseName)) return true;
      continue;
    }
    if (normalized === cleaned || normalized.startsWith(`${cleaned}/`) || baseName === cleaned) return true;
  }
  return false;
}

function roleForPath(rel, isDirectory) {
  const normalized = normalizeRel(rel);
  if (isDirectory) {
    if (normalized === "docs/product" || normalized.startsWith("docs/product/")) return ["product_document"];
    if (normalized === "docs/workflow" || normalized.startsWith("docs/workflow/")) return ["workflow_document"];
    if (normalized === "docs/design-system" || normalized.startsWith("docs/design-system/")) return ["design_system_document"];
    if (normalized === "docs/memory" || normalized.startsWith("docs/memory/")) return ["memory_document"];
    if (normalized === "ops" || normalized.startsWith("ops/")) return ["ops_directory"];
    if (normalized === "skills" || normalized.startsWith("skills/")) return ["agent_support"];
    if (normalized === "tools" || normalized.startsWith("tools/")) return ["repository_tool"];
    if (normalized === "src" || normalized.startsWith("src/")) return ["source_tree"];
    if (normalized === "test" || normalized === "tests" || normalized.startsWith("test/") || normalized.startsWith("tests/")) return ["test_tree"];
    return ["repository_directory"];
  }
  if (normalized === "AGENTS.MD") return ["repository_rules"];
  if (normalized === "AGENT.md") return ["repository_rules"];
  if (normalized === "README.md") return ["repository_entry"];
  if (normalized === "package.json" || normalized === "package-lock.json") return ["dependency_config"];
  if (normalized.startsWith(".github/workflows/")) return ["ci_workflow"];
  if (normalized.startsWith("docs/product/")) return ["product_document"];
  if (normalized.startsWith("docs/workflow/")) return ["workflow_document"];
  if (normalized.startsWith("docs/design-system/")) return ["design_system_document"];
  if (normalized.startsWith("docs/memory/")) return ["memory_document"];
  if (normalized.startsWith("ops/")) return ["ops_manifest"];
  if (normalized.startsWith("skills/")) return ["agent_support"];
  if (normalized.startsWith("tools/")) return ["repository_tool"];
  if (normalized.startsWith("src/") || normalized.startsWith("bin/") || normalized.startsWith("lib/")) return ["source_code"];
  if (normalized.startsWith("test/") || normalized.startsWith("tests/")) return ["unit_test"];
  return ["repository_file"];
}

function roleDescription(roleId) {
  const descriptions = {
    design_system_document: "Design system document: visual rules, component guidance, and UI decisions for the product.",
    repository_tool: "Repository tool: local command or script used to inspect, verify, or operate this repository.",
  };
  return descriptions[roleId] || "";
}

function walk(root, excludePatterns, limit = 700) {
  const files = [];
  const directories = [];
  let truncated = false;

  function visit(relativeDir) {
    if (files.length >= limit) {
      truncated = true;
      return;
    }
    const absoluteDir = path.join(root, relativeDir);
    let entries = [];
    try {
      entries = fs.readdirSync(absoluteDir, { withFileTypes: true });
    } catch (_error) {
      return;
    }
    entries.sort((left, right) => left.name.localeCompare(right.name));
    for (const entry of entries) {
      const rel = normalizeRel(path.posix.join(normalizeRel(relativeDir), entry.name));
      const isDirectory = entry.isDirectory();
      if (shouldExclude(rel, isDirectory, excludePatterns)) continue;
      if (isDirectory) {
        directories.push(rel);
        visit(rel);
        if (truncated) return;
      } else if (entry.isFile()) {
        let stat = null;
        try {
          stat = fs.statSync(path.join(root, rel));
        } catch (_error) {
          stat = null;
        }
        files.push({
          path: rel,
          type: "file",
          size: stat ? stat.size : 0,
          mtime_ms: stat ? Math.trunc(stat.mtimeMs) : 0,
        });
        if (files.length >= limit) {
          truncated = true;
          return;
        }
      }
    }
  }

  visit("");
  return { files, directories, truncated };
}

function existsEntry(root, rel, type = "file") {
  if (!safeRel(rel)) return false;
  try {
    const stat = fs.statSync(path.join(root, rel));
    return type === "directory" ? stat.isDirectory() : stat.isFile();
  } catch (_error) {
    return false;
  }
}

const menuId = text(process.env.DASHBOARD_SCOPE_MENU_ID, "unknown");
const workflowContext = text(process.env.DASHBOARD_SCOPE_WORKFLOW_CONTEXT, "unknown");
const repositoryName = text(process.env.DASHBOARD_SCOPE_REPOSITORY_NAME, "not_selected");
const repositoryRoot = text(process.env.DASHBOARD_SCOPE_REPOSITORY_ROOT, "");
const authority = jsonFromEnv("DASHBOARD_SCOPE_AUTHORITY_JSON", {});
const index = authority.repository_index && typeof authority.repository_index === "object" ? authority.repository_index : {};
const observedAt = text(process.env.DASHBOARD_SCOPE_OBSERVED_AT, "");
const pathState = text(process.env.DASHBOARD_SCOPE_PATH_STATE, "unknown");
const gitState = text(process.env.DASHBOARD_SCOPE_GIT_STATE, "unknown");
const profilePath = "ops/PRODUCT_PROFILE.json";
const indexPath = text(index.path, "ops/REPOSITORY_INDEX.json");
const scopeBasis = `${menuId}\0${workflowContext}\0${repositoryName}\0${text(index.root_name, repositoryName)}`;
const scopeId = hash(scopeBasis).slice(0, 16);
const isDirectoryRoot = repositoryRoot && fs.existsSync(repositoryRoot) && fs.statSync(repositoryRoot).isDirectory();
const repositoryRole = workflowContext === "lesson" ? "lesson_product_repository" : workflowContext === "lesson-maintenance" ? "lesson_repository" : "external_product_repository";
const staleAfter = observedAt && !Number.isNaN(Date.parse(observedAt)) ? new Date(Date.parse(observedAt) + 15000).toISOString().replace(".000Z", "Z") : "";

if (!isDirectoryRoot) {
  process.stdout.write(JSON.stringify({
    scope_id: scopeId,
    menu_id: menuId,
    workflow_context: workflowContext,
    repository_role: repositoryRole,
    repository_name: repositoryName,
    path_state: pathState,
    git_state: gitState,
    observed_at: observedAt,
    stale_after: staleAfter,
    inventory_hash: "",
    previous_inventory_hash: "",
    change_summary: "not_observed",
    inventory: {
      status: "missing",
      drift_status: "missing",
      default_expand_depth: Number(index.default_expand_depth) || 0,
      summary: { directories: 0, files: 0, indexed_files: Array.isArray(index.files) ? index.files.length : 0, added_since_index: 0, missing_from_worktree: 0, truncated: false },
      files: [],
      added_since_index: [],
      missing_from_worktree: [],
      required_paths: [],
      warnings: ["target repository root is not configured or not readable"],
    },
    source_files: [profilePath, indexPath],
  }));
  process.exit(0);
}

let profileMenuId = "";
try {
  const profile = JSON.parse(fs.readFileSync(path.join(repositoryRoot, profilePath), "utf8"));
  profileMenuId = text(profile.menu_id, "");
} catch (_error) {
  profileMenuId = "";
}

const excludePatterns = [];
for (const item of Array.isArray(index.excludes) ? index.excludes : []) {
  const pattern = text(item && item.pattern, "");
  if (pattern) excludePatterns.push(pattern);
}
for (const fallback of [".git/", ".framecue/", "node_modules/", "dist/", "coverage/"]) {
  if (!excludePatterns.includes(fallback)) excludePatterns.push(fallback);
}

const observed = walk(repositoryRoot, excludePatterns);
const observedPathSet = new Set(observed.files.map((file) => file.path));
const indexRows = Array.isArray(index.files) ? index.files.filter((item) => item && safeRel(item.path)) : [];
const indexByPath = new Map(indexRows.map((item) => [normalizeRel(item.path), item]));
const addedSinceIndex = observed.files.map((file) => file.path).filter((rel) => !indexByPath.has(rel));
const missingFromWorktree = indexRows
  .map((item) => ({ item, rel: normalizeRel(item.path), type: item.type === "directory" ? "directory" : "file" }))
  .filter(({ item, rel, type }) => item.tracked !== false && !existsEntry(repositoryRoot, rel, type))
  .map(({ rel }) => rel);

const requiredPathSpecs = [
  ["AGENTS.MD", "file", "repository_rules"],
  [profilePath, "file", "product_profile"],
  [indexPath, "file", "repository_index"],
  ["ops/PRODUCT_OPERATION_MODE.tsv", "file", "ops_manifest"],
  ["tools/product-mode", "file", "repository_tool"],
  ["docs/product/REQUIREMENTS.md", "file", "product_document"],
  ["docs/product/SPECIFICATION.md", "file", "product_document"],
  ["docs/product/IMPLEMENTATION_PLAN.md", "file", "product_document"],
  ["docs/workflow/TASK_TRACKER.md", "file", "workflow_document"],
  ["docs/workflow/HANDOFF.md", "file", "workflow_document"],
  ["docs/design-system", "directory", "design_system_document"],
  ["skills", "directory", "agent_support"],
  ["tools", "directory", "repository_tool"],
  ["ops", "directory", "ops_directory"],
];
const requiredPaths = requiredPathSpecs.map(([rel, type, roleId]) => ({
  path: rel,
  type,
  role_ids: [roleId],
  status: existsEntry(repositoryRoot, rel, type) ? "ready" : "missing",
}));
const missingRequired = requiredPaths.filter((item) => item.status === "missing").map((item) => item.path);

const roles = { ...(index.roles && typeof index.roles === "object" && !Array.isArray(index.roles) ? index.roles : {}) };
for (const roleId of ["design_system_document", "repository_tool"]) {
  if (!roles[roleId]) {
    roles[roleId] = { label: roleId.replace(/_/g, " "), description: roleDescription(roleId) };
  }
}

const fileRows = [];
for (const file of observed.files) {
  const indexed = indexByPath.get(file.path);
  const roleIds = Array.isArray(indexed && indexed.role_ids) && indexed.role_ids.length ? indexed.role_ids.map((roleId) => text(roleId, "")).filter(Boolean) : roleForPath(file.path, false);
  fileRows.push({
    id: `observed:${file.path}`,
    path: file.path,
    type: "file",
    status: "ready",
    observed: true,
    indexed: Boolean(indexed),
    index_state: indexed ? "indexed" : "not_indexed",
    size: file.size,
    mtime_ms: file.mtime_ms,
    source_id: roleIds[0] || "repository_file",
    role_ids: roleIds,
    description: indexed && typeof indexed.description === "string" ? indexed.description : "",
  });
}
for (const rel of missingFromWorktree) {
  const indexed = indexByPath.get(rel) || {};
  const type = indexed.type === "directory" ? "directory" : "file";
  const roleIds = Array.isArray(indexed.role_ids) && indexed.role_ids.length ? indexed.role_ids.map((roleId) => text(roleId, "")).filter(Boolean) : roleForPath(rel, type === "directory");
  fileRows.push({
    id: `missing-indexed:${rel}`,
    path: rel,
    type,
    status: "missing",
    observed: false,
    indexed: true,
    index_state: "missing_from_worktree",
    source_id: roleIds[0] || "repository_file",
    role_ids: roleIds,
    description: indexed.description || "",
  });
}
for (const required of requiredPaths) {
  if (required.status !== "missing" || fileRows.some((row) => row.path === required.path)) continue;
  fileRows.push({
    id: `missing-required:${required.path}`,
    path: required.path,
    type: required.type,
    status: "missing",
    observed: false,
    indexed: indexByPath.has(required.path),
    index_state: "missing_required",
    source_id: required.role_ids[0],
    role_ids: required.role_ids,
    description: "",
  });
}

const inventorySeed = observed.files.map((file) => `${file.path}\0${file.size}\0${file.mtime_ms}`).join("\n");
const inventoryHash = hash(inventorySeed);
let indexHash = "";
try {
  indexHash = hash(fs.readFileSync(path.join(repositoryRoot, indexPath)));
} catch (_error) {
  indexHash = "";
}

let previousInventoryHash = "";
const previousSnapshotFile = text(process.env.DASHBOARD_PREVIOUS_SNAPSHOT_FILE, "");
if (previousSnapshotFile && fs.existsSync(previousSnapshotFile)) {
  try {
    const previous = JSON.parse(fs.readFileSync(previousSnapshotFile, "utf8"));
    if (previous && previous.repository_scope && previous.repository_scope.scope_id === scopeId) {
      previousInventoryHash = text(previous.repository_scope.inventory_hash, "");
    }
  } catch (_error) {
    previousInventoryHash = "";
  }
}
const changeSummary = previousInventoryHash ? (previousInventoryHash === inventoryHash ? "unchanged" : "changed") : "first_observation";
const warnings = [];
if (addedSinceIndex.length) warnings.push("repository index does not include every observed file");
if (missingFromWorktree.length) warnings.push("repository index lists files that are missing from the worktree");
if (missingRequired.length) warnings.push("standard product repository paths are missing");
if (existsEntry(repositoryRoot, "AGENT.md", "file") && !existsEntry(repositoryRoot, "AGENTS.MD", "file")) warnings.push("legacy AGENT.md exists but AGENTS.MD is missing");
if (observed.truncated) warnings.push("repository inventory was truncated before all files were listed");

const driftStatus = missingRequired.length || addedSinceIndex.length || missingFromWorktree.length || observed.truncated ? "stale" : "ready";
const summary = {
  directories: observed.directories.length,
  files: observed.files.length,
  indexed_files: indexRows.length,
  added_since_index: addedSinceIndex.length,
  missing_from_worktree: missingFromWorktree.length,
  missing_required: missingRequired.length,
  truncated: observed.truncated,
};

process.stdout.write(JSON.stringify({
  scope_id: scopeId,
  menu_id: menuId,
  workflow_context: workflowContext,
  repository_role: repositoryRole,
  repository_name: repositoryName,
  root_name: text(index.root_name, repositoryName),
  path_state: pathState,
  git_state: gitState,
  product_type: "",
  profile_path: profilePath,
  profile_menu_id: profileMenuId,
  index_path: indexPath,
  observed_at: observedAt,
  stale_after: staleAfter,
  inventory_hash: inventoryHash,
  repository_index_hash: indexHash,
  previous_inventory_hash: previousInventoryHash,
  change_summary: changeSummary,
  inventory: {
    status: driftStatus,
    drift_status: driftStatus,
    default_expand_depth: Number(index.default_expand_depth) || 0,
    summary,
    roles,
    files: fileRows,
    added_since_index: addedSinceIndex.slice(0, 200),
    missing_from_worktree: missingFromWorktree.slice(0, 200),
    required_paths: requiredPaths,
    warnings,
  },
  source_files: [profilePath, indexPath, ...requiredPathSpecs.map(([rel]) => rel)].filter((value, index, array) => array.indexOf(value) === index),
}));
NODE
}

dashboard_live_repository_state_json() {
  local repo="$1"
  local path_state="$2"
  local git_state="$3"
  local branch="" head="" upstream="" dirty_count="0" untracked_count="0" ahead="0" behind="0"
  if [[ "$path_state" == "configured" && "$git_state" == "configured" && -n "$repo" && -d "$repo/.git" ]]; then
    branch="$(git -C "$repo" branch --show-current 2>/dev/null || true)"
    head="$(git -C "$repo" rev-parse --short=12 HEAD 2>/dev/null || true)"
    upstream="$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
    dirty_count="$(git -C "$repo" status --porcelain=v1 2>/dev/null | wc -l | tr -d '[:space:]')"
    untracked_count="$(git -C "$repo" status --porcelain=v1 2>/dev/null | awk '$1 == "??" { count += 1 } END { print count + 0 }')"
    if [[ -n "$upstream" ]]; then
      read -r ahead behind < <(git -C "$repo" rev-list --left-right --count HEAD...'@{u}' 2>/dev/null || printf '0 0')
    fi
  fi
  printf '{"branch":'
  dashboard_json_string "$branch"
  printf ',"head":'
  dashboard_json_string "$head"
  printf ',"upstream":'
  dashboard_json_string "$upstream"
  printf ',"dirty_count":%s,"untracked_count":%s,"ahead":%s,"behind":%s}' \
    "${dirty_count:-0}" \
    "${untracked_count:-0}" \
    "${ahead:-0}" \
    "${behind:-0}"
}

dashboard_repository_changes_json() {
  local menu_id="${1:-$SELECTED_MENU_ID}"
  local generated_at="${2:-$(dashboard_data_generated_at)}"
  local repo path_state git_state status branch head upstream main_target detached stale_reason
  local staged_count="0" unstaged_count="0" untracked_count="0" ahead="0" behind="0" worktree_count="0"
  local -a changed_samples=()
  repo="$(dashboard_target_repository_root "$menu_id" 2>/dev/null || true)"
  path_state="$(dashboard_target_repository_path_state "$menu_id")"
  git_state="$(dashboard_target_repository_git_state "$menu_id")"
  status="$path_state"
  branch=""
  head=""
  upstream=""
  main_target=""
  detached="false"
  stale_reason="not_collected"
  if [[ "$path_state" == "configured" && "$git_state" == "configured" && -n "$repo" && -d "$repo/.git" ]]; then
    branch="$(git -C "$repo" branch --show-current 2>/dev/null || true)"
    [[ -n "$branch" ]] || detached="true"
    head="$(git -C "$repo" rev-parse --short=12 HEAD 2>/dev/null || true)"
    upstream="$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
    if git -C "$repo" rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
      main_target="origin/main"
    elif git -C "$repo" rev-parse --verify --quiet main >/dev/null 2>&1; then
      main_target="main"
    fi
    staged_count="$(git -C "$repo" status --porcelain=v1 2>/dev/null | awk '$1 != "??" && substr($0, 1, 1) != " " { count += 1 } END { print count + 0 }')"
    unstaged_count="$(git -C "$repo" status --porcelain=v1 2>/dev/null | awk '$1 != "??" && substr($0, 2, 1) != " " { count += 1 } END { print count + 0 }')"
    untracked_count="$(git -C "$repo" status --porcelain=v1 2>/dev/null | awk '$1 == "??" { count += 1 } END { print count + 0 }')"
    mapfile -t changed_samples < <(git -C "$repo" status --porcelain=v1 2>/dev/null | sed -E 's/^.. //' | head -n 8)
    if [[ -n "$upstream" ]]; then
      read -r ahead behind < <(git -C "$repo" rev-list --left-right --count HEAD...'@{u}' 2>/dev/null || printf '0 0')
    fi
    worktree_count="$(git -C "$repo" worktree list --porcelain 2>/dev/null | awk '$1 == "worktree" { count += 1 } END { print count + 0 }')"
    if (( staged_count > 0 || unstaged_count > 0 || untracked_count > 0 )); then
      status="manual_required"
      stale_reason="local_changes_present"
    elif (( behind > 0 )); then
      status="stale"
      stale_reason="behind_upstream"
    elif (( ahead > 0 )); then
      status="manual_required"
      stale_reason="ahead_of_upstream"
    else
      status="ready"
      stale_reason="current"
    fi
  elif [[ "$path_state" == "not_applicable" || "$git_state" == "not_applicable" ]]; then
    status="not_applicable"
  elif [[ "$path_state" == "missing" || "$git_state" == "missing" ]]; then
    status="missing"
  else
    status="unknown"
  fi

  dashboard_data_validate_state "$status"

  printf '{"status":'
  dashboard_json_string "$status"
  printf ',"observed_at":'
  dashboard_json_string "$generated_at"
  printf ',"path_state":'
  dashboard_json_string "$path_state"
  printf ',"git_state":'
  dashboard_json_string "$git_state"
  printf ',"branch":'
  dashboard_json_string "$branch"
  printf ',"head":'
  dashboard_json_string "$head"
  printf ',"upstream":'
  dashboard_json_string "$upstream"
  printf ',"main_target":'
  dashboard_json_string "$main_target"
  printf ',"detached":'
  dashboard_json_bool "$detached"
  printf ',"staged_count":%d,"unstaged_count":%d,"untracked_count":%d,"ahead":%d,"behind":%d,"worktree_count":%d' \
    "${staged_count:-0}" "${unstaged_count:-0}" "${untracked_count:-0}" "${ahead:-0}" "${behind:-0}" "${worktree_count:-0}"
  printf ',"changed_role_counts":{"staged":%d,"unstaged":%d,"untracked":%d}' \
    "${staged_count:-0}" "${unstaged_count:-0}" "${untracked_count:-0}"
  printf ',"safe_changed_file_samples":'
  dashboard_json_string_array "${changed_samples[@]}"
  printf ',"stale_reason":'
  dashboard_json_string "$stale_reason"
  printf '}'
}

dashboard_live_github_repository_name() {
  local repo="$1"
  local remote_url github_repo=""
  remote_url="$(git -C "$repo" remote get-url origin 2>/dev/null || true)"
  case "$remote_url" in
    https://github.com/*/*.git)
      github_repo="${remote_url#https://github.com/}"
      github_repo="${github_repo%.git}"
      ;;
    https://github.com/*/*)
      github_repo="${remote_url#https://github.com/}"
      ;;
    git@github.com:*.git)
      github_repo="${remote_url#git@github.com:}"
      github_repo="${github_repo%.git}"
      ;;
    git@github.com:*)
      github_repo="${remote_url#git@github.com:}"
      ;;
  esac
  printf '%s' "$github_repo"
}

