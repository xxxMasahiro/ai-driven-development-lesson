dashboard_first_blocker_field() {
  local field="$1"
  if [[ "${#blocking_items[@]}" -eq 0 ]]; then
    return 1
  fi
  dashboard_json_get_field "${blocking_items[0]}" "$field" 2>/dev/null || return 1
}

dashboard_selected_context_first_blocker_field() {
  local field="$1"
  DASHBOARD_SELECTED_CONTEXT_JSON="${selected_context_json:-}" DASHBOARD_SELECTED_CONTEXT_BLOCKER_FIELD="$field" node <<'NODE'
let data = {};
try {
  data = JSON.parse(process.env.DASHBOARD_SELECTED_CONTEXT_JSON || "{}");
} catch (_error) {
  data = {};
}
const field = String(process.env.DASHBOARD_SELECTED_CONTEXT_BLOCKER_FIELD || "");
const blockers = Array.isArray(data.blockers) ? data.blockers : [];
const blocker = blockers.find((item) => item && typeof item === "object" && !Array.isArray(item));
if (!blocker || !(field in blocker)) process.exit(2);
process.stdout.write(String(blocker[field] ?? "").replace(/[\u0000-\u001f]+/g, " ").trim());
NODE
}

dashboard_operational_primary_source() {
  local source
  source="$(dashboard_first_blocker_field source 2>/dev/null || true)"
  if [[ -n "$source" ]]; then printf '%s' "$source"; return; fi
  source="$(dashboard_selected_context_first_blocker_field source 2>/dev/null || true)"
  if [[ -n "$source" ]]; then printf '%s' "$source"; return; fi
  if dashboard_attention_state "$product_repository_status"; then printf 'development.product_repository'; return; fi
  if dashboard_attention_state "$product_authority_status"; then printf 'development.product_authority'; return; fi
  if dashboard_attention_state "$git_sync_status"; then printf 'development.git_sync_status'; return; fi
  if dashboard_attention_state "$ci_status"; then printf 'development.ci_status'; return; fi
  if dashboard_attention_state "$security_gate_status"; then printf 'security.gate_status'; return; fi
  if dashboard_attention_state "$documents_catalog_status"; then printf 'documents.status'; return; fi
  printf 'summary.primary_action'
}

dashboard_operational_reason() {
  local reason
  reason="$(dashboard_first_blocker_field reason 2>/dev/null || true)"
  if [[ -n "$reason" ]]; then printf '%s' "$reason"; return; fi
  reason="$(dashboard_selected_context_first_blocker_field reason 2>/dev/null || true)"
  if [[ -n "$reason" ]]; then printf '%s' "$reason"; return; fi
  case "$1" in
    ready|passed) printf 'No blocking item is currently reported by the dashboard producer.' ;;
    approval_required) printf 'One or more workflow actions remain behind an approval boundary.' ;;
    missing) printf 'A required repository, document, or evidence source is missing.' ;;
    stale) printf 'At least one evidence source is older than the current repository state.' ;;
    manual_required|not_run) printf 'Manual evidence review is required before this state can be considered complete.' ;;
    blocked|failed) printf 'A blocking status is present in the current producer-owned evidence.' ;;
    *) printf 'The dashboard producer cannot prove readiness for the current context.' ;;
  esac
}

dashboard_operational_next_action() {
  local command
  command="$(dashboard_first_blocker_field required_command 2>/dev/null || true)"
  if [[ -n "$command" ]]; then printf '%s' "$command"; return; fi
  command="$(dashboard_selected_context_first_blocker_field required_command 2>/dev/null || true)"
  if [[ -n "$command" ]]; then printf '%s' "$command"; return; fi
  case "$1" in
    ready|passed) printf 'Open the relevant detail page only if you need supporting evidence.' ;;
    approval_required) printf 'Review approval boundaries before running any Git, CI, merge, or cleanup operation.' ;;
    missing) printf 'Open Repository Info or Documents to identify the missing source before proceeding.' ;;
    stale) printf 'Refresh or recollect the stale evidence before using it for a current decision.' ;;
    manual_required|not_run) printf 'Open Workflow and Maintenance details, then run the displayed command manually if needed.' ;;
    blocked|failed) printf 'Repair the top blocker first, then regenerate Dashboard data.' ;;
    *) printf 'Review Workflow, Safety, and Maintenance details before continuing.' ;;
  esac
}

dashboard_repository_development_json() {
  local changed_paths non_plan_changed_paths phase reason row order purpose required_inputs allowed_writes recommended_checks required_checks git_ci_expectations approval_requirements cleanup_behavior stop_conditions
  local records_file current_head current_policy_fingerprint current_input_fingerprint runner_records_status
  changed_paths="$(git -C "$ROOT" status --short --untracked-files=normal 2>/dev/null | awk '{ print $2 }')"
  non_plan_changed_paths="$(printf '%s\n' "$changed_paths" | grep -Ev '^(docs/as-built/|docs/workflow/(AS_BUILT_SYNC_CONTRACT|TASK_TRACKER|HANDOFF)\.)' 2>/dev/null || true)"
  if [[ -z "$changed_paths" ]]; then
    phase="context_triage"
    reason="working tree is clean"
  elif grep -Eq '^(\.github/|\.githooks/|docs/workflow/(GIT_HOOK|FINAL_GATE|TEST_PLAN)|tools/(git-hooks|ci-final-gate|ci-evidence|test-plan)|tools/lib/(git_hooks|ci_|test_plan))' <<<"$changed_paths"; then
    phase="mid_tests"
    reason="changed paths affect hooks, CI, final-gate, or test-plan wiring"
  elif [[ -z "$non_plan_changed_paths" ]] && grep -Eq '^(docs/as-built/|docs/workflow/(AS_BUILT_SYNC_CONTRACT|TASK_TRACKER|HANDOFF)\.)' <<<"$changed_paths"; then
    phase="implementation_plan"
    reason="changed paths are limited to synchronized planning documents"
  else
    phase="fast_loop"
    reason="working tree has scoped runtime or test changes"
  fi
  row="$(awk -F '\t' -v phase="$phase" '$1 == phase { print; found = 1; exit } END { exit found ? 0 : 1 }' "$ROOT/docs/workflow/REPOSITORY_DEVELOPMENT_WORKFLOW.tsv" 2>/dev/null || true)"
  if [[ -n "$row" ]]; then
    IFS=$'\t' read -r _phase order purpose required_inputs allowed_writes recommended_checks required_checks git_ci_expectations approval_requirements cleanup_behavior stop_conditions <<<"$row"
  else
    order="0"
    purpose="Repository development workflow phase could not be read."
    required_inputs="unknown"
    allowed_writes="none"
    recommended_checks="none"
    required_checks="none"
    git_ci_expectations="unknown"
    approval_requirements="unknown"
    cleanup_behavior="plan_only"
    stop_conditions="unknown"
  fi
  records_file="$ROOT/.repository-development-runs/records.tsv"
  current_head="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || true)"
  current_policy_fingerprint="$(repository_development_runner_policy_fingerprint 2>/dev/null || true)"
  current_input_fingerprint="$(repository_development_runner_input_fingerprint 2>/dev/null || true)"
  if [[ ! -f "$records_file" ]]; then
    runner_records_status="missing"
  elif [[ -n "$current_head" && -n "$current_policy_fingerprint" && -n "$current_input_fingerprint" ]] \
    && awk -F '\t' \
      -v head="$current_head" \
      -v policy_fingerprint="$current_policy_fingerprint" \
      -v input_fingerprint="$current_input_fingerprint" \
      'NR > 1 && $8 == head && $9 == policy_fingerprint && $10 == input_fingerprint && $7 == "pass" { found = 1; exit } END { exit found ? 0 : 1 }' "$records_file"; then
    runner_records_status="current"
  else
    runner_records_status="stale"
  fi
  printf '{"current_phase":'
  dashboard_json_string "$phase"
  printf ',"phase_order":%d' "${order:-0}"
  printf ',"inference_reason":'
  dashboard_json_string "$reason"
  printf ',"purpose":'
  dashboard_json_string "$purpose"
  printf ',"required_inputs":'
  dashboard_json_string "$required_inputs"
  printf ',"allowed_writes":'
  dashboard_json_string "$allowed_writes"
  printf ',"recommended_checks":'
  dashboard_json_string "$recommended_checks"
  printf ',"required_checks":'
  dashboard_json_string "$required_checks"
  printf ',"git_ci_expectations":'
  dashboard_json_string "$git_ci_expectations"
  printf ',"required_approvals":'
  dashboard_json_string "$approval_requirements"
  printf ',"cleanup_behavior":'
  dashboard_json_string "$cleanup_behavior"
  printf ',"stop_conditions":'
  dashboard_json_string "$stop_conditions"
  printf ',"runner_records_status":'
  dashboard_json_string "$runner_records_status"
  printf ',"source_files":'
  dashboard_json_string_array "docs/workflow/REPOSITORY_DEVELOPMENT_WORKFLOW.tsv" "docs/workflow/REPOSITORY_DEVELOPMENT_RUNNER_POLICY.tsv" "learning/REPOSITORY_DEVELOPMENT_APPROVALS.tsv"
  printf '}'
}

