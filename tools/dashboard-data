dashboard_document_decision_brief_current_hash() {
  local id="$1"
  local menu_id="${2:-$SELECTED_MENU_ID}"
  local cache_key source_paths rel display_rel path digest seed first
  local -a paths=()
  cache_key="$id|$menu_id"
  if [[ -n "${DASHBOARD_DOCUMENT_DECISION_BRIEF_CURRENT_HASH_CACHE[$cache_key]+set}" ]]; then
    digest="${DASHBOARD_DOCUMENT_DECISION_BRIEF_CURRENT_HASH_CACHE[$cache_key]}"
    [[ "$digest" != "__missing__" ]] || return 1
    printf '%s' "$digest"
    return 0
  fi
  source_paths="$(dashboard_document_decision_brief_source_paths "$id" "$menu_id")"
  if [[ -z "$source_paths" ]]; then
    DASHBOARD_DOCUMENT_DECISION_BRIEF_CURRENT_HASH_CACHE[$cache_key]="__missing__"
    return 1
  fi
  IFS=';' read -r -a paths <<<"$source_paths"
  first=1
  seed=""
  for rel in "${paths[@]}"; do
    [[ -n "$rel" ]] || continue
    display_rel="$rel"
    case "$rel" in
      /*|\\*|*..*) return 1 ;;
    esac
    if [[ "$rel" == product:* ]]; then
      display_rel="${rel#product:}"
      case "$display_rel" in
        /*|\\*|*..*) return 1 ;;
      esac
      path="$(dashboard_selected_product_root "$menu_id" 2>/dev/null || true)"
      [[ -n "$path" ]] || path="__dashboard_product_repository_not_selected__"
      path="$path/$display_rel"
    else
      path="$ROOT/$rel"
    fi
    if [[ -f "$path" ]]; then
      if command -v sha256sum >/dev/null 2>&1; then
        digest="$(sha256sum "$path" | awk '{ print $1; exit }')"
      else
        digest="$(shasum -a 256 "$path" | awk '{ print $1; exit }')"
      fi
    else
      digest="missing"
    fi
    if [[ "${#paths[@]}" -eq 1 ]]; then
      DASHBOARD_DOCUMENT_DECISION_BRIEF_CURRENT_HASH_CACHE[$cache_key]="$digest"
      printf '%s' "$digest"
      return 0
    fi
    seed+="${digest} ${display_rel}"$'\n'
    first=0
  done
  if [[ -z "$seed" ]]; then
    DASHBOARD_DOCUMENT_DECISION_BRIEF_CURRENT_HASH_CACHE[$cache_key]="__missing__"
    return 1
  fi
  digest="$(dashboard_data_content_hash "$seed")"
  DASHBOARD_DOCUMENT_DECISION_BRIEF_CURRENT_HASH_CACHE[$cache_key]="$digest"
  printf '%s' "$digest"
}

