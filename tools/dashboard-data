dashboard_authority_axis_status() {
  local authority_json="$1"
  local axis_prefix="$2"
  local fallback_status="$3"
  DASHBOARD_AUTHORITY_JSON="$authority_json" DASHBOARD_AXIS_PREFIX="$axis_prefix" DASHBOARD_AXIS_FALLBACK="$fallback_status" node <<'NODE'
const allowed = new Set([
  "missing",
  "ready",
  "passed",
  "failed",
  "blocked",
  "unknown",
  "approval_required",
  "optional",
  "cached",
  "not_run",
  "stale",
  "manual_required",
]);
const priority = {
  failed: 0,
  blocked: 1,
  stale: 2,
  not_run: 3,
  unknown: 4,
  manual_required: 5,
  approval_required: 6,
  missing: 7,
  optional: 8,
  cached: 9,
  ready: 10,
  passed: 11,
};
function normalize(value, fallback = "unknown") {
  const text = String(value ?? fallback).trim() || fallback;
  return allowed.has(text) ? text : "unknown";
}
function matches(source, prefix) {
  return source === prefix || source.startsWith(`${prefix}.`);
}
let data = {};
try {
  data = JSON.parse(process.env.DASHBOARD_AUTHORITY_JSON || "{}");
} catch (_error) {
  data = {};
}
const prefix = String(process.env.DASHBOARD_AXIS_PREFIX || "");
const fallback = normalize(process.env.DASHBOARD_AXIS_FALLBACK, "unknown");
const statuses = [];
for (const blocker of Array.isArray(data.product_operation_blockers) ? data.product_operation_blockers : []) {
  const source = String(blocker?.source ?? "");
  if (matches(source, prefix)) {
    statuses.push(normalize(blocker.status));
  }
}
const items = Array.isArray(data.evidence_summary?.items) ? data.evidence_summary.items : [];
for (const item of items) {
  const source = String(item?.source_id ?? "");
  if (!matches(source, prefix)) continue;
  let status = normalize(item.status);
  const required = item.required_in_context === true;
  const freshness = String(item.freshness_state ?? "unknown");
  const authority = String(item.authority ?? "unknown");
  if (status === "passed" && freshness === "stale") {
    status = "stale";
  }
  if (required && status === "passed" && (freshness !== "current" || authority !== "authoritative")) {
    status = "not_run";
  }
  statuses.push(status);
}
if (!statuses.length) {
  process.stdout.write(fallback);
  process.exit(0);
}
statuses.sort((left, right) => (priority[left] ?? 99) - (priority[right] ?? 99));
process.stdout.write(statuses[0]);
NODE
}

dashboard_authority_evidence_field() {
  local authority_json="$1"
  local source_id="$2"
  local field="$3"
  local fallback="${4:-}"
  DASHBOARD_AUTHORITY_JSON="$authority_json" \
  DASHBOARD_AUTHORITY_SOURCE_ID="$source_id" \
  DASHBOARD_AUTHORITY_FIELD="$field" \
  DASHBOARD_AUTHORITY_FALLBACK="$fallback" node <<'NODE'
function safeText(value, fallback = "") {
  const text = String(value ?? fallback)
    .replace(/[\u0000-\u001f]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  return text || fallback;
}
let data = {};
try {
  data = JSON.parse(process.env.DASHBOARD_AUTHORITY_JSON || "{}");
} catch (_error) {
  data = {};
}
const sourceId = safeText(process.env.DASHBOARD_AUTHORITY_SOURCE_ID);
const field = safeText(process.env.DASHBOARD_AUTHORITY_FIELD);
const fallback = safeText(process.env.DASHBOARD_AUTHORITY_FALLBACK);
const items = Array.isArray(data.evidence_summary?.items) ? data.evidence_summary.items : [];
const exact = items.find((item) => safeText(item?.source_id) === sourceId);
if (exact && Object.prototype.hasOwnProperty.call(exact, field)) {
  process.stdout.write(safeText(exact[field], fallback));
  process.exit(0);
}
const blockers = Array.isArray(data.product_operation_blockers) ? data.product_operation_blockers : [];
const blocker = blockers.find((item) => safeText(item?.source) === sourceId);
if (blocker && Object.prototype.hasOwnProperty.call(blocker, field)) {
  process.stdout.write(safeText(blocker[field], fallback));
  process.exit(0);
}
process.stdout.write(fallback);
NODE
}

dashboard_authority_axis_primary_source() {
  local authority_json="$1"
  local axis_prefix="$2"
  local fallback="$3"
  DASHBOARD_AUTHORITY_JSON="$authority_json" DASHBOARD_AXIS_PREFIX="$axis_prefix" DASHBOARD_AXIS_FALLBACK="$fallback" node <<'NODE'
function safeText(value, fallback = "") {
  const text = String(value ?? fallback)
    .replace(/[\u0000-\u001f]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  return text || fallback;
}
const priority = {
  failed: 0,
  blocked: 1,
  stale: 2,
  not_run: 3,
  missing: 4,
  unknown: 5,
  manual_required: 6,
  approval_required: 7,
  optional: 8,
  cached: 9,
  ready: 10,
  passed: 11,
};
function rank(value) {
  return priority[safeText(value, "unknown")] ?? 99;
}
function matches(source, prefix) {
  return source === prefix || source.startsWith(`${prefix}.`);
}
let data = {};
try {
  data = JSON.parse(process.env.DASHBOARD_AUTHORITY_JSON || "{}");
} catch (_error) {
  data = {};
}
const prefix = safeText(process.env.DASHBOARD_AXIS_PREFIX);
const fallback = safeText(process.env.DASHBOARD_AXIS_FALLBACK);
const candidates = [];
for (const blocker of Array.isArray(data.product_operation_blockers) ? data.product_operation_blockers : []) {
  const source = safeText(blocker?.source);
  if (matches(source, prefix)) candidates.push({ source, rank: rank(blocker?.status) - 0.5 });
}
for (const item of Array.isArray(data.evidence_summary?.items) ? data.evidence_summary.items : []) {
  const source = safeText(item?.source_id);
  if (matches(source, prefix)) candidates.push({ source, rank: rank(item?.status) });
}
candidates.sort((left, right) => left.rank - right.rank || left.source.localeCompare(right.source));
process.stdout.write(candidates[0]?.source || fallback);
NODE
}

