lesson_status() {
  local config_file="$1"
  local state_file current_step
  local learning_mode_status workflow_language_status product_language_status
  state_file="$(dashboard_data_lesson_state_file_from_config "$config_file")"
  learning_mode_status="$(dashboard_data_lesson_setting_state "$config_file" learning_mode)"
  workflow_language_status="$(dashboard_data_lesson_setting_state "$config_file" workflow_language)"
  product_language_status="$(dashboard_data_lesson_setting_state "$config_file" product_language)"
  if [[ ! -f "$state_file" ]]; then
    printf 'missing'
  elif dashboard_data_lesson_all_completed "$state_file"; then
    printf 'passed'
  elif current_step="$(dashboard_data_current_lesson_step "$state_file" 2>/dev/null)"; then
    if [[ "$learning_mode_status" == "ready" && "$workflow_language_status" == "ready" && "$product_language_status" == "ready" ]]; then
      printf 'ready'
    else
      printf 'missing'
    fi
  else
    printf 'unknown'
  fi
}

lesson_object() {
  local label="$1"
  local config_file="$2"
  local state_file
  local status="unknown"
  local current_step=""
  local learning_mode_status
  local workflow_language_status
  local product_language_status
	  local source_state_file
	  local points=()
	  local warnings=()
	  local next_learning_action

  state_file="$(dashboard_data_lesson_state_file_from_config "$config_file")"
  source_state_file="$(dashboard_data_relative_path "$state_file")"
  learning_mode_status="$(dashboard_data_lesson_setting_state "$config_file" learning_mode)"
  workflow_language_status="$(dashboard_data_lesson_setting_state "$config_file" workflow_language)"
  product_language_status="$(dashboard_data_lesson_setting_state "$config_file" product_language)"
  if [[ ! -f "$state_file" ]]; then
    status="missing"
  elif dashboard_data_lesson_all_completed "$state_file"; then
    status="passed"
    current_step="all steps completed"
  elif current_step="$(dashboard_data_current_lesson_step "$state_file" 2>/dev/null)"; then
    if [[ "$learning_mode_status" == "ready" && "$workflow_language_status" == "ready" && "$product_language_status" == "ready" ]]; then
      status="ready"
    else
      status="missing"
    fi
  else
    status="unknown"
  fi
	  points+=("$label lesson status is $status.")
	  points+=("Current lesson step is ${current_step:-unknown}.")
	  if [[ "$learning_mode_status" != "ready" ]]; then
	    warnings+=("Learning mode setting is $learning_mode_status.")
	  fi
	  if [[ "$workflow_language_status" != "ready" ]]; then
	    warnings+=("Workflow display language setting is $workflow_language_status.")
	  fi
	  if [[ "$product_language_status" != "ready" ]]; then
	    warnings+=("Product development language setting is $product_language_status.")
	  fi
	  if [[ "$status" == "missing" ]]; then
	    next_learning_action="Restore the lesson state source before continuing."
	  elif [[ "$learning_mode_status" != "ready" || "$workflow_language_status" != "ready" || "$product_language_status" != "ready" ]]; then
	    next_learning_action="Select missing lesson settings before passing the next lesson step."
	  elif [[ "$status" == "passed" ]]; then
	    next_learning_action="Review completed lesson progress or continue with the workflow surface."
	  else
	    next_learning_action="Review the current step and obtain the required approval before passing it."
	  fi

	  printf '{"label":'
  dashboard_json_string "$label"
  printf ',"status":'
  dashboard_json_string "$status"
  printf ',"current_step":'
  dashboard_json_string "${current_step:-unknown}"
  printf ',"learning_mode_status":'
  dashboard_json_string "$learning_mode_status"
  printf ',"workflow_language_status":'
  dashboard_json_string "$workflow_language_status"
  printf ',"product_language_status":'
  dashboard_json_string "$product_language_status"
	  printf ',"source_state_file":'
	  dashboard_json_string "$source_state_file"
	  printf ',"points":'
	  dashboard_json_string_array "${points[@]}"
	  printf ',"warnings":'
	  dashboard_json_string_array "${warnings[@]}"
	  printf ',"next_learning_action":'
	  dashboard_json_string "$next_learning_action"
	  printf '}'
	}

