}

dashboard_product_types_valid() {
  local value="$1"
  local item valid=1
  [[ -n "$value" ]] || return 1
  IFS='|' read -r -a items <<<"$value"
  for item in "${items[@]}"; do
    [[ -n "$item" ]] || valid=0
    dashboard_product_type_valid "$item" || valid=0
  done
  [[ "$valid" -eq 1 ]]
}

dashboard_product_types_from_manifest() {
  local product_root="${1-}"
  if [[ ! "${1+x}" ]]; then
    product_root="$PRODUCT_ROOT"
  fi
  [[ -n "$product_root" ]] || { printf 'unknown'; return; }
  local manifest="$product_root/ops/PRODUCT_MANIFEST.tsv"
  [[ -f "$manifest" ]] || { printf 'unknown'; return; }
  awk -F '\t' '
    function trim(value) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      return value
    }
    function add_type(type) {
      type = trim(type)
      if (type == "all") {
        has_all = 1
      } else if (type ~ /^(web|api|cli|library|integration|custom)$/ && !(type in seen)) {
        seen[type] = 1
        order[++count] = type
      }
    }
    /^[[:space:]]*$/ { next }
    $1 ~ /^#/ { next }
    NF != 9 { next }
    {
      type_count = split($4, types, /\|/)
      for (i = 1; i <= type_count; i++) {
        add_type(types[i])
      }
    }
    END {
      if (count > 0) {
        for (i = 1; i <= count; i++) {
          printf "%s%s", (i == 1 ? "" : "|"), order[i]
        }
        printf "\n"
        exit
      }
      print has_all ? "all" : "unknown"
    }
  ' "$manifest"
}

