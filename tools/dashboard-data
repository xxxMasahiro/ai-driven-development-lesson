dashboard_first_scoped_reference() {
  local value="$1"
  local fallback="${2:-not_collected}"
  local part
  local -a parts
  IFS=';' read -r -a parts <<<"$value"
  for part in "${parts[@]}"; do
    part="$(printf '%s' "$part" | sed -E 's/^[[:space:]]+//;s/[[:space:]]+$//')"
    [[ -n "$part" ]] || continue
    case "$part" in
      /*|../*|*/../*|*\\*) continue ;;
    esac
    printf '%s' "$part"
    return
  done
  printf '%s' "$fallback"
}

