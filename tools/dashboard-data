dashboard_git_operation_mode() {
  local action="$1"
  local repo="$ROOT"
  case "$SELECTED_WORKFLOW_CONTEXT" in
    free-development|product-improvement|external-integration)
      repo="$(dashboard_selected_product_root 2>/dev/null || true)"
      [[ -n "$repo" ]] || { printf 'unknown'; return; }
      ;;
  esac
  git_workflow_action_mode "$action" "$repo" 2>/dev/null || printf 'unknown'
}

dashboard_git_operation_status() {
  local action="$1"
  local mode="$2"
  local evidence_status="$3"

  if [[ "$mode" == "not_applicable" ]]; then
    printf 'not_applicable'
    return
  fi

  case "$git_settings_status" in
    blocked|failed|missing|unknown)
      printf '%s' "$git_settings_status"
      return
      ;;
  esac

  case "$mode" in
    manual)
      printf 'manual_required'
      ;;
    after_approval)
      printf 'approval_required'
      ;;
    developer_auto)
      printf 'ready'
      ;;
    auto)
      case "$action" in
        push|pr)
          printf 'approval_required'
          ;;
        *)
          printf '%s' "$evidence_status"
          ;;
      esac
      ;;
    *)
      printf 'unknown'
      ;;
  esac
}

dashboard_product_git_operation_applicable() {
  local action="$1"
  local mode="$2"
  case "$SELECTED_WORKFLOW_CONTEXT" in
    free-development|product-improvement|external-integration) ;;
    *) return 0 ;;
  esac
  case "$mode" in
    none|local) return 1 ;;
    remote_sync)
      case "$action" in
        push|sync) return 0 ;;
        *) return 1 ;;
      esac
      ;;
    ci) return 0 ;;
  esac
  return 1
}

dashboard_git_operation_effective_mode() {
  local action="$1"
  local mode
  mode="$(dashboard_git_operation_mode "$action")"
  if ! dashboard_product_git_operation_applicable "$action" "$PRODUCT_AUTHORITY_GIT_USAGE_MODE"; then
    printf 'not_applicable'
    return
  fi
  printf '%s' "$mode"
}

dashboard_git_operation_detail() {
  local action="$1"
  local default_detail="$2"
  if ! dashboard_product_git_operation_applicable "$action" "$PRODUCT_AUTHORITY_GIT_USAGE_MODE"; then
    printf 'Not applicable for product workflow Git usage mode: %s.' "$PRODUCT_AUTHORITY_GIT_USAGE_MODE"
    return
  fi
  printf '%s' "$default_detail"
}

