    run_json="$(timeout "$timeout_seconds" gh api -X GET "repos/$github_repo/actions/runs" -f per_page=1 -f branch="$branch" 2>/dev/null || true)"
  else
    run_json="$(timeout "$timeout_seconds" gh api -X GET "repos/$github_repo/actions/runs" -f per_page=1 2>/dev/null || true)"
  fi
  DASHBOARD_LIVE_CI_RUN_JSON="$run_json" DASHBOARD_LIVE_REPOSITORY_HEAD="$repo_head" node <<'NODE'
const data = (() => {
  try {
    return JSON.parse(process.env.DASHBOARD_LIVE_CI_RUN_JSON || "{}");
  } catch {
    return {};
  }
})();
const run = Array.isArray(data.workflow_runs) ? data.workflow_runs[0] : null;
if (!run) {
  process.stdout.write(JSON.stringify({
