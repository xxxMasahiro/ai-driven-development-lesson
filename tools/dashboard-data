  local value saw_approval=0 saw_missing=0 saw_stale=0 saw_manual=0 saw_unknown=0
  for value in "$@"; do
    dashboard_data_allowed_state "$value" || value="unknown"
    case "$value" in
      failed|blocked) printf 'blocked'; return ;;
      missing) saw_missing=1 ;;
      approval_required) saw_approval=1 ;;
      stale) saw_stale=1 ;;
      manual_required|not_run) saw_manual=1 ;;
      unknown) saw_unknown=1 ;;
    esac
  done
  if [[ "$saw_missing" -eq 1 ]]; then
    printf 'missing'
  elif [[ "$saw_stale" -eq 1 ]]; then
    printf 'stale'
  elif [[ "$saw_manual" -eq 1 ]]; then
    printf 'manual_required'
  elif [[ "$saw_approval" -eq 1 ]]; then
    printf 'approval_required'
  elif [[ "$saw_unknown" -eq 1 ]]; then
    printf 'unknown'
  else
    printf 'ready'
  fi
}

