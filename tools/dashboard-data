partial_failures=()
manual_followups=()
blocking_items=()
guidance_items=(
  "$(dashboard_json_guidance_item "lesson" "non_engineer" "info" "Review the current step and setup choices before starting or passing the next lesson step." "./tools/dashboard lesson")"
  "$(dashboard_json_guidance_item "workflow" "engineer" "attention" "Treat optional, cached, or unknown workflow status as non-authoritative until the listed check runs." "./tools/dashboard development")"
  "$(dashboard_json_guidance_item "workflow" "all" "action" "Review gates, blockers, approvals, evidence, and command previews before operational actions." "./tools/dashboard all")"
)

add_partial_failure() {
  dashboard_data_add_partial_failure partial_failures "$1" "$2" "$3" "$4"
}

add_manual_followup() {
  dashboard_data_add_manual_followup manual_followups "$1" "$2" "$3" "$4"
}

add_blocking_item() {
  dashboard_data_add_blocking_item blocking_items "$1" "$2" "$3" "$4"
}

require_source_file() {
  local relpath="$1"
  local source="$2"
  if [[ ! -f "$ROOT/$relpath" ]]; then
    add_blocking_item "$source" "missing" "Required dashboard data source file is missing." "Restore $relpath, then run ./tools/check_lesson_structure.sh"
  fi
}

for relpath in "${source_files[@]}"; do
  require_source_file "$relpath" "$relpath"
done

add_manual_followup "product_git_sync_live" "optional" "Live product Git sync is not executed by the read-only dashboard snapshot." "./tools/check_git_sync.sh --product --required"
add_manual_followup "product_ci_live" "optional" "Live CI or GitHub status is optional and is not authoritative in this snapshot." "./tools/check_ci_status.sh --product --required"
add_manual_followup "as_built_sync_live" "optional" "As-built sync validation is reported as a manual follow-up command instead of blocking JSON generation." "./tools/check_as_built_sync_contract.sh"
add_manual_followup "workflow_pair_live" "optional" "Workflow pair validation is reported as a manual follow-up command instead of blocking JSON generation." "./tools/check_workflow_pair_sync.sh"
add_manual_followup "git_workflow_gate_live" "optional" "Git workflow gates are not inferred from policy readiness in the read-only snapshot." "./tools/git-workflow check"
add_manual_followup "product_security_gate_live" "optional" "Product-security gate passage is not inferred from policy readiness in the read-only snapshot." "./tools/product-security gate --context product-improvement"

lesson_status() {
  local config_file="$1"
  local state_file current_step
  state_file="$(dashboard_data_lesson_state_file_from_config "$config_file")"
  if [[ ! -f "$state_file" ]]; then
    printf 'missing'
  elif current_step="$(dashboard_data_current_lesson_step "$state_file" 2>/dev/null)"; then
    printf 'ready'
  elif dashboard_data_lesson_all_completed "$state_file"; then
    printf 'passed'
  else
    printf 'unknown'
  fi
}

lesson_object() {
  local label="$1"
  local config_file="$2"
  local state_file
  local status="unknown"
  local current_step=""
  local learning_mode_status
  local workflow_language_status
  local product_language_status
	  local source_state_file
	  local points=()
	  local warnings=()
	  local next_learning_action

  state_file="$(dashboard_data_lesson_state_file_from_config "$config_file")"
  source_state_file="$(dashboard_data_relative_path "$state_file")"
  if [[ ! -f "$state_file" ]]; then
    status="missing"
  elif current_step="$(dashboard_data_current_lesson_step "$state_file" 2>/dev/null)"; then
    status="ready"
  elif dashboard_data_lesson_all_completed "$state_file"; then
    status="passed"
    current_step="all steps completed"
  else
    status="unknown"
  fi
	  learning_mode_status="$(dashboard_data_lesson_setting_state "$config_file" learning_mode)"
	  workflow_language_status="$(dashboard_data_lesson_setting_state "$config_file" workflow_language)"
	  product_language_status="$(dashboard_data_lesson_setting_state "$config_file" product_language)"
	  points+=("$label lesson status is $status.")
	  points+=("Current lesson step is ${current_step:-unknown}.")
	  if [[ "$learning_mode_status" != "ready" ]]; then
	    warnings+=("Learning mode setting is $learning_mode_status.")
	  fi
	  if [[ "$workflow_language_status" != "ready" ]]; then
	    warnings+=("Workflow display language setting is $workflow_language_status.")
	  fi
	  if [[ "$product_language_status" != "ready" ]]; then
	    warnings+=("Product development language setting is $product_language_status.")
	  fi
	  if [[ "$status" == "missing" ]]; then
	    next_learning_action="Restore the lesson state source before continuing."
	  elif [[ "$learning_mode_status" != "ready" || "$workflow_language_status" != "ready" || "$product_language_status" != "ready" ]]; then
	    next_learning_action="Select missing lesson settings before passing the next lesson step."
	  elif [[ "$status" == "passed" ]]; then
	    next_learning_action="Review completed lesson progress or continue with the workflow surface."
	  else
	    next_learning_action="Review the current step and obtain the required approval before passing it."
	  fi

	  printf '{"label":'
  dashboard_json_string "$label"
  printf ',"status":'
  dashboard_json_string "$status"
  printf ',"current_step":'
  dashboard_json_string "${current_step:-unknown}"
  printf ',"learning_mode_status":'
  dashboard_json_string "$learning_mode_status"
  printf ',"workflow_language_status":'
  dashboard_json_string "$workflow_language_status"
  printf ',"product_language_status":'
  dashboard_json_string "$product_language_status"
	  printf ',"source_state_file":'
	  dashboard_json_string "$source_state_file"
	  printf ',"points":'
	  dashboard_json_string_array "${points[@]}"
	  printf ',"warnings":'
	  dashboard_json_string_array "${warnings[@]}"
	  printf ',"next_learning_action":'
	  dashboard_json_string "$next_learning_action"
	  printf '}'
	}

advanced_lesson_object() {
	  local learning_mode_status workflow_language_status product_language_status status
	  local points=()
	  local warnings=()
	  local next_learning_action
  learning_mode_status="$(dashboard_data_latest_menu_setting_state learning_mode)"
  workflow_language_status="$(dashboard_data_latest_menu_setting_state workflow_language)"
  product_language_status="$(dashboard_data_latest_menu_setting_state product_language)"
	  if [[ "$learning_mode_status" == "ready" && "$workflow_language_status" == "ready" && "$product_language_status" == "ready" ]]; then
	    status="ready"
	  else
	    status="missing"
	  fi
	  points+=("Applied lesson prerequisite status is $status.")
	  points+=("Learner approval is required before starting applied lesson work.")
	  if [[ "$learning_mode_status" != "ready" ]]; then
	    warnings+=("Learning mode setting is $learning_mode_status.")
	  fi
	  if [[ "$workflow_language_status" != "ready" ]]; then
	    warnings+=("Workflow display language setting is $workflow_language_status.")
	  fi
	  if [[ "$product_language_status" != "ready" ]]; then
	    warnings+=("Product development language setting is $product_language_status.")
	  fi
	  if [[ "$status" == "ready" ]]; then
	    next_learning_action="Request learner approval before starting the applied lesson workflow."
	  else
	    next_learning_action="Select missing shared menu settings before starting the applied lesson workflow."
	  fi

	  printf '{"label":'
  dashboard_json_string "Applied lesson"
  printf ',"status":'
  dashboard_json_string "$status"
  printf ',"learning_mode_status":'
  dashboard_json_string "$learning_mode_status"
  printf ',"workflow_language_status":'
  dashboard_json_string "$workflow_language_status"
  printf ',"product_language_status":'
  dashboard_json_string "$product_language_status"
	  printf ',"learner_approval_status":'
	  dashboard_json_string "approval_required"
	  printf ',"points":'
	  dashboard_json_string_array "${points[@]}"
	  printf ',"warnings":'
	  dashboard_json_string_array "${warnings[@]}"
	  printf ',"next_learning_action":'
	  dashboard_json_string "$next_learning_action"
	  printf '}'
	}

advanced_lesson_status() {
  local learning_mode_status workflow_language_status product_language_status
  learning_mode_status="$(dashboard_data_latest_menu_setting_state learning_mode)"
  workflow_language_status="$(dashboard_data_latest_menu_setting_state workflow_language)"
  product_language_status="$(dashboard_data_latest_menu_setting_state product_language)"
  if [[ "$learning_mode_status" == "ready" && "$workflow_language_status" == "ready" && "$product_language_status" == "ready" ]]; then
    printf 'ready'
  else
    printf 'missing'
  fi
}

product_documents_status() {
  local file
  [[ -d "$PRODUCT_ROOT/.git" ]] || { printf 'unknown'; return; }
  for file in REQUIREMENTS.md SPECIFICATION.md IMPLEMENTATION_PLAN.md TASK_TRACKER.md HANDOFF.md; do
    [[ -f "$PRODUCT_ROOT/$file" ]] || { printf 'missing'; return; }
  done
  printf 'ready'
}

skills_status() {
  local skill_files=("$ROOT"/skills/*/SKILL.md)
  if [[ -e "${skill_files[0]}" ]]; then
    printf 'ready'
  else
    printf 'missing'
  fi
}

summary_mode() {
  if [[ -d "$PRODUCT_ROOT/.git" ]]; then
    printf 'development'
  elif dashboard_data_current_lesson_step "$ROOT/learning/LESSON_STATE_14_DAYS.tsv" >/dev/null 2>&1 || dashboard_data_current_lesson_step "$ROOT/learning/LESSON_STATE.tsv" >/dev/null 2>&1; then
    printf 'learning'
  elif [[ -d "$ROOT/.git" ]]; then
    printf 'maintenance'
  else
    printf 'unknown'
  fi
}

