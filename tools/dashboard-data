dashboard_git_operation_mode() {
  local action="$1"
  git_workflow_action_mode "$action" "$ROOT" 2>/dev/null || printf 'unknown'
}

dashboard_git_operation_status() {
  local action="$1"
  local mode="$2"
  local evidence_status="$3"

  case "$git_settings_status" in
    blocked|failed|missing|unknown)
      printf '%s' "$git_settings_status"
      return
      ;;
  esac

  case "$mode" in
    manual)
      printf 'manual_required'
      ;;
    after_approval)
      printf 'approval_required'
      ;;
    developer_auto)
      printf 'ready'
      ;;
    auto)
      case "$action" in
        push|pr)
          printf 'approval_required'
          ;;
        *)
          printf '%s' "$evidence_status"
          ;;
      esac
      ;;
    *)
      printf 'unknown'
      ;;
  esac
}

