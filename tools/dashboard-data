dashboard_document_decision_brief_row() {
  local id="$1"
  local file
  local row
  if [[ -n "${DASHBOARD_DOCUMENT_DECISION_BRIEF_ROW_CACHE[$id]+set}" ]]; then
    row="${DASHBOARD_DOCUMENT_DECISION_BRIEF_ROW_CACHE[$id]}"
    [[ "$row" != "__missing__" ]] || return 1
    printf '%s\n' "$row"
    return 0
  fi
  file="$(dashboard_document_decision_briefs_file)"
  if [[ ! -f "$file" ]]; then
    DASHBOARD_DOCUMENT_DECISION_BRIEF_ROW_CACHE[$id]="__missing__"
    return 1
  fi
  row="$(awk -F '\t' -v id="$id" '
    /^[[:space:]]*$/ { next }
    $1 ~ /^#/ { next }
    $1 == id { print; found = 1; exit }
    END { exit found ? 0 : 1 }
  ' "$file")" || {
    DASHBOARD_DOCUMENT_DECISION_BRIEF_ROW_CACHE[$id]="__missing__"
    return 1
  }
  DASHBOARD_DOCUMENT_DECISION_BRIEF_ROW_CACHE[$id]="$row"
  printf '%s\n' "$row"
}

