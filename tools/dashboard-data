dashboard_first_relative_artifact() {
  local rel_dir="$1"
  local name_filter="${2:-}"
  local root_dir="$ROOT/$rel_dir"
  [[ -d "$root_dir" ]] || return 1
  while IFS= read -r -d '' artifact_path; do
    artifact_path="${artifact_path#$ROOT/}"
    case "$artifact_path" in
      ""|/*|*..*|*[!A-Za-z0-9._/@%+=,-]*)
        continue
        ;;
    esac
    printf '%s' "$artifact_path"
    return 0
  done < <(
    if [[ -n "$name_filter" ]]; then
      find "$root_dir" -type f -name "$name_filter" -print0 2>/dev/null | sort -z
    else
      find "$root_dir" -type f -print0 2>/dev/null | sort -z
    fi
  )
  return 1
}

