dashboard_repository_candidate_path_state() {
  local raw_path="$1"
  local root
  root="$(lesson_expand_path "$raw_path")"
  if [[ -z "$root" ]]; then
    printf 'missing'
  elif [[ -d "$root" ]]; then
    printf 'configured'
  elif [[ -e "$root" ]]; then
    printf 'unknown'
  else
    printf 'missing'
  fi
}

dashboard_repository_candidate_git_state() {
  local raw_path="$1"
  local git_requirement="$2"
  local root
  if [[ "$git_requirement" != "required" ]]; then
    printf 'not_applicable'
    return
  fi
  root="$(lesson_expand_path "$raw_path")"
  if [[ -z "$root" ]]; then
    printf 'missing'
  elif [[ -d "$root/.git" ]]; then
    printf 'configured'
  elif [[ -d "$root" ]]; then
    printf 'missing'
  elif [[ -e "$root" ]]; then
    printf 'unknown'
  else
    printf 'missing'
  fi
}

dashboard_repository_candidate_status() {
  local path_state="$1"
  local git_state="$2"
  local git_requirement="$3"
  if [[ "$path_state" != "configured" ]]; then
    printf '%s' "$path_state"
    return
  fi
  if [[ "$git_requirement" == "required" && "$git_state" != "configured" ]]; then
    printf 'missing'
    return
  fi
  printf 'ready'
}

dashboard_repository_selection_state_for_menu() {
