dashboard_browser_debug_status_json() {
  local cli_root cli_status cli_repo manifest_status latest_review latest_package latest_result latest_report
  local review_status package_status result_status report_status overall_status review_ref package_ref result_ref

  cli_root="$(dashboard_browser_debug_cli_root 2>/dev/null || true)"
  if [[ -n "$cli_root" ]]; then
    cli_status="ready"
    cli_repo="browser-debug-cli"
  else
    cli_status="manual_required"
    cli_repo="not_selected"
  fi

  if [[ -f "$ROOT/tools/dashboard-browser-debug-manifest" ]]; then
    manifest_status="ready"
  else
    manifest_status="missing"
  fi

  latest_review="$(dashboard_first_relative_artifact ".browser-debug/review-artifacts" "*.json" 2>/dev/null || true)"
  latest_package="$(dashboard_first_relative_artifact ".browser-debug/agent-packages" "packet.json" 2>/dev/null || true)"
  latest_result="$(dashboard_first_relative_artifact ".browser-debug/agent-results" "*.json" 2>/dev/null || true)"
  latest_report="$(dashboard_first_relative_artifact ".browser-debug/reports" "*.md" 2>/dev/null || true)"
  review_status="$(dashboard_artifact_status "$latest_review")"
  package_status="$(dashboard_artifact_status "$latest_package")"
  result_status="$(dashboard_artifact_status "$latest_result")"
  report_status="$(dashboard_artifact_status "$latest_report")"

  if [[ "$manifest_status" != "ready" ]]; then
    overall_status="missing"
  elif [[ "$cli_status" != "ready" ]]; then
    overall_status="optional"
  elif [[ "$review_status" != "passed" ]]; then
    overall_status="not_run"
  elif [[ "$package_status" == "passed" && "$result_status" == "passed" && "$report_status" == "passed" ]]; then
    overall_status="passed"
  else
    overall_status="manual_required"
  fi

  review_ref="${latest_review:-.browser-debug/review-artifacts/review-index.json}"
  package_ref="${latest_package:-.browser-debug/agent-packages/packet.json}"
  result_ref="${latest_result:-.browser-debug/agent-results/agent-advisory-result.json}"

  dashboard_json_raw_object \
    "schema_version" "$(dashboard_json_string "0.1.0")" \
    "status" "$(dashboard_json_string "$overall_status")" \
    "target" "$(dashboard_json_string "Dashboard Control Center")" \
    "selected_cli_repository" "$(dashboard_json_string "$cli_repo")" \
    "tool" "$(dashboard_json_raw_object \
      "status" "$(dashboard_json_string "$cli_status")" \
      "command" "$(dashboard_json_string "node product:bin/browser-debug.js")" \
      "source" "$(dashboard_json_string "selected_free_development_repository")")" \
    "manifest" "$(dashboard_json_raw_object \
      "status" "$(dashboard_json_string "$manifest_status")" \
      "path" "$(dashboard_json_string "tools/dashboard-browser-debug-manifest")" \
      "command" "$(dashboard_json_string "tools/dashboard-browser-debug-manifest --output .tmp/dashboard-browser-debug-target.json")")" \
    "review" "$(dashboard_json_raw_object \
      "status" "$(dashboard_json_string "$review_status")" \
      "artifact_index_path" "$(dashboard_json_string "${latest_review:-not_collected}")" \
      "command" "$(dashboard_json_string "node product:bin/browser-debug.js review --target .tmp/dashboard-browser-debug-target.json --json")")" \
    "agent_package" "$(dashboard_json_raw_object \
      "status" "$(dashboard_json_string "$package_status")" \
      "path" "$(dashboard_json_string "${latest_package:-not_collected}")" \
      "command" "$(dashboard_json_string "node product:bin/browser-debug.js agent package --review-index $review_ref --surface local-subscription-agent --json")")" \
    "agent_result" "$(dashboard_json_raw_object \
      "status" "$(dashboard_json_string "$result_status")" \
      "path" "$(dashboard_json_string "${latest_result:-not_collected}")" \
      "command" "$(dashboard_json_string "node product:bin/browser-debug.js agent ingest --package $package_ref --input $result_ref --json")")" \
    "agent_report" "$(dashboard_json_raw_object \
      "status" "$(dashboard_json_string "$report_status")" \
