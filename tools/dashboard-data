dashboard_document_status_rollup() {
  DASHBOARD_DOCUMENT_STATUSES="$*" node <<'NODE'
const allowed = new Set([
  "missing",
  "ready",
  "passed",
  "failed",
  "blocked",
  "unknown",
  "approval_required",
  "optional",
  "cached",
  "not_run",
  "stale",
  "manual_required",
  "not_applicable",
]);
const priority = {
  failed: 0,
  blocked: 1,
  stale: 2,
  not_run: 3,
  unknown: 4,
  manual_required: 5,
  approval_required: 6,
  missing: 7,
  optional: 8,
  cached: 9,
  ready: 10,
  passed: 11,
  not_applicable: 12,
};
const statuses = String(process.env.DASHBOARD_DOCUMENT_STATUSES || "")
  .split(/\s+/)
  .map((value) => value.trim())
  .filter(Boolean)
  .map((value) => (allowed.has(value) ? value : "unknown"));
if (!statuses.length) {
  process.stdout.write("unknown");
  process.exit(0);
}
statuses.sort((left, right) => (priority[left] ?? 99) - (priority[right] ?? 99));
process.stdout.write(statuses[0]);
NODE
}

