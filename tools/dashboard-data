    return
  fi
  selected_row="$(product_repository_registry_selection_rows 2>/dev/null | awk -F '\t' -v menu_id="$menu_id" -v selected_id="$selected_id" '$1 == menu_id && $2 == selected_id { print; found = 1; exit } END { exit found ? 0 : 1 }' || true)"
  if [[ -n "$selected_row" ]]; then
    printf 'explicit'
  else
    printf 'fallback'
  fi
}

dashboard_repository_selection_option_json() {
  local menu_id="$1"
  local selected_id="$2"
  local git_requirement="$3"
  local repo_id="$4"
  local primary_menu_id="$5"
  local allowed_contexts="$6"
  local display_name="$7"
  local raw_path="$8"
  local product_type="$9"
  local source="${10}"
  local path_state git_state status selectable selected disabled_reason_key disabled_detail select_command normalized_source
  local -a allowed_context_values=()

  path_state="$(dashboard_repository_candidate_path_state "$raw_path")"
  git_state="$(dashboard_repository_candidate_git_state "$raw_path" "$git_requirement")"
  status="$(dashboard_repository_candidate_status "$path_state" "$git_state" "$git_requirement")"
  selectable="false"
  [[ "$status" != "ready" ]] || selectable="true"
  selected="false"
  [[ "$repo_id" != "$selected_id" ]] || selected="true"
  case "$status" in
    ready)
      disabled_reason_key="context.repositorySelection.selectable"
      disabled_detail="This registered repository can be selected for the current workflow context."
      ;;
    missing)
      disabled_reason_key="context.repositorySelection.pathMissing"
      disabled_detail="The registered repository path is missing or Git metadata is required but not available."
      ;;
    unknown)
      disabled_reason_key="context.repositorySelection.pathUnknown"
      disabled_detail="The registered repository path exists but cannot be interpreted as a readable directory."
      ;;
    *)
      disabled_reason_key="context.repositorySelection.unavailable"
      disabled_detail="This repository cannot be selected from the current dashboard snapshot."
      ;;
  esac
  if [[ "$selected" == "true" ]]; then
    select_command="tools/product-repository-registry selected $menu_id"
  elif [[ "$selectable" == "true" ]]; then
    select_command="tools/product-repository-registry select $menu_id $repo_id --confirm"
  else
    select_command="tools/product-repository-registry verify --context $menu_id --all"
  fi
  case "$source" in
    explicit|discover|legacy) normalized_source="$source" ;;
    *) normalized_source="unknown" ;;
  esac
  IFS='|' read -r -a allowed_context_values <<<"$allowed_contexts"

  printf '{"repo_id":'
  dashboard_json_string "$repo_id"
  printf ',"display_name":'
  dashboard_json_string "$display_name"
  printf ',"primary_menu_id":'
  dashboard_json_string "$primary_menu_id"
  printf ',"allowed_contexts":'
  dashboard_json_string_array "${allowed_context_values[@]}"
  printf ',"product_type":'
  dashboard_json_string "$product_type"
  printf ',"registration_source":'
  dashboard_json_string "$normalized_source"
  printf ',"path_state":'
  dashboard_json_string "$path_state"
  printf ',"git_state":'
  dashboard_json_string "$git_state"
  printf ',"status":'
  dashboard_json_string "$status"
  printf ',"selectable":%s' "$selectable"
  printf ',"selected":%s' "$selected"
  printf ',"disabled_reason_key":'
  dashboard_json_string "$disabled_reason_key"
  printf ',"disabled_detail":'
  dashboard_json_string "$disabled_detail"
  printf ',"select_command":'
  dashboard_json_string "$select_command"
  printf '}'
}

dashboard_repository_selection_json() {
  local menu_id="$1"
  local workflow_context selected_id selection_state status current_name git_requirement registry_file selection_file
  local repo_id primary_menu_id allowed_contexts display_name raw_path product_type source option_json selected_option_status
  local -a options=()
  workflow_context="$(dashboard_selected_workflow_context "$menu_id")"
  registry_file="$(dashboard_data_relative_path "$(product_repository_registry_file)")"
  selection_file="$(dashboard_data_relative_path "$(product_repository_registry_selection_file)")"
  if [[ "$(dashboard_context_product_repo_required "$menu_id")" != "true" ]] || ! product_repository_registry_context_supported "$menu_id"; then
    printf '{"status":"not_applicable","menu_id":'
    dashboard_json_string "$menu_id"
    printf ',"workflow_context":'
    dashboard_json_string "$workflow_context"
    printf ',"current_repo_id":"not_applicable","current_repository_name":"not_applicable","selection_state":"not_applicable","registry_file":'
    dashboard_json_string "$registry_file"
    printf ',"selection_file":'
    dashboard_json_string "$selection_file"
    printf ',"options":[]}'
    return
  fi

  selected_id="$(product_repository_registry_id_for_menu "$menu_id" 2>/dev/null || true)"
  selection_state="$(dashboard_repository_selection_state_for_menu "$menu_id" "$selected_id")"
  current_name="not_selected"
  if [[ -n "$selected_id" ]]; then
    current_name="$(product_repository_registry_field_for_id "$selected_id" display_name 2>/dev/null || printf 'not_selected')"
  fi
  git_requirement="$(dashboard_product_git_requirement_for_menu "$menu_id")"
  selected_option_status=""
  while IFS=$'\t' read -r repo_id primary_menu_id allowed_contexts display_name raw_path product_type source; do
    [[ -n "$repo_id" ]] || continue
    option_json="$(dashboard_repository_selection_option_json "$menu_id" "$selected_id" "$git_requirement" "$repo_id" "$primary_menu_id" "$allowed_contexts" "$display_name" "$raw_path" "$product_type" "$source")"
    options+=("$option_json")
    if [[ "$repo_id" == "$selected_id" ]]; then
      selected_option_status="$(dashboard_json_get_field "$option_json" status 2>/dev/null || true)"
    fi
  done < <(product_repository_registry_rows_for_context "$menu_id" 2>/dev/null || true)

  if [[ -z "$selected_id" ]]; then
    if [[ "${#options[@]}" -gt 0 ]]; then
      status="manual_required"
    else
      status="missing"
    fi
  else
    status="${selected_option_status:-unknown}"
  fi

  printf '{"status":'
  dashboard_json_string "$status"
  printf ',"menu_id":'
  dashboard_json_string "$menu_id"
  printf ',"workflow_context":'
  dashboard_json_string "$workflow_context"
  printf ',"current_repo_id":'
  dashboard_json_string "${selected_id:-not_selected}"
  printf ',"current_repository_name":'
  dashboard_json_string "$current_name"
  printf ',"selection_state":'
  dashboard_json_string "$selection_state"
  printf ',"registry_file":'
  dashboard_json_string "$registry_file"
  printf ',"selection_file":'
  dashboard_json_string "$selection_file"
  printf ',"options":'
  dashboard_json_raw_array "${options[@]}"
  printf '}'
}

dashboard_available_context_selectable() {
  local menu_id="$1"
  local status="$2"
  local path_state
  if [[ "$(dashboard_context_product_repo_required "$menu_id")" == "true" ]]; then
    path_state="$(dashboard_target_repository_path_state "$menu_id")"
    if [[ "$path_state" != "configured" ]]; then
      printf 'false'
      return
    fi
    if [[ "$menu_id" == "free-development" && "$status" == "not_run" ]]; then
      printf 'true'
      return
    fi
  fi
  case "$status" in
    missing|not_run)
      printf 'false'
      ;;
    *)
      printf 'true'
      ;;
  esac
}

dashboard_available_context_reason_key() {
  local menu_id="$1"
  local status="$2"
  local selectable="$3"
  local workflow_context path_state
  if [[ "$selectable" == "true" ]]; then
    printf 'context.menuAvailability.selectable'
    return
  fi
  workflow_context="$(dashboard_selected_workflow_context "$menu_id")"
  path_state="$(dashboard_target_repository_path_state "$menu_id")"
  if [[ "$status" == "not_run" ]]; then
    printf 'context.menuAvailability.notStarted'
  elif [[ "$(dashboard_context_product_repo_required "$menu_id")" == "true" && "$path_state" == "missing" ]]; then
    printf 'context.menuAvailability.productRepositoryMissing'
  elif [[ "$(dashboard_context_product_repo_required "$menu_id")" == "true" && "$path_state" == "unknown" ]]; then
    printf 'context.menuAvailability.productRepositoryUnknown'
  elif [[ "$workflow_context" == "lesson" && "$status" == "missing" ]]; then
    printf 'context.menuAvailability.lessonMissing'
  else
    printf 'context.menuAvailability.contextMissing'
  fi
}

dashboard_available_context_detail() {
  local menu_id="$1"
  local status="$2"
  local selectable="$3"
  local target_name
  target_name="$(dashboard_target_repository_name "$menu_id")"
  if [[ "$selectable" == "true" ]]; then
    printf 'This menu can be inspected from the current dashboard snapshot.'
    return
  fi
  case "$(dashboard_available_context_reason_key "$menu_id" "$status" "$selectable")" in
    context.menuAvailability.productRepositoryMissing)
      printf 'The configured target repository is missing: %s.' "$target_name"
      ;;
    context.menuAvailability.productRepositoryUnknown)
      printf 'The configured target repository path is not a readable directory: %s.' "$target_name"
      ;;
    context.menuAvailability.lessonMissing)
      printf 'The lesson state for this menu is missing or has not started.'
      ;;
    context.menuAvailability.notStarted)
      printf 'This menu has not been started yet.'
      ;;
    *)
      printf 'Required context data is missing for this menu.'
      ;;
