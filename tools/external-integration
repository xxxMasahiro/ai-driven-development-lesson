#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$SCRIPT_DIR/lib/lesson_common.sh"
# shellcheck source=tools/lib/product_repository_authority.sh
source "$SCRIPT_DIR/lib/product_repository_authority.sh"
# shellcheck source=tools/lib/product_workflow_git_usage.sh
source "$SCRIPT_DIR/lib/product_workflow_git_usage.sh"

COMMAND="${1:-status}"

usage() {
  cat <<'USAGE'
Usage:
  tools/external-integration status
  tools/external-integration start
  tools/external-integration gate-plan
  tools/external-integration gate

Rules:
  - This path can follow Free Development Mode or start from an existing product repository.
  - It does not replace the lesson, free-development, product improvement, or MCP learning paths.
  - The learner chooses the external tool and scope before implementation.
USAGE
}

check_scope_docs() {
  local product_root missing file
  product_root="$(product_workflow_git_usage_repository_root_for_context external-integration)"
  missing=0
  for file in REQUIREMENTS.md SPECIFICATION.md IMPLEMENTATION_PLAN.md; do
    if [[ ! -s "$product_root/docs/product/$file" ]]; then
      printf 'missing external-integration scope document: docs/product/%s\n' "$file" >&2
      missing=1
    fi
  done
  [[ "$missing" -eq 0 ]] || exit 1
}

case "$COMMAND" in
  status|現在地)
    printf 'External Integration: optional extension path\n'
    printf 'Product repository: %s\n' "$(product_workflow_git_usage_repository_root_for_context external-integration 2>/dev/null || printf 'not_selected')"
    printf 'Typical targets: calendar, task service, spreadsheet, documentation, API, or MCP-style resource.\n'
    "$LESSON_ROOT/tools/product-security" advise --context external-integration || true
    lesson_menu_print_readiness "External Integration"
    lesson_product_profile_print_readiness 6 "Product name"
    ;;
  start|開始)
    lesson_menu_require_start_approval "External Integration" "${2:-}"
    lesson_menu_require_settings "External Integration"
    product_workflow_git_usage_repository_boundary_gate external-integration
    lesson_product_profile_require 6 "External Integration"
    product_workflow_git_usage_instruction_gate external-integration
    cat <<'PROMPT'
External Integration start prompt:

I want to extend my product by connecting it to an external tool.
First inspect docs/product/REQUIREMENTS.md, docs/product/SPECIFICATION.md, docs/product/IMPLEMENTATION_PLAN.md, docs/workflow/TASK_TRACKER.md, and docs/workflow/HANDOFF.md.
Then ask me which external tool I want to connect, what information should move, and what should stay out of scope.
Before implementation, collect and record the connected service, data sent, data received, write behavior, OAuth scopes, token storage, redirect URI, token refresh and revoke behavior, webhook signature handling, rate limits, sandbox or test-account usage, prohibited log output, and rollback or recovery approach.
Record that approval in EXTERNAL_INTEGRATION_SECURITY.md before the gate is passed.
Do not implement until I approve the smallest useful integration plan.
PROMPT
    printf '\nProduct security guidance:\n'
    "$LESSON_ROOT/tools/product-security" advise --context external-integration || true
    ;;
  gate-plan|plan)
    product_workflow_git_usage_gate_plan external-integration integration
    ;;
  gate|確認)
    lesson_menu_require_settings "External Integration"
    product_workflow_git_usage_repository_boundary_gate external-integration
    lesson_product_profile_require 6 "External Integration"
    check_scope_docs
    product_workflow_git_usage_gate external-integration integration
    printf 'External Integration gate passed.\n'
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n' "$COMMAND" >&2
    usage
    exit 1
    ;;
esac
