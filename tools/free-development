#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=tools/lib/lesson_common.sh
source "$SCRIPT_DIR/lib/lesson_common.sh"
# shellcheck source=tools/lib/product_repository_authority.sh
source "$SCRIPT_DIR/lib/product_repository_authority.sh"
# shellcheck source=tools/lib/product_workflow_git_usage.sh
source "$SCRIPT_DIR/lib/product_workflow_git_usage.sh"

COMMAND="${1:-status}"

usage() {
  cat <<'USAGE'
Usage:
  tools/free-development status
  tools/free-development start
  tools/free-development gate-plan
  tools/free-development gate

Rules:
  - This mode is optional and starts only after the learner chooses it.
  - It does not replace the 7-day or 14-day lesson flows.
  - The learner may choose the language, framework, database, payment system, and tools.
  - Product work must follow the repository workflow: stack choice, requirements, specification, implementation plan, task tracker, handoff, local checks, and the selected Git usage mode.
USAGE
}

case "$COMMAND" in
  status|現在地)
    printf 'Free Development Mode: optional\n'
    printf 'Guide: %s\n' "$LESSON_ROOT/free-development/FREE_DEVELOPMENT_MODE.md"
    printf 'Product repository: %s\n' "$(product_workflow_git_usage_repository_root_for_context free-development 2>/dev/null || printf 'not_selected')"
    "$LESSON_ROOT/tools/product-security" advise --context free-development || true
    lesson_menu_print_readiness "Free Development Mode"
    lesson_product_profile_print_readiness 4 "Product name"
    ;;
  start|開始)
    lesson_menu_require_start_approval "Free Development Mode" "${2:-}"
    lesson_menu_require_settings "Free Development Mode"
    product_workflow_git_usage_repository_boundary_gate free-development
    lesson_product_profile_require 4 "Free Development Mode"
    printf 'Free Development Mode start prompt:\n\n'
    sed -n '/^## Product Setup Prompt$/,/^## Completion Gate$/p' "$LESSON_ROOT/free-development/FREE_DEVELOPMENT_MODE.md" | sed '$d'
    printf '\nProduct security guidance:\n'
    "$LESSON_ROOT/tools/product-security" advise --context free-development || true
    ;;
  gate-plan|plan)
    product_workflow_git_usage_gate_plan free-development all
    ;;
  gate|確認)
    lesson_menu_require_settings "Free Development Mode"
    product_workflow_git_usage_repository_boundary_gate free-development
    lesson_product_profile_require 4 "Free Development Mode"
    product_workflow_git_usage_gate free-development all
    printf 'Free Development Mode gate passed.\n'
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n' "$COMMAND" >&2
    usage
    exit 1
    ;;
esac
