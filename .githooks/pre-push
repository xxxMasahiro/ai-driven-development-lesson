#!/usr/bin/env bash
# sync_id: repository_document_sync_enforcement
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
ZERO_SHA="0000000000000000000000000000000000000000"
checked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -n "${local_ref:-}" ]] || continue
  [[ "$local_sha" != "$ZERO_SHA" ]] || continue
  [[ "$local_ref" == refs/heads/* ]] || continue

  if [[ "$remote_sha" == "$ZERO_SHA" ]]; then
    node "$ROOT/tools/check_repository_document_sync.mjs" --repo "$ROOT" --initial-head "$local_sha"
  else
    node "$ROOT/tools/check_repository_document_sync.mjs" --repo "$ROOT" --range-mode push --base "$remote_sha" --head "$local_sha"
  fi
  checked=$((checked + 1))
done

if [[ "$checked" -eq 0 ]]; then
  printf 'Repository document sync pre-push: no branch updates to inspect.\n'
fi
